// HTTP-сервис: Заказ на производство.

Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";
	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция РазобратьДату(ЗначСтрока, ПоУмолчанию, ЭтоКонецДня)
	Если ЗначСтрока = "" Тогда
		Возврат ПоУмолчанию;
	КонецЕсли;

	КолЧастейДаты = СтрДлина("000"); // 3
	ДлинаГода = СтрДлина("0000"); // 4

	Части = СтрРазделить(ЗначСтрока, ".");
	Если Части.Количество() = КолЧастейДаты Тогда
		ДатаРез = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
		Если ЭтоКонецДня Тогда
			ДатаРез = КонецДня(ДатаРез);
		КонецЕсли;
		Возврат ДатаРез;
	КонецЕсли;

	Части = СтрРазделить(ЗначСтрока, "-");
	Если Части.Количество() <> КолЧастейДаты Тогда
		Возврат ПоУмолчанию;
	КонецЕсли;

	Если СтрДлина(Части[0]) = ДлинаГода Тогда
		ДатаРез = Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
	Иначе
		ДатаРез = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
	КонецЕсли;

	Если ЭтоКонецДня Тогда
		ДатаРез = КонецДня(ДатаРез);
	КонецЕсли;

	Возврат ДатаРез;
КонецФункции

Функция РазобратьПериодFromTo(ЗначFrom, ЗначTo, ДатаПоУмолчанию, МассивОшибок)
	Рез = Новый Структура;
	Рез.Вставить("ИспользоватьПериод", Ложь);
	Рез.Вставить("ДатаНачала", ДатаПоУмолчанию);
	Рез.Вставить("ДатаОкончания", ДатаПоУмолчанию);

	Если ЗначFrom = "" Или ЗначTo = "" Тогда
		Возврат Рез;
	КонецЕсли;

	ДатаНачала = РазобратьДату(ЗначFrom, ДатаПоУмолчанию, Ложь);
	ДатаОкончания = РазобратьДату(ЗначTo, ДатаПоУмолчанию, Истина);

	Если ДатаНачала <> ДатаПоУмолчанию И ДатаОкончания <> ДатаПоУмолчанию Тогда
		Рез.Вставить("ИспользоватьПериод", Истина);
		Рез.Вставить("ДатаНачала", ДатаНачала);
		Рез.Вставить("ДатаОкончания", ДатаОкончания);
	Иначе
		МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
	КонецЕсли;

	Возврат Рез;
КонецФункции

Функция ПолучитьНаименование(ЗначениеСсылки)
	Если ЗначениеЗаполнено(ЗначениеСсылки) Тогда
		Возврат Строка(ЗначениеСсылки.Наименование);
	КонецЕсли;

	Возврат "";
КонецФункции

Функция СформироватьСтрокуТЧ(СтрокаТЧ)
	Стр = Новый Структура;
	Стр.Вставить("Номенклатура", ПолучитьНаименование(СтрокаТЧ.Номенклатура));
	Стр.Вставить("Количество", СтрокаТЧ.Количество);
	Стр.Вставить("ЕдиницаИзмерения", ПолучитьНаименование(СтрокаТЧ.ЕдиницаИзмерения));
	Возврат Стр;
КонецФункции

Функция ПостроитьМассивСтрокТЧ(ТабЧасть)
	Массив = Новый Массив;
	Для Каждого СтрокаТЧ Из ТабЧасть Цикл
		Стр = СформироватьСтрокуТЧ(СтрокаТЧ);
		Массив.Добавить(Стр);
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция СформироватьЗаказ(Выборка, ПолныйОтвет, МассивОшибок)
	Заказ = Новый Структура;

	Если ПолныйОтвет Тогда
		Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
			Заказ.Вставить("Ссылка", Строка(Выборка.Ссылка));
		КонецЕсли;
	КонецЕсли;

	Заказ.Вставить("Номер", ?(ЗначениеЗаполнено(Выборка.Номер), Строка(Выборка.Номер), "Не указан"));
	Заказ.Вставить("Дата", ?(ЗначениеЗаполнено(Выборка.Дата), Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"), "Не указана"));
	Заказ.Вставить("Договор", ?(ЗначениеЗаполнено(Выборка.Комментарий), Строка(Выборка.Комментарий), "Не указан"));
	Заказ.Вставить("Организация", ?(ЗначениеЗаполнено(Выборка.Организация), Строка(Выборка.Организация), ""));
	Заказ.Вставить("Ответственный", ?(ЗначениеЗаполнено(Выборка.Ответственный), Строка(Выборка.Ответственный), ""));

	Если ПолныйОтвет Тогда
		Если Не ЗначениеЗаполнено(Выборка.Ссылка) Тогда
			Возврат Заказ;
		КонецЕсли;

		Попытка
			ОбъектЗаказ = Выборка.Ссылка.ПолучитьОбъект();
			Заказ.Вставить("Продукция",  ПостроитьМассивСтрокТЧ(ОбъектЗаказ.Продукция));
			Заказ.Вставить("Материалы",  ПостроитьМассивСтрокТЧ(ОбъектЗаказ.Материалы));
		Исключение
			ТекстОшибки = "Заказ на производство №" + Выборка.Номер + " от "
				+ Формат(Выборка.Дата, "ДФ=dd.MM.yyyy") + ": " + ОписаниеОшибки();
			МассивОшибок.Добавить(ТекстОшибки);
		КонецПопытки;
	КонецЕсли;

	Возврат Заказ;
КонецФункции

Функция GetMOrders(Запрос) Экспорт
	МассивЗаказов = Новый Массив;
	МассивОшибок = Новый Массив;
	HTTPСтатусОшибки = 500;
	HTTPСтатусУспеха = 200;

	ДатаПоУмолчанию = Дата(1, 1, 1);

	Попытка
		ЗначFrom = ПолучитьСтроковойПараметр(Запрос, "from");
		ЗначTo = ПолучитьСтроковойПараметр(Запрос, "to");
		Период = РазобратьПериодFromTo(ЗначFrom, ЗначTo, ДатаПоУмолчанию, МассивОшибок);
		ИспользоватьПериод = Период.ИспользоватьПериод;
		ДатаНачала = Период.ДатаНачала;
		ДатаОкончания = Период.ДатаОкончания;

		ЗначCode = ПолучитьСтроковойПараметр(Запрос, "code");
		Если ЗначCode <> "" Тогда
			ИспользоватьФильтрНомер = Истина;
			ШаблонНомер = "%" + ЗначCode + "%";
		Иначе
			ИспользоватьФильтрНомер = Ложь;
			ШаблонНомер = "%";
		КонецЕсли;

		ЗначContract = ПолучитьСтроковойПараметр(Запрос, "contract");
		Если ЗначContract <> "" Тогда
			ЗначContract = СтрЗаменить(ЗначContract, "_slash_", "/");
			ИспользоватьФильтрДоговор = Истина;
			ШаблонДоговор = "%" + ЗначContract + "%";
		Иначе
			ИспользоватьФильтрДоговор = Ложь;
			ШаблонДоговор = "%";
		КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = ПолучитьСтроковойПараметр(Запрос, "full");
		Если ЗначFull <> "" Тогда
			ПолныйОтвет = (ВРег(ЗначFull) = "1"
				Или ВРег(ЗначFull) = "TRUE"
				Или ВРег(ЗначFull) = "YES"
				Или ВРег(ЗначFull) = "ДА");
		КонецЕсли;

		Условия = "";
		Если ИспользоватьФильтрНомер Тогда
			Условия = Условия + " И ЗаказНаПроизводство.Номер ПОДОБНО &ШаблонНомер";
		КонецЕсли;
		Если ИспользоватьФильтрДоговор Тогда
			Условия = Условия + " И ЗаказНаПроизводство.Комментарий ПОДОБНО &ШаблонДоговор";
		КонецЕсли;
		Если ИспользоватьПериод Тогда
			Условия = Условия + " И (ЗаказНаПроизводство.Дата >= &ДатаНачала И ЗаказНаПроизводство.Дата <= &ДатаОкончания)";
		КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	ЗаказНаПроизводство.Ссылка КАК Ссылка,
		|	ЗаказНаПроизводство.Номер КАК Номер,
		|	ЗаказНаПроизводство.Дата КАК Дата,
		|	ЗаказНаПроизводство.Комментарий КАК Комментарий,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказНаПроизводство.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказНаПроизводство.Ответственный) КАК Ответственный
		|ИЗ
		|	Документ.ЗаказНаПроизводство КАК ЗаказНаПроизводство
		|ГДЕ 1=1" + Условия + "
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказНаПроизводство.Дата";

		ЗапросБД.УстановитьПараметр("ШаблонНомер", ШаблонНомер);
		ЗапросБД.УстановитьПараметр("ШаблонДоговор", ШаблонДоговор);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Заказ = СформироватьЗаказ(Выборка, ПолныйОтвет, МассивОшибок);
			МассивЗаказов.Добавить(Заказ);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивЗаказов);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();

		Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(HTTPСтатусОшибки);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
