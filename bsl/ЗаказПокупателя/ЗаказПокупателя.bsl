	Возврат Неопределено;
КонецФункции

Функция НайтиСсылкуСпецификацииПоИмениВыходногоИзделия(ИмяНоменклатуры)
	Если ИмяНоменклатуры = "" Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросСпецификацииПоВыходномуИзделию = Новый Запрос;
	ЗапросСпецификацииПоВыходномуИзделию.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Спецификации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СпецификацииНоменклатуры КАК Спецификации
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СпецификацииНоменклатуры.ВыходныеИзделия КАК ВыходныеИзделия
	|	ПО ВыходныеИзделия.Ссылка = Спецификации.Ссылка
	|ГДЕ
	|	НЕ Спецификации.ЭтоГруппа
	|	И НЕ Спецификации.ПометкаУдаления
	|	И ПРЕДСТАВЛЕНИЕ(ВыходныеИзделия.Номенклатура) = &Наименование
	|УПОРЯДОЧИТЬ ПО
	|	Спецификации.Активная УБЫВ,
	|	Спецификации.ДатаУтверждения УБЫВ";
	ЗапросСпецификацииПоВыходномуИзделию.УстановитьПараметр("Наименование", ИмяНоменклатуры);
	РезультатПоВыходномуИзделию = ЗапросСпецификацииПоВыходномуИзделию.Выполнить().Выбрать();
	Если РезультатПоВыходномуИзделию.Следующий() Тогда
		Возврат РезультатПоВыходномуИзделию.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НайтиСсылкуСпецификацииПоНоменклатуре(НоменклатураСсылка)
	ЗапросСпецификации = Новый Запрос;
	ЗапросСпецификации.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Спецификации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СпецификацииНоменклатуры КАК Спецификации
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СпецификацииНоменклатуры.ВыходныеИзделия КАК ВыходныеИзделия
	|	ПО ВыходныеИзделия.Ссылка = Спецификации.Ссылка
	|ГДЕ
	|	НЕ Спецификации.ЭтоГруппа
	|	И НЕ Спецификации.ПометкаУдаления
	|	И ВыходныеИзделия.Номенклатура = &Номенклатура
	|УПОРЯДОЧИТЬ ПО
	|	Спецификации.Активная УБЫВ,
	|	Спецификации.ДатаУтверждения УБЫВ";
	ЗапросСпецификации.УстановитьПараметр("Номенклатура", НоменклатураСсылка);

	РезультатСпецификации = ЗапросСпецификации.Выполнить().Выбрать();
	Если РезультатСпецификации.Следующий() Тогда
		Возврат РезультатСпецификации.Ссылка;
	КонецЕсли;

	ИмяНоменклатуры = "";
	Попытка
		ИмяНоменклатуры = СокрЛП(Строка(НоменклатураСсылка.Наименование));
	Исключение
		ИмяНоменклатуры = "";
	КонецПопытки;

	СсылкаСпецификации = НайтиСсылкуСпецификацииПоИмениВыходногоИзделия(ИмяНоменклатуры);
	Если Не ЗначениеЗаполнено(СсылкаСпецификации) Тогда
		СсылкаСпецификации = НайтиСсылкуСпецификацииПоКодуНоменклатуры(НоменклатураСсылка);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(СсылкаСпецификации) Тогда
		СсылкаСпецификации = НайтиСсылкуСпецификацииПоИмени(ИмяНоменклатуры);
	КонецЕсли;
	// Последний fallback: ПОДОБНО по токенам наименования (один запрос ПЕРВЫЕ 1, без перебора кандидатов).
	Если Не ЗначениеЗаполнено(СсылкаСпецификации) И ИмяНоменклатуры <> "" Тогда
		ШаблонПоИмени = ПостроитьШаблонПоИмени(ИмяНоменклатуры);
		ЗапросПоТокенам = Новый Запрос;
		ЗапросПоТокенам.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спецификации.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СпецификацииНоменклатуры КАК Спецификации
		|ГДЕ
		|	НЕ Спецификации.ЭтоГруппа
		|	И НЕ Спецификации.ПометкаУдаления
		|	И Спецификации.Наименование ПОДОБНО &Шаблон
		|УПОРЯДОЧИТЬ ПО
		|	Спецификации.Активная УБЫВ,
		|	Спецификации.ДатаУтверждения УБЫВ";
		ЗапросПоТокенам.УстановитьПараметр("Шаблон", ШаблонПоИмени);
		РезультатПоТокенам = ЗапросПоТокенам.Выполнить().Выбрать();
		Если РезультатПоТокенам.Следующий() Тогда
			СсылкаСпецификации = РезультатПоТокенам.Ссылка;
		КонецЕсли;
	КонецЕсли;

	Возврат СсылкаСпецификации;
КонецФункции

Функция ПолучитьДанныеСпецификацииПоНоменклатуре(НоменклатураСсылка, КэшСпецификаций)
	Если Не ЗначениеЗаполнено(НоменклатураСсылка) Тогда
		Возврат Новый Структура("Наименование,ПлановаяСебестоимость", "", 0);
	КонецЕсли;

	ЗначениеИзКэша = КэшСпецификаций.Получить(НоменклатураСсылка);
	Если ЗначениеИзКэша <> Неопределено Тогда
		Возврат ЗначениеИзКэша;
	КонецЕсли;

	ДанныеСпецификации = Новый Структура("Наименование,ПлановаяСебестоимость", "", 0);

	Попытка
		СсылкаСпецификации = НайтиСсылкуСпецификацииПоНоменклатуре(НоменклатураСсылка);

		Если ЗначениеЗаполнено(СсылкаСпецификации) Тогда
			Попытка
				ДанныеСпецификации.Наименование = СокрЛП(Строка(СсылкаСпецификации.Наименование));
			Исключение
				ДанныеСпецификации.Наименование = "";
			КонецПопытки;
			ДанныеСпецификации.ПлановаяСебестоимость =
				РассчитатьПлановуюСебестоимостьСпецификацииПоСсылке(СсылкаСпецификации);
		КонецЕсли;
	Исключение
		ДанныеСпецификации.ПлановаяСебестоимость = 0;
	КонецПопытки;

	Если ЗначениеЗаполнено(ДанныеСпецификации.Наименование)
		Или ДанныеСпецификации.ПлановаяСебестоимость <> 0 Тогда
		КэшСпецификаций.Вставить(НоменклатураСсылка, ДанныеСпецификации);
	КонецЕсли;

	Возврат ДанныеСпецификации;
КонецФункции

Функция ПлановаяСебестоимостьИСпецификацияДляСтрокиТовара(СтрТЧ, КэшСпецификаций)
	// MCP user-1c-upp-mcp: Документ.ЗаказПокупателя.Товары - реквизиты Спецификация, ПлановаяСебестоимость.
	// Ссылку на спецификацию из строки нужно использовать в приоритете; не подменять её поиском по номенклатуре.
	КлючиПоляПланИСпец = "ПлановаяСебестоимость,Спецификация";
	ПлановаяСебестоимость = ?(СтрТЧ.ПлановаяСебестоимость = Неопределено, 0, СтрТЧ.ПлановаяСебестоимость);
	Спецификация = "";
	Если ЗначениеЗаполнено(СтрТЧ.Спецификация) Тогда
		Попытка
			Спецификация = СокрЛП(Строка(СтрТЧ.Спецификация.Наименование));
		Исключение
			Спецификация = "";
		КонецПопытки;
	КонецЕсли;

	Если ПлановаяСебестоимость <> 0 Тогда
		Возврат Новый Структура(КлючиПоляПланИСпец, ПлановаяСебестоимость, Спецификация);
	КонецЕсли;

	Если ЗначениеЗаполнено(СтрТЧ.Спецификация) Тогда
		ПлановаяСебестоимость = РассчитатьПлановуюСебестоимостьСпецификацииПоСсылке(СтрТЧ.Спецификация);
		Возврат Новый Структура(КлючиПоляПланИСпец, ПлановаяСебестоимость, Спецификация);
	КонецЕсли;

	Если Не ЗначениеЗаполнено(СтрТЧ.Номенклатура) Тогда
		Возврат Новый Структура(КлючиПоляПланИСпец, ПлановаяСебестоимость, Спецификация);
	КонецЕсли;

	ДанныеСпецификации = ПолучитьДанныеСпецификацииПоНоменклатуре(СтрТЧ.Номенклатура, КэшСпецификаций);
	Если Спецификация = "" И ЗначениеЗаполнено(ДанныеСпецификации.Наименование) Тогда
		Спецификация = ДанныеСпецификации.Наименование;
	КонецЕсли;
	Если ПлановаяСебестоимость = 0 И ДанныеСпецификации.ПлановаяСебестоимость <> 0 Тогда
		ПлановаяСебестоимость = ДанныеСпецификации.ПлановаяСебестоимость;
	КонецЕсли;

	Возврат Новый Структура(КлючиПоляПланИСпец, ПлановаяСебестоимость, Спецификация);
КонецФункции

Функция СформироватьСтрокуТовараПолногоОтвета(СтрТЧ, КэшСпецификаций)
	СтрокаТовара = Новый Структура;
	ТекстНеУказано = "Не указано";
	ПоляСпецификации = ПлановаяСебестоимостьИСпецификацияДляСтрокиТовара(СтрТЧ, КэшСпецификаций);
	ПлановаяСебестоимость = ПоляСпецификации.ПлановаяСебестоимость;
	Спецификация = ПоляСпецификации.Спецификация;

	СтрокаТовара.Вставить(
		"Номенклатура",
		?(ЗначениеЗаполнено(СтрТЧ.Номенклатура), Строка(СтрТЧ.Номенклатура.Наименование), ТекстНеУказано));
	СтрокаТовара.Вставить(
		"ХарактеристикаНоменклатуры",
		?(ЗначениеЗаполнено(СтрТЧ.ХарактеристикаНоменклатуры), Строка(СтрТЧ.ХарактеристикаНоменклатуры.Наименование), ""));
	СтрокаТовара.Вставить("Количество", ?(СтрТЧ.Количество = Неопределено, 0, СтрТЧ.Количество));
	СтрокаТовара.Вставить("Цена", ?(СтрТЧ.Цена = Неопределено, 0, СтрТЧ.Цена));
	СтрокаТовара.Вставить("Сумма", ?(СтрТЧ.Сумма = Неопределено, 0, СтрТЧ.Сумма));
	СтрокаТовара.Вставить(
		"ЕдиницаИзмерения",
		?(ЗначениеЗаполнено(СтрТЧ.ЕдиницаИзмерения), Строка(СтрТЧ.ЕдиницаИзмерения.Наименование), ""));
	СтрокаТовара.Вставить("КоличествоМест", ?(СтрТЧ.КоличествоМест = Неопределено, 0, СтрТЧ.КоличествоМест));
	СтрокаТовара.Вставить("Коэффициент", ?(СтрТЧ.Коэффициент = Неопределено, 0, СтрТЧ.Коэффициент));
	СтрокаТовара.Вставить("ПлановаяСебестоимость", ПлановаяСебестоимость);
	СтрокаТовара.Вставить("СуммаНДС", ?(СтрТЧ.СуммаНДС = Неопределено, 0, СтрТЧ.СуммаНДС));
	СтрокаТовара.Вставить("СтавкаНДС", Строка(?(СтрТЧ.СтавкаНДС = Неопределено, "", СтрТЧ.СтавкаНДС)));
	СтрокаТовара.Вставить("Спецификация", Спецификация);
	Возврат СтрокаТовара;
КонецФункции

Функция СформироватьТоварыПолногоОтвета(СсылкаЗаказа)
	МассивТоваров = Новый Массив;
	КэшСпецификаций = Новый Соответствие;
	ОбъектЗаказа = СсылкаЗаказа.ПолучитьОбъект();
	Для каждого СтрТЧ Из ОбъектЗаказа.Товары Цикл
		МассивТоваров.Добавить(СформироватьСтрокуТовараПолногоОтвета(СтрТЧ, КэшСпецификаций));
	КонецЦикла;
	Возврат МассивТоваров;
КонецФункции

Функция ПолучитьВыборкуЗаказов(Фильтры)
	ЗапросБД = Новый Запрос;
	УсловияГде = "";

	Если Фильтры.ИспользоватьПериод Тогда
		УсловияГде = УсловияГде + "
			|	И ЗК.Дата >= &ДатаНачала
			|	И ЗК.Дата <= &ДатаОкончания";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрНомер Тогда
		УсловияГде = УсловияГде + "
			|	И ЗК.Номер ПОДОБНО &НомерШаблон";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрДата Тогда
		УсловияГде = УсловияГде + "
			|	И ЗК.Дата >= &ДатаФильтр
			|	И ЗК.Дата <= &ДатаФильтрКонец";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрСумма Тогда
		УсловияГде = УсловияГде + "
			|	И ЗК.СуммаДокумента = &СуммаФильтр";
	КонецЕсли;
	Если Фильтры.ИспользоватьФильтрПроведен Тогда
		УсловияГде = УсловияГде + "
			|	И ЗК.Проведен = &ПроведенФильтр";
	КонецЕсли;

	ЗапросБД.Текст =
	"ВЫБРАТЬ
	|	ЗК.Ссылка КАК Ссылка,
	|	ЗК.Номер КАК Номер,
	|	ЗК.Дата КАК Дата,
	|	ЗК.Контрагент КАК КонтрагентСсылка,
	|	ЗК.ДатаОплаты КАК ДатаОплаты,
	|	ЗК.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ПРЕДСТАВЛЕНИЕ(ЗК.Контрагент) КАК Контрагент,
	|	ПРЕДСТАВЛЕНИЕ(ЗК.Организация) КАК Организация,
	|	ПРЕДСТАВЛЕНИЕ(ЗК.СкладГруппа) КАК Склад,
	|	ПРЕДСТАВЛЕНИЕ(ЗК.Ответственный) КАК Ответственный,
	|	ПРЕДСТАВЛЕНИЕ(ЗК.ДоговорКонтрагента) КАК Договор,
	|	ЗК.СуммаДокумента КАК СуммаДокумента,
	|	ЗК.Проведен КАК Проведен,
	|	ЗК.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗК
	|ГДЕ
	|	1=1"
	+ УсловияГде
	+ "
	|УПОРЯДОЧИТЬ ПО
	|	ЗК.Дата УБЫВ, ЗК.Номер УБЫВ";

	ЗапросБД.УстановитьПараметр("ДатаНачала", Фильтры.ДатаНачала);
	ЗапросБД.УстановитьПараметр("ДатаОкончания", Фильтры.ДатаОкончания);
	ЗапросБД.УстановитьПараметр("НомерШаблон", Фильтры.НомерШаблон);
	ЗапросБД.УстановитьПараметр("ДатаФильтр", Фильтры.ДатаФильтр);
	ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", Фильтры.ДатаФильтрКонец);
	ЗапросБД.УстановитьПараметр("СуммаФильтр", Фильтры.СуммаФильтр);
	ЗапросБД.УстановитьПараметр("ПроведенФильтр", Фильтры.ПроведенФильтр);

	Возврат ЗапросБД.Выполнить().Выбрать();
КонецФункции

Функция СформироватьЗаказИзВыборки(Выборка, Фильтры, МассивОшибок)
	Заказ = Новый Структура;
	ФорматДаты = "ДФ=dd.MM.yyyy";
	ТекстНеУказано = "Не указано";

	Заказ.Вставить("Номер", Выборка.Номер);
	Заказ.Вставить("Дата", Формат(Выборка.Дата, ФорматДаты));
	Заказ.Вставить(
		"Контрагент",
		?(ЗначениеЗаполнено(Выборка.Контрагент), Выборка.Контрагент, ТекстНеУказано));
	ИННКонтрагента = ПолучитьИННКонтрагента(Выборка.КонтрагентСсылка);
	Заказ.Вставить(
		"ИНН",
		?(ЗначениеЗаполнено(ИННКонтрагента), ИННКонтрагента, ""));
	Заказ.Вставить(
		"Организация",
		?(ЗначениеЗаполнено(Выборка.Организация), Выборка.Организация, ТекстНеУказано));
	Заказ.Вставить(
		"Ответственный",
		?(ЗначениеЗаполнено(Выборка.Ответственный), Выборка.Ответственный, ТекстНеУказано));
	Заказ.Вставить("Договор", ?(ЗначениеЗаполнено(Выборка.Договор), Выборка.Договор, ""));
	Заказ.Вставить("Сумма", ?(ЗначениеЗаполнено(Выборка.СуммаДокумента), Выборка.СуммаДокумента, 0));
	Заказ.Вставить("Склад", ?(ЗначениеЗаполнено(Выборка.Склад), Выборка.Склад, ТекстНеУказано));
	Заказ.Вставить("Проведен", Выборка.Проведен);
	Заказ.Вставить("Комментарий", ?(ЗначениеЗаполнено(Выборка.Комментарий), Выборка.Комментарий, ""));
	Заказ.Вставить("ДатаОплаты", ?(ЗначениеЗаполнено(Выборка.ДатаОплаты), Формат(Выборка.ДатаОплаты, ФорматДаты), ""));
	Заказ.Вставить(
		"ДатаОтгрузки",
		?(ЗначениеЗаполнено(Выборка.ДатаОтгрузки), Формат(Выборка.ДатаОтгрузки, ФорматДаты), ""));

	Если Фильтры.ПолныйОтвет Тогда
		Попытка
			Заказ.Вставить("Товары", СформироватьТоварыПолногоОтвета(Выборка.Ссылка));
		Исключение
			МассивОшибок.Добавить("Проблема в заказе №" + Выборка.Номер + ". Ошибка: " + ОписаниеОшибки());
			Заказ.Вставить("Товары", Новый Массив);
		КонецПопытки;
	КонецЕсли;

	Возврат Заказ;
КонецФункции

Функция GetOrders_Impl(Запрос)
	МассивЗаказов = Новый Массив;
	МассивОшибок = Новый Массив;
	HTTPСтатусУспеха = 200;
	HTTPСтатусВнутренняяОшибкаСервера = 500;
	КолЧастейДаты = СтрДлина("000");
	ДлинаГода = СтрДлина("0000");
	ДлинаМесяца = СтрДлина("00");
	ДлинаДня = СтрДлина("00");

	Попытка
		Фильтры = СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок);
		Выборка = ПолучитьВыборкуЗаказов(Фильтры);
		Пока Выборка.Следующий() Цикл
			Если ПроходитПостФильтры(Выборка, Фильтры) Тогда
				МассивЗаказов.Добавить(СформироватьЗаказИзВыборки(Выборка, Фильтры, МассивОшибок));
			КонецЕсли;
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивЗаказов);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);

		JSON = Новый ЗаписьJSON;
		JSON.УстановитьСтроку();
		ЗаписатьJSON(JSON, ИтоговыйРезультат);
		JSONСтрока = JSON.Закрыть();

		Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);

		Возврат Ответ;
	Исключение
		ДанныеОшибки = Новый Структура("error", ОписаниеОшибки());
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);

		Ответ = Новый HTTPСервисОтвет(HTTPСтатусВнутренняяОшибкаСервера);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());

		Возврат Ответ;
	КонецПопытки;
КонецФункции
