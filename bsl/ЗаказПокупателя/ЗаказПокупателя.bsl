	КонецПопытки;

	Если КодНоменклатуры = "" Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросПоКоду = Новый Запрос;
	ЗапросПоКоду.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Спецификации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СпецификацииНоменклатуры КАК Спецификации
	|ГДЕ
	|	НЕ Спецификации.ЭтоГруппа
	|	И НЕ Спецификации.ПометкаУдаления
	|	И Спецификации.Код = &Код
	|УПОРЯДОЧИТЬ ПО
	|	Спецификации.Активная УБЫВ,
	|	Спецификации.ДатаУтверждения УБЫВ";
	ЗапросПоКоду.УстановитьПараметр("Код", КодНоменклатуры);
	РезультатПоКоду = ЗапросПоКоду.Выполнить().Выбрать();
	Если РезультатПоКоду.Следующий() Тогда
