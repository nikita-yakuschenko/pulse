// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Заказы покупателей.
// Формат ответа: { data: [...], errors: [...] }.

Функция GetOrders(Запрос) Экспорт
	Возврат GetOrders_Impl(Запрос);
КонецФункции

Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";

	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПреобразоватьВБулево(СтрокаЛог)
	Если ПустаяСтрока(СтрокаЛог) Тогда
		Возврат Ложь;
	КонецЕсли;

	Стр = ВРег(СокрЛП(СтрокаЛог));
	Возврат Стр = "1" Или Стр = "TRUE" Или Стр = "YES" Или Стр = "ДА";
КонецФункции

Функция РазобратьДатуСтрокой(ЗначДата, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня)
	Результат = Новый Структура;
	Результат.Вставить("Ок", Ложь);
	Результат.Вставить("Г", "");
	Результат.Вставить("М", "");
	Результат.Вставить("Д", "");

	Если Не ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат Результат;
	КонецЕсли;

	Г = "";
	М = "";
	Д = "";
	ЧастиТочка = СтрРазделить(ЗначДата, ".", Ложь);
	ЧастиДефис = СтрРазделить(ЗначДата, "-", Ложь);

	Если ЧастиТочка.Количество() = КолЧастейДаты Тогда
		Д = ЧастиТочка[0];
		М = ЧастиТочка[1];
		Г = ЧастиТочка[2];
	ИначеЕсли ЧастиДефис.Количество() = КолЧастейДаты Тогда
		Если СтрДлина(СокрЛП(ЧастиДефис[0])) = ДлинаГода Тогда
			Г = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Д = ЧастиДефис[2];
		Иначе
			Д = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Г = ЧастиДефис[2];
		КонецЕсли;
	Иначе
		Возврат Результат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Г) Тогда
		Возврат Результат;
	КонецЕсли;

	Пока СтрДлина(Г) < ДлинаГода Цикл
		Г = "0" + Г;
	КонецЦикла;
	Пока СтрДлина(М) < ДлинаМесяца Цикл
		М = "0" + М;
	КонецЦикла;
	Пока СтрДлина(Д) < ДлинаДня Цикл
		Д = "0" + Д;
	КонецЦикла;

	Результат.Вставить("Ок", Истина);
	Результат.Вставить("Г", Г);
	Результат.Вставить("М", М);
	Результат.Вставить("Д", Д);
	Возврат Результат;
КонецФункции

Функция РазобратьПериодFromTo(ЗначFrom, ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	ПериодРезультат = Новый Структура;
	ПериодРезультат.Вставить("ИспользоватьПериод", Ложь);
	ПериодРезультат.Вставить("ДатаНачала", Дата(1, 1, 1));
	ПериодРезультат.Вставить("ДатаОкончания", Дата(1, 1, 1));

	Если Не ЗначениеЗаполнено(ЗначFrom) Или Не ЗначениеЗаполнено(ЗначTo) Тогда
		Возврат ПериодРезультат;
	КонецЕсли;

	П1 = РазобратьДатуСтрокой(ЗначFrom, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	П2 = РазобратьДатуСтрокой(ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	Если П1.Ок И П2.Ок Тогда
		ПериодРезультат.ДатаНачала = Дата(П1.Г + П1.М + П1.Д + "000000");
		ПериодРезультат.ДатаОкончания = КонецДня(Дата(П2.Г + П2.М + П2.Д + "000000"));
		ПериодРезультат.ИспользоватьПериод = Истина;
	Иначе
		МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
	КонецЕсли;

	Возврат ПериодРезультат;
КонецФункции

Функция ПохожеНаЧисло(СтрокаЧисло)
	Если СтрокаЧисло = "" Тогда
		Возврат Ложь;
	КонецЕсли;

	ТекстЧисла = СтрЗаменить(СтрокаЧисло, ",", ".");
	ЕстьТочка = Ложь;
	Для Индекс = 1 По СтрДлина(ТекстЧисла) Цикл
		Символ = Сред(ТекстЧисла, Индекс, 1);
		Если Символ = "." Тогда
			Если ЕстьТочка Тогда
				Возврат Ложь;
			КонецЕсли;
			ЕстьТочка = Истина;
		ИначеЕсли Символ >= "0" И Символ <= "9" Тогда
			Продолжить;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;
КонецФункции

Функция СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	Фильтры = Новый Структура;
	ПараметрПолныйБазовый = "full";
	ПараметрПолныйНижний = НРег(ПараметрПолныйБазовый);
	ПараметрПолныйВерхний = ВРег(ПараметрПолныйБазовый);
	ПозицияНачалаОстатка = 2;
	ПараметрПолныйСЗаглавной = ВРег(Лев(ПараметрПолныйНижний, 1))
		+ Сред(ПараметрПолныйНижний, ПозицияНачалаОстатка, СтрДлина(ПараметрПолныйНижний) - 1);

	ЗначFrom = ПолучитьСтроковойПараметр(Запрос, "from");
	ЗначTo = ПолучитьСтроковойПараметр(Запрос, "to");
	ПериодРезультат = РазобратьПериодFromTo(
		ЗначFrom,
		ЗначTo,
		КолЧастейДаты,
		ДлинаГода,
		ДлинаМесяца,
		ДлинаДня,
		МассивОшибок);
	Фильтры.Вставить("ИспользоватьПериод", ПериодРезультат.ИспользоватьПериод);
	Фильтры.Вставить("ДатаНачала", ПериодРезультат.ДатаНачала);
	Фильтры.Вставить("ДатаОкончания", ПериодРезультат.ДатаОкончания);

	ЗначCode = ПолучитьСтроковойПараметр(Запрос, "code");
	Фильтры.Вставить("ИспользоватьФильтрНомер", ЗначCode <> "");
	Фильтры.Вставить("НомерШаблон", ?(ЗначCode <> "", "%" + ЗначCode + "%", "%"));

	ИспользоватьФильтрДата = Ложь;
	ДатаФильтр = Дата(1, 1, 1);
	ДатаФильтрКонец = Дата(1, 1, 1);
	ЗначDate = ПолучитьСтроковойПараметр(Запрос, "date");
	Если ЗначDate <> "" Тогда
		П = РазобратьДатуСтрокой(ЗначDate, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
		Если П.Ок Тогда
			ДатаФильтр = Дата(П.Г + П.М + П.Д + "000000");
			ДатаФильтрКонец = КонецДня(ДатаФильтр);
			ИспользоватьФильтрДата = Истина;
		Иначе
			МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
		КонецЕсли;
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
	Фильтры.Вставить("ДатаФильтр", ДатаФильтр);
	Фильтры.Вставить("ДатаФильтрКонец", ДатаФильтрКонец);

	ЗначSumm = ПолучитьСтроковойПараметр(Запрос, "summ");
	Фильтры.Вставить("ИспользоватьФильтрСумма", ПохожеНаЧисло(ЗначSumm));
	Фильтры.Вставить("СуммаФильтр", ?(ПохожеНаЧисло(ЗначSumm), Число(ЗначSumm), 0));

	ЗначApproved = ПолучитьСтроковойПараметр(Запрос, "approved");
	Фильтры.Вставить("ИспользоватьФильтрПроведен", ЗначApproved <> "");
	Фильтры.Вставить("ПроведенФильтр", ПреобразоватьВБулево(ЗначApproved));

	ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйНижний);
	Если ЗначПолный = "" Тогда
		ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйСЗаглавной);
	КонецЕсли;
	Если ЗначПолный = "" Тогда
		ЗначПолный = ПолучитьСтроковойПараметр(Запрос, ПараметрПолныйВерхний);
	КонецЕсли;
	Фильтры.Вставить("ПолныйОтвет", ПреобразоватьВБулево(ЗначПолный));

	ЗначCustomer = ПолучитьСтроковойПараметр(Запрос, "customer");
	Фильтры.Вставить("ИспользоватьФильтрКонтрагент", ЗначCustomer <> "");
	Фильтры.Вставить("ПодстрокаКонтрагент", ЗначCustomer);
	ЗначInn = ПолучитьСтроковойПараметр(Запрос, "inn");
	Фильтры.Вставить("ИспользоватьФильтрИНН", ЗначInn <> "");
	Фильтры.Вставить("ПодстрокаИНН", ЗначInn);

	ЗначOrg = ПолучитьСтроковойПараметр(Запрос, "org");
	Фильтры.Вставить("ИспользоватьФильтрОрганизация", ЗначOrg <> "");
	Фильтры.Вставить("ПодстрокаОрганизация", ЗначOrg);

	ЗначWarehouse = ПолучитьСтроковойПараметр(Запрос, "warehouse");
	Фильтры.Вставить("ИспользоватьФильтрСклад", ЗначWarehouse <> "");
	Фильтры.Вставить("ПодстрокаСклад", ЗначWarehouse);

	ЗначResponsible = ПолучитьСтроковойПараметр(Запрос, "responsible");
	Фильтры.Вставить("ИспользоватьФильтрОтветственный", ЗначResponsible <> "");
	Фильтры.Вставить("ПодстрокаОтветственный", ЗначResponsible);

	ЗначComment = ПолучитьСтроковойПараметр(Запрос, "comment");
	Фильтры.Вставить("ИспользоватьФильтрКомментарий", ЗначComment <> "");
	Фильтры.Вставить("ПодстрокаКомментарий", ЗначComment);

	Возврат Фильтры;
КонецФункции

Функция ПроходитПостФильтры(Выборка, Фильтры)
	ИННКонтрагента = ПолучитьИННКонтрагента(Выборка.КонтрагентСсылка);

	Возврат
		ПроходитФильтрИНН(Фильтры, ИННКонтрагента)
		И ПроходитФильтрКонтрагент(Выборка, Фильтры, ИННКонтрагента)
		И ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрОрганизация,
			Выборка.Организация,
			Фильтры.ПодстрокаОрганизация)
		И ПроходитСтроковыйПостФильтр(Фильтры.ИспользоватьФильтрСклад, Выборка.Склад, Фильтры.ПодстрокаСклад)
		И ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрОтветственный,
			Выборка.Ответственный,
			Фильтры.ПодстрокаОтветственный)
		И ПроходитСтроковыйПостФильтр(
			Фильтры.ИспользоватьФильтрКомментарий,
			Выборка.Комментарий,
			Фильтры.ПодстрокаКомментарий);
КонецФункции

Функция ПолучитьИННКонтрагента(СсылкаКонтрагента)
	Если Не ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		ОбъектКонтрагента = СсылкаКонтрагента.ПолучитьОбъект();
		Если ЗначениеЗаполнено(ОбъектКонтрагента.ИНН) Тогда
			Возврат Строка(ОбъектКонтрагента.ИНН);
		КонецЕсли;
	Исключение
		Возврат "";
	КонецПопытки;

	Возврат "";
КонецФункции

Функция СовпадаетКонтрагентПоИмениИИНН(Выборка, ИННКонтрагента, ПодстрокаКонтрагент)
	КонтрагентСовпал =
		СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПодстрокаКонтрагент)) > 0;
	ИННСовпал = СтрНайти(ВРег(ИННКонтрагента), ВРег(ПодстрокаКонтрагент)) > 0;

	Возврат КонтрагентСовпал Или ИННСовпал;
КонецФункции

Функция СовпадаетИННКонтрагента(ИННКонтрагента, ПодстрокаИНН)
	Возврат СтрНайти(ВРег(ИННКонтрагента), ВРег(ПодстрокаИНН)) > 0;
КонецФункции

Функция СовпадаетПостФильтр(ЗначениеПоля, Подстрока)
	Возврат СтрНайти(ВРег(Строка(ЗначениеПоля)), ВРег(Подстрока)) > 0;
КонецФункции

Функция ПроходитФильтрИНН(Фильтры, ИННКонтрагента)
	Если Не Фильтры.ИспользоватьФильтрИНН Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетИННКонтрагента(ИННКонтрагента, Фильтры.ПодстрокаИНН);
КонецФункции

Функция ПроходитФильтрКонтрагент(Выборка, Фильтры, ИННКонтрагента)
	Если Не Фильтры.ИспользоватьФильтрКонтрагент Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетКонтрагентПоИмениИИНН(Выборка, ИННКонтрагента, Фильтры.ПодстрокаКонтрагент);
КонецФункции

Функция ПроходитСтроковыйПостФильтр(ИспользоватьФильтр, ЗначениеПоля, Подстрока)
	Если Не ИспользоватьФильтр Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат СовпадаетПостФильтр(ЗначениеПоля, Подстрока);
КонецФункции

// Плановая себестоимость по спецификации: ТЧ ИсходныеКомплектующие - сумма (Количество * Цена) по строкам;
// при указанной вложенной спецификации в строке (реквизит Спецификация, MCP) - рекурсивно.
// Метаданные: MCP user-1c-upp-mcp - Справочник.СпецификацииНоменклатуры, ТЧ ИсходныеКомплектующие.
//
// Параметры:
//  СсылкаНаСпецификацию - СправочникСсылка.СпецификацииНоменклатуры - спецификация.
//
// Возвращаемое значение:
//  Число - сумма плановых затрат.
Функция РассчитатьПлановуюСебестоимостьСпецификацииПоСсылке(СсылкаНаСпецификацию)
	Возврат РассчитатьПлановуюСебестоимостьСпецификацииПоСсылкеРекурсивно(СсылкаНаСпецификацию, 0);
КонецФункции

Функция СсылкаВложеннойСпецификацииИзСтрокиКомплектующих(СтрокаТЧ, ТипСсылкаСпецификации)
	Если ЗначениеЗаполнено(СтрокаТЧ.Спецификация) Тогда
		Возврат СтрокаТЧ.Спецификация;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) И ТипЗнч(СтрокаТЧ.Номенклатура) = ТипСсылкаСпецификации Тогда
		Возврат СтрокаТЧ.Номенклатура;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция РассчитатьПлановуюСебестоимостьСпецификацииПоСсылкеРекурсивно(СсылкаНаСпецификацию, Глубина)
	МаксГлубина = 30;
	Если Глубина > МаксГлубина Тогда
		Возврат 0;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(СсылкаНаСпецификацию) Тогда
		Возврат 0;
	КонецЕсли;

	Попытка
		ОбъектСпецификации = СсылкаНаСпецификацию.ПолучитьОбъект();
	Исключение
		Возврат 0;
	КонецПопытки;

	СуммаПлановая = 0;
	ТипСсылкаСпецификации = Тип("СправочникСсылка.СпецификацииНоменклатуры");

	Для каждого СтрокаТЧ Из ОбъектСпецификации.ИсходныеКомплектующие Цикл
		КоличествоСтроки = ?(СтрокаТЧ.Количество = Неопределено, 0, СтрокаТЧ.Количество);
		СсылкаВложеннойСпецификации = СсылкаВложеннойСпецификацииИзСтрокиКомплектующих(СтрокаТЧ, ТипСсылкаСпецификации);
		Если ЗначениеЗаполнено(СсылкаВложеннойСпецификации) Тогда
			СуммаВложенной =
				РассчитатьПлановуюСебестоимостьСпецификацииПоСсылкеРекурсивно(СсылкаВложеннойСпецификации, Глубина + 1);
			СуммаПлановая = СуммаПлановая + СуммаВложенной * КоличествоСтроки;
		Иначе
			ЦенаПлановая = ?(СтрокаТЧ.Цена = Неопределено, 0, СтрокаТЧ.Цена);
			СуммаПлановая = СуммаПлановая + ЦенаПлановая * КоличествоСтроки;
		КонецЕсли;
	КонецЦикла;

	Возврат СуммаПлановая;
КонецФункции

Функция НайтиСсылкуСпецификацииПоИмени(ИмяНоменклатуры)
	Имя = СокрЛП(Строка(ИмяНоменклатуры));
	Если Имя = "" Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЗапросСпецификацииПоИмени = Новый Запрос;
	ЗапросСпецификацииПоИмени.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Спецификации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СпецификацииНоменклатуры КАК Спецификации
	|ГДЕ
	|	НЕ Спецификации.ЭтоГруппа
	|	И НЕ Спецификации.ПометкаУдаления
	|	И Спецификации.Наименование = &Наименование
	|УПОРЯДОЧИТЬ ПО
	|	Спецификации.Активная УБЫВ,
	|	Спецификации.ДатаУтверждения УБЫВ";
	ЗапросСпецификацииПоИмени.УстановитьПараметр("Наименование", Имя);
	РезультатСпецификацииПоИмени = ЗапросСпецификацииПоИмени.Выполнить().Выбрать();
	Если РезультатСпецификацииПоИмени.Следующий() Тогда
		Возврат РезультатСпецификацииПоИмени.Ссылка;
	КонецЕсли;

	ШаблонПодстрока = "%" + Имя + "%";
	ЗапросПоПодобию = Новый Запрос;
	ЗапросПоПодобию.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Спецификации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СпецификацииНоменклатуры КАК Спецификации
	|ГДЕ
	|	НЕ Спецификации.ЭтоГруппа
	|	И НЕ Спецификации.ПометкаУдаления
	|	И Спецификации.Наименование ПОДОБНО &Шаблон
	|УПОРЯДОЧИТЬ ПО
	|	Спецификации.Активная УБЫВ,
	|	Спецификации.ДатаУтверждения УБЫВ";
	ЗапросПоПодобию.УстановитьПараметр("Шаблон", ШаблонПодстрока);
	РезультатПоПодобию = ЗапросПоПодобию.Выполнить().Выбрать();
	Если РезультатПоПодобию.Следующий() Тогда
		Возврат РезультатПоПодобию.Ссылка;
	КонецЕсли;

	ИмяАльт = НормализоватьИмяДляПоискаСпецификации(Имя);
	Если ИмяАльт <> Имя Тогда
		Возврат НайтиСсылкуСпецификацииПоИмени(ИмяАльт);
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция НормализоватьИмяДляПоискаСпецификации(Имя)
	// Частая путаница латиницы и кириллицы в наименованиях (например «A» и «А» в коде изделия).
	Результат = Имя;
	Результат = СтрЗаменить(Результат, "A", "А");
	Результат = СтрЗаменить(Результат, "a", "а");
	Возврат Результат;
КонецФункции

Функция ПостроитьШаблонПоИмени(Имя)
	Текст = СокрЛП(Строка(Имя));
	Если Текст = "" Тогда
		Возврат "%";
	КонецЕсли;

	Текст = СтрЗаменить(Текст, "(", " ");
	Текст = СтрЗаменить(Текст, ")", " ");
	Текст = СтрЗаменить(Текст, "/", " ");
	Текст = СтрЗаменить(Текст, ".", " ");
	Текст = СтрЗаменить(Текст, ",", " ");
	Текст = СтрЗаменить(Текст, "-", " ");
	Текст = СтрЗаменить(Текст, "_", " ");

	Пока СтрНайти(Текст, "  ") > 0 Цикл
		Текст = СтрЗаменить(Текст, "  ", " ");
	КонецЦикла;

	Части = СтрРазделить(Текст, " ", Ложь);
	Шаблон = "%";
	Для каждого Часть Из Части Цикл
		ЧистаяЧасть = СокрЛП(Строка(Часть));
		Если ЧистаяЧасть <> "" Тогда
			Шаблон = Шаблон + ЧистаяЧасть + "%";
		КонецЕсли;
	КонецЦикла;

	Возврат Шаблон;
КонецФункции

Функция НайтиСсылкуСпецификацииПоКодуНоменклатуры(НоменклатураСсылка)
	КодНоменклатуры = "";
