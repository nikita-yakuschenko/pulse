// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Заявки на расходование средств. В JSON у каждой заявки: Номер, ДатаРасхода, Ответственный, Получатель, Контрагент, Организация (наша организация), Касса (счёт/касса оплаты), СуммаДокумента, Проведен (при полном ответе).
// Параметры: from, to; code; date; responsible, recipient, contractor, cash; summ; approved; full (при true — полные СвязанныеДокументы и Вложения; иначе — сводки). По умолчанию — базовый набор полей (Номер, ДатаДокумента, ДатаРасхода, Ответственный, Получатель, Организация, Касса, СуммаДокумента, Статус, Комментарий, Проведен, КтоИзменилСтатус, ДатаСменыСтатуса).

Функция GetPayments(Запрос) Экспорт
	МассивЗаявок = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ДатаНачала = Дата(1, 1, 1);
		ДатаОкончания = Дата(1, 1, 1);
		ИспользоватьПериод = Ложь;

		ЗначFrom = "";
		Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFrom) Тогда Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки; КонецЕсли;
		ЗначTo = "";
		Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначTo) Тогда Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFrom) И ЗначениеЗаполнено(ЗначTo) Тогда
			Попытка
				Г1 = ""; М1 = ""; Д1 = "";
				ЧТ1 = СтрРазделить(ЗначFrom, ".", Ложь); ЧД1 = СтрРазделить(ЗначFrom, "-", Ложь);
				Если ЧТ1.Количество() = 3 Тогда Д1 = ЧТ1[0]; М1 = ЧТ1[1]; Г1 = ЧТ1[2];
				ИначеЕсли ЧД1.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД1[0])) = 4 Тогда Г1 = ЧД1[0]; М1 = ЧД1[1]; Д1 = ЧД1[2]; Иначе Д1 = ЧД1[0]; М1 = ЧД1[1]; Г1 = ЧД1[2]; КонецЕсли;
				КонецЕсли;
				Г2 = ""; М2 = ""; Д2 = "";
				ЧТ2 = СтрРазделить(ЗначTo, ".", Ложь); ЧД2 = СтрРазделить(ЗначTo, "-", Ложь);
				Если ЧТ2.Количество() = 3 Тогда Д2 = ЧТ2[0]; М2 = ЧТ2[1]; Г2 = ЧТ2[2];
				ИначеЕсли ЧД2.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД2[0])) = 4 Тогда Г2 = ЧД2[0]; М2 = ЧД2[1]; Д2 = ЧД2[2]; Иначе Д2 = ЧД2[0]; М2 = ЧД2[1]; Г2 = ЧД2[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г1) И ЗначениеЗаполнено(Г2) Тогда
					Пока СтрДлина(Г1) < 4 Цикл Г1 = "0" + Г1; КонецЦикла; Пока СтрДлина(М1) < 2 Цикл М1 = "0" + М1; КонецЦикла; Пока СтрДлина(Д1) < 2 Цикл Д1 = "0" + Д1; КонецЦикла;
					Пока СтрДлина(Г2) < 4 Цикл Г2 = "0" + Г2; КонецЦикла; Пока СтрДлина(М2) < 2 Цикл М2 = "0" + М2; КонецЦикла; Пока СтрДлина(Д2) < 2 Цикл Д2 = "0" + Д2; КонецЦикла;
					ДатаНачала = Дата(Г1 + М1 + Д1 + "000000");
					ДатаОкончания = КонецДня(Дата(Г2 + М2 + Д2 + "000000"));
					ИспользоватьПериод = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга from/to: " + ЗначFrom + " / " + ЗначTo);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрНомер = Ложь;
		НомерШаблон = "";
		ЗначCode = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрНомер = Истина; НомерШаблон = "%" + ЗначCode + "%"; Иначе НомерШаблон = "%"; КонецЕсли;

		ДатаФильтр = Дата(1, 1, 1);
		ДатаФильтрКонец = Дата(1, 1, 1);
		ИспользоватьФильтрДата = Ложь;
		ЗначDate = "";
		Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначDate) Тогда Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначDate) Тогда
			Попытка
				Г = ""; М = ""; Д = "";
				ЧастиТочка = СтрРазделить(ЗначDate, ".", Ложь);
				ЧастиДефис = СтрРазделить(ЗначDate, "-", Ложь);
				Если ЧастиТочка.Количество() = 3 Тогда Д = ЧастиТочка[0]; М = ЧастиТочка[1]; Г = ЧастиТочка[2];
				ИначеЕсли ЧастиДефис.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧастиДефис[0])) = 4 Тогда Г = ЧастиДефис[0]; М = ЧастиДефис[1]; Д = ЧастиДефис[2]; Иначе Д = ЧастиДефис[0]; М = ЧастиДефис[1]; Г = ЧастиДефис[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г) Тогда
					Пока СтрДлина(Г) < 4 Цикл Г = "0" + Г; КонецЦикла;
					Пока СтрДлина(М) < 2 Цикл М = "0" + М; КонецЦикла;
					Пока СтрДлина(Д) < 2 Цикл Д = "0" + Д; КонецЦикла;
					ДатаФильтр = Дата(Г + М + Д + "000000");
					ДатаФильтрКонец = КонецДня(ДатаФильтр);
					ИспользоватьФильтрДата = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга date: " + ЗначDate);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрОтветственный = Ложь;
		ШаблонОтветственный = "";
		ЗначResponsible = "";
		ЗначResponsible = "";
		Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("responsible"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначResponsible) Тогда Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыURL["responsible"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначResponsible) Тогда ИспользоватьФильтрОтветственный = Истина; ШаблонОтветственный = "%" + ЗначResponsible + "%"; Иначе ШаблонОтветственный = "%"; КонецЕсли;

		ИспользоватьФильтрПолучатель = Ложь;
		ШаблонПолучатель = "";
		ЗначRecipient = "";
		ЗначRecipient = "";
		Попытка ЗначRecipient = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("recipient"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначRecipient) Тогда Попытка ЗначRecipient = СокрЛП(Строка(Запрос.ПараметрыURL["recipient"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначRecipient) Тогда ИспользоватьФильтрПолучатель = Истина; ШаблонПолучатель = "%" + ЗначRecipient + "%"; Иначе ШаблонПолучатель = "%"; КонецЕсли;

		ИспользоватьФильтрКонтрагент = Ложь;
		ШаблонКонтрагент = "";
		ЗначContractor = "";
		ЗначContractor = "";
		Попытка ЗначContractor = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначContractor) Тогда Попытка ЗначContractor = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначContractor) Тогда ИспользоватьФильтрКонтрагент = Истина; ШаблонКонтрагент = "%" + ЗначContractor + "%"; Иначе ШаблонКонтрагент = "%"; КонецЕсли;

		ИспользоватьФильтрКасса = Ложь;
		ШаблонКасса = "";
		ЗначCash = "";
		ЗначCash = "";
		Попытка ЗначCash = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("cash"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCash) Тогда Попытка ЗначCash = СокрЛП(Строка(Запрос.ПараметрыURL["cash"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCash) Тогда ИспользоватьФильтрКасса = Истина; ШаблонКасса = "%" + ЗначCash + "%"; Иначе ШаблонКасса = "%"; КонецЕсли;

		ИспользоватьФильтрКомментарий = Ложь;
		ЗначComment = "";
		ЗначComment = "";
		Попытка ЗначComment = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("comment"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначComment) Тогда Попытка ЗначComment = СокрЛП(Строка(Запрос.ПараметрыURL["comment"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначComment) Тогда ИспользоватьФильтрКомментарий = Истина; КонецЕсли;

		ИспользоватьФильтрСтатус = Ложь;
		ЗначStatus = "";
		ЗначStatus = "";
		Попытка ЗначStatus = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("status"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначStatus) Тогда Попытка ЗначStatus = СокрЛП(Строка(Запрос.ПараметрыURL["status"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначStatus) Тогда ИспользоватьФильтрСтатус = Истина; КонецЕсли;

		ИспользоватьФильтрСумма = Ложь;
		СуммаФильтр = 0;
		ЗначSumm = "";
		ЗначSumm = "";
		Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("summ"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSumm) Тогда Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыURL["summ"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSumm) Тогда Попытка СуммаФильтр = Число(ЗначSumm); ИспользоватьФильтрСумма = Истина; Исключение КонецПопытки; КонецЕсли;

		ИспользоватьФильтрПроведен = Ложь;
		ПроведенФильтр = Ложь;
		ЗначApproved = "";
		ЗначApproved = "";
		Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("approved"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначApproved) Тогда Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыURL["approved"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначApproved) Тогда ИспользоватьФильтрПроведен = Истина; ПроведенФильтр = (ВРег(ЗначApproved) = "1" Или ВРег(ЗначApproved) = "TRUE" Или ВРег(ЗначApproved) = "ДА" Или ВРег(ЗначApproved) = "YES"); КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	ЗС.Ссылка КАК Ссылка,
		|	ЗС.Номер КАК Номер,
		|	ЗС.Дата КАК ДатаДокумента,
		|	ЗС.ДатаРасхода КАК ДатаРасхода,
		|	ЗС.ДокументОснование КАК ДокументОснование,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.Состояние) КАК Статус,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.ИзменилСтатус) КАК КтоИзменилСтатус,
		|	ЗС.Комментарий КАК Комментарий,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.Ответственный) КАК Ответственный,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.Получатель) КАК Получатель,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.Контрагент) КАК Контрагент,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(ЗС.БанковскийСчетКасса) КАК Касса,
		|	ЗС.СуммаДокумента КАК СуммаДокумента,
		|	ЗС.Проведен КАК Проведен
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеСредств КАК ЗС
		|ГДЕ
		|	(НЕ &ИспользоватьПериод ИЛИ (ЗС.ДатаРасхода >= &ДатаНачала И ЗС.ДатаРасхода <= &ДатаОкончания))
		|	И (НЕ &ИспользоватьФильтрНомер ИЛИ ЗС.Номер ПОДОБНО &НомерШаблон)
		|	И (НЕ &ИспользоватьФильтрДата ИЛИ (ЗС.ДатаРасхода >= &ДатаФильтр И ЗС.ДатаРасхода <= &ДатаФильтрКонец))
		|	И (НЕ &ИспользоватьФильтрСумма ИЛИ ЗС.СуммаДокумента = &СуммаФильтр)
		|	И (НЕ &ИспользоватьФильтрПроведен ИЛИ ЗС.Проведен = &ПроведенФильтр)
		|УПОРЯДОЧИТЬ ПО
		|	ЗС.ДатаРасхода УБЫВ, ЗС.Номер УБЫВ";

		ЗапросБД.УстановитьПараметр("ИспользоватьПериод", ИспользоватьПериод);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
		ЗапросБД.УстановитьПараметр("НомерШаблон", НомерШаблон);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
		ЗапросБД.УстановитьПараметр("ДатаФильтр", ДатаФильтр);
		ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", ДатаФильтрКонец);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрСумма", ИспользоватьФильтрСумма);
		ЗапросБД.УстановитьПараметр("СуммаФильтр", СуммаФильтр);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПроведен", ИспользоватьФильтрПроведен);
		ЗапросБД.УстановитьПараметр("ПроведенФильтр", ПроведенФильтр);

		ШаблонБСЛ_Ответственный = СтрЗаменить(СтрЗаменить(ШаблонОтветственный, "%", "*"), "_", "?");
		ШаблонБСЛ_Получатель = СтрЗаменить(СтрЗаменить(ШаблонПолучатель, "%", "*"), "_", "?");
		ШаблонБСЛ_Контрагент = СтрЗаменить(СтрЗаменить(ШаблонКонтрагент, "%", "*"), "_", "?");
		ШаблонБСЛ_Касса = СтрЗаменить(СтрЗаменить(ШаблонКасса, "%", "*"), "_", "?");

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Если ИспользоватьФильтрОтветственный = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Ответственный, 2, СтрДлина(ШаблонБСЛ_Ответственный) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Ответственный)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрПолучатель = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Получатель, 2, СтрДлина(ШаблонБСЛ_Получатель) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Получатель)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрКонтрагент = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Контрагент, 2, СтрДлина(ШаблонБСЛ_Контрагент) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрКасса = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Касса, 2, СтрДлина(ШаблонБСЛ_Касса) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Касса)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрКомментарий = Истина Тогда
				Если СтрНайти(ВРег(Строка(Выборка.Комментарий)), ВРег(ЗначComment)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрСтатус = Истина Тогда
				Если СтрНайти(ВРег(Строка(Выборка.Статус)), ВРег(ЗначStatus)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;

			ЗаявкаРасход = Новый Структура;
			ЗаявкаРасход.Вставить("Номер", Выборка.Номер);
			Если ЗначениеЗаполнено(Выборка.ДатаДокумента) Тогда ЗаявкаРасход.Вставить("ДатаДокумента", Формат(Выборка.ДатаДокумента, "ДФ=dd.MM.yyyy")); Иначе ЗаявкаРасход.Вставить("ДатаДокумента", ""); КонецЕсли;
			ЗаявкаРасход.Вставить("ДатаРасхода", Формат(Выборка.ДатаРасхода, "ДФ=dd.MM.yyyy"));
			Если Не ЗначениеЗаполнено(Выборка.Ответственный) Тогда ЗаявкаРасход.Вставить("Ответственный", "Не указан"); Иначе ЗаявкаРасход.Вставить("Ответственный", Выборка.Ответственный); КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.Получатель) Тогда ЗаявкаРасход.Вставить("Получатель", Выборка.Получатель); ИначеЕсли ЗначениеЗаполнено(Выборка.Контрагент) Тогда ЗаявкаРасход.Вставить("Получатель", Выборка.Контрагент); Иначе ЗаявкаРасход.Вставить("Получатель", "Не указан"); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Организация) Тогда ЗаявкаРасход.Вставить("Организация", ""); Иначе ЗаявкаРасход.Вставить("Организация", Выборка.Организация); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Касса) Тогда ЗаявкаРасход.Вставить("Касса", "Не указана"); Иначе ЗаявкаРасход.Вставить("Касса", Выборка.Касса); КонецЕсли;
			Если ПустаяСтрока(Строка(Выборка.СуммаДокумента)) Или Выборка.СуммаДокумента = Неопределено Тогда ЗаявкаРасход.Вставить("СуммаДокумента", 0); Иначе ЗаявкаРасход.Вставить("СуммаДокумента", Выборка.СуммаДокумента); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Статус) Тогда ЗаявкаРасход.Вставить("Статус", ""); Иначе ЗаявкаРасход.Вставить("Статус", Выборка.Статус); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Комментарий) Тогда ЗаявкаРасход.Вставить("Комментарий", ""); Иначе ЗаявкаРасход.Вставить("Комментарий", Выборка.Комментарий); КонецЕсли;
			ЗаявкаРасход.Вставить("Проведен", Выборка.Проведен);
			Если Не ЗначениеЗаполнено(Выборка.КтоИзменилСтатус) Тогда ЗаявкаРасход.Вставить("КтоИзменилСтатус", ""); Иначе ЗаявкаРасход.Вставить("КтоИзменилСтатус", Выборка.КтоИзменилСтатус); КонецЕсли;
			ДатаСменыСтатусаСтр = ""; Попытка ВремИзмен = Выборка.Ссылка.ВремяИзмененияДокумента; Если ТипЗнч(ВремИзмен) = Тип("Дата") И ЗначениеЗаполнено(ВремИзмен) Тогда ДатаСменыСтатусаСтр = Формат(ВремИзмен, "ДФ=dd.MM.yyyy"); КонецЕсли; Исключение КонецПопытки;
			ЗаявкаРасход.Вставить("ДатаСменыСтатуса", ДатаСменыСтатусаСтр);

			Если ПолныйОтвет Тогда
			// Документ-основание (один документ).
			ДокументОснованиеСтр = Новый Структура;
			Если ЗначениеЗаполнено(Выборка.ДокументОснование) Тогда
				Попытка
					ДокументОснованиеСтр.Вставить("Тип", Выборка.ДокументОснование.Метаданные().Имя);
					ДокументОснованиеСтр.Вставить("Номер", Выборка.ДокументОснование.Номер);
					ДатаОсн = ""; Если ЗначениеЗаполнено(Выборка.ДокументОснование.Дата) Тогда ДатаОсн = Формат(Выборка.ДокументОснование.Дата, "ДФ=dd.MM.yyyy"); КонецЕсли;
					ДокументОснованиеСтр.Вставить("Дата", ДатаОсн);
					ДокументОснованиеСтр.Вставить("НомерДата", Строка(Выборка.ДокументОснование.Номер) + " от " + ДатаОсн);
				Исключение
					МассивОшибок.Добавить("Заявка №" + Выборка.Номер + ": не удалось прочитать документ-основание — " + ОписаниеОшибки());
				КонецПопытки;
			Иначе
				ДокументОснованиеСтр.Вставить("Тип", ""); ДокументОснованиеСтр.Вставить("Номер", ""); ДокументОснованиеСтр.Вставить("Дата", ""); ДокументОснованиеСтр.Вставить("НомерДата", "");
			КонецЕсли;

			// Связанные документы: платежи по регистру ЗаявкиНаРасходованиеСредств (ДокументРасчетовСКонтрагентом).
			МассивПлатежей = Новый Массив;
			Попытка
				ЗапросРег = Новый Запрос;
				ЗапросРег.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ЗР.ДокументРасчетовСКонтрагентом КАК ДокументРасчетовСКонтрагентом ИЗ РегистрНакопления.ЗаявкиНаРасходованиеСредств КАК ЗР ГДЕ ЗР.ЗаявкаНаРасходование = &Заявка";
				ЗапросРег.УстановитьПараметр("Заявка", Выборка.Ссылка);
				РезРег = ЗапросРег.Выполнить();
				ВыборкаРег = РезРег.Выбрать();
				ДобавленныеПлатежи = Новый Соответствие;
				Пока ВыборкаРег.Следующий() Цикл
					Если Не ЗначениеЗаполнено(ВыборкаРег.ДокументРасчетовСКонтрагентом) Тогда Продолжить; КонецЕсли;
					КлючПл = Строка(ВыборкаРег.ДокументРасчетовСКонтрагентом.УникальныйИдентификатор());
					Если ДобавленныеПлатежи.Получить(КлючПл) = Неопределено Тогда
						ДобавленныеПлатежи.Вставить(КлючПл, Истина);
						Попытка
							ТипДок = ВыборкаРег.ДокументРасчетовСКонтрагентом.Метаданные().Имя;
							НомерПл = ВыборкаРег.ДокументРасчетовСКонтрагентом.Номер;
							ДатаПл = ""; Если ЗначениеЗаполнено(ВыборкаРег.ДокументРасчетовСКонтрагентом.Дата) Тогда ДатаПл = Формат(ВыборкаРег.ДокументРасчетовСКонтрагентом.Дата, "ДФ=dd.MM.yyyy"); КонецЕсли;
							ЭтПл = Новый Структура("Тип", ТипДок, "Номер", НомерПл, "Дата", ДатаПл, "НомерДата", Строка(НомерПл) + " от " + ДатаПл);
							МассивПлатежей.Добавить(ЭтПл);
						Исключение
							МассивОшибок.Добавить("Заявка №" + Выборка.Номер + ": ошибка чтения связанного документа — " + ОписаниеОшибки());
						КонецПопытки;
					КонецЕсли;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заявка №" + Выборка.Номер + ": ошибка запроса регистра ЗаявкиНаРасходованиеСредств — " + ОписаниеОшибки());
			КонецПопытки;
			СвязанныеДокументы = Новый Структура;
			СвязанныеДокументы.Вставить("ДокументОснование", ДокументОснованиеСтр);
			СвязанныеДокументы.Вставить("ДокументыРасчетовСКонтрагентом", МассивПлатежей);
			ЗаявкаРасход.Вставить("СвязанныеДокументы", СвязанныеДокументы);

			// Вложения из хранилища дополнительной информации.
			МассивВложений = Новый Массив;
			ЗапросХДИ = Новый Запрос;
			ЗапросХДИ.Текст = "ВЫБРАТЬ ХДИ.Ссылка КАК Ссылка, ХДИ.ИмяФайла КАК ИмяФайла ИЗ Справочник.ХранилищеДополнительнойИнформации КАК ХДИ ГДЕ ХДИ.Объект = &СсылкаДокумента";
			ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", Выборка.Ссылка);
			Попытка
				РезультатХДИ = ЗапросХДИ.Выполнить();
				ВыборкаХДИ = РезультатХДИ.Выбрать();
				Пока ВыборкаХДИ.Следующий() Цикл
					Попытка
						ЭлементХДИ = ВыборкаХДИ.Ссылка.ПолучитьОбъект();
						ДвоичныеДанные = Неопределено;
						Если ЗначениеЗаполнено(ЭлементХДИ.Хранилище) Тогда ДвоичныеДанные = ЭлементХДИ.Хранилище.Получить(); КонецЕсли;
						ДанныеBase64 = "";
						Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") И ДвоичныеДанные.Размер() > 0 Тогда Попытка ДанныеBase64 = Строка(Base64Строка(ДвоичныеДанные)); Исключение ДанныеBase64 = ""; КонецПопытки; КонецЕсли;
						Вложение = Новый Структура("ИмяФайла", ВыборкаХДИ.ИмяФайла); Вложение.Вставить("Данные", ДанныеBase64);
						МассивВложений.Добавить(Вложение);
					Исключение
						МассивОшибок.Добавить("Заявка №" + Выборка.Номер + ": не удалось прочитать вложение """ + ВыборкаХДИ.ИмяФайла + """ — " + ОписаниеОшибки());
					КонецПопытки;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заявка №" + Выборка.Номер + ": ошибка запроса вложений — " + ОписаниеОшибки());
			КонецПопытки;
			ЗаявкаРасход.Вставить("Вложения", МассивВложений);

			Иначе
			// Сводки по связям и вложениям (без full).
			ОснованиеЕсть = ЗначениеЗаполнено(Выборка.ДокументОснование);
			КоличествоПлатежей = 0;
			Попытка
				ЗапросРег = Новый Запрос;
				ЗапросРег.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ЗР.ДокументРасчетовСКонтрагентом КАК ДокументРасчетовСКонтрагентом ИЗ РегистрНакопления.ЗаявкиНаРасходованиеСредств КАК ЗР ГДЕ ЗР.ЗаявкаНаРасходование = &Заявка";
				ЗапросРег.УстановитьПараметр("Заявка", Выборка.Ссылка);
				РезРег = ЗапросРег.Выполнить();
				ВыборкаРег = РезРег.Выбрать();
				ДобавленныеПл = Новый Соответствие;
				Пока ВыборкаРег.Следующий() Цикл
					Если ЗначениеЗаполнено(ВыборкаРег.ДокументРасчетовСКонтрагентом) Тогда КлючПл = Строка(ВыборкаРег.ДокументРасчетовСКонтрагентом.УникальныйИдентификатор()); Если ДобавленныеПл.Получить(КлючПл) = Неопределено Тогда ДобавленныеПл.Вставить(КлючПл, Истина); КоличествоПлатежей = КоличествоПлатежей + 1; КонецЕсли; КонецЕсли;
				КонецЦикла;
			Исключение КонецПопытки;
			КоличествоВложений = 0;
			Попытка
				ЗапросХДИ = Новый Запрос;
				ЗапросХДИ.Текст = "ВЫБРАТЬ КОЛИЧЕСТВО(ХДИ.Ссылка) КАК Количество ИЗ Справочник.ХранилищеДополнительнойИнформации КАК ХДИ ГДЕ ХДИ.Объект = &СсылкаДокумента";
				ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", Выборка.Ссылка);
				РезХДИ = ЗапросХДИ.Выполнить();
				ТХДИ = РезХДИ.Выгрузить();
				Если ТХДИ.Количество() > 0 Тогда КоличествоВложений = ТХДИ[0].Количество; КонецЕсли;
			Исключение КонецПопытки;
			ДокументОснованиеКратко = Новый Структура("Есть", ОснованиеЕсть, "Количество", ?(ОснованиеЕсть, 1, 0));
			ПлатежиКратко = Новый Структура("Есть", КоличествоПлатежей > 0, "Количество", КоличествоПлатежей);
			ВложенияКратко = Новый Структура("Есть", КоличествоВложений > 0, "Количество", КоличествоВложений);
			СвязанныеДокументы = Новый Структура;
			СвязанныеДокументы.Вставить("ДокументОснование", ДокументОснованиеКратко);
			СвязанныеДокументы.Вставить("ДокументыРасчетовСКонтрагентом", ПлатежиКратко);
			ЗаявкаРасход.Вставить("СвязанныеДокументы", СвязанныеДокументы);
			ЗаявкаРасход.Вставить("Вложения", ВложенияКратко);
			КонецЕсли;

			Попытка
				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, ЗаявкаРасход);
				ТестоваяЗаписьJSON.Закрыть();
				МассивЗаявок.Добавить(ЗаявкаРасход);
			Исключение
				МассивОшибок.Добавить("Проблема в заявке №" + Выборка.Номер + " от " + Формат(Выборка.ДатаРасхода, "ДФ=dd.MM.yyyy") + ". Ошибка: " + ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивЗаявок);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		JSON = Новый ЗаписьJSON;
		JSON.УстановитьСтроку();
		ЗаписатьJSON(JSON, ИтоговыйРезультат);
		JSONСтрока = JSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
