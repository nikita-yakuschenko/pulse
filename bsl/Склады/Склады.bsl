// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Справочник складов (Справочник.Склады). В JSON: data — массив элементов с полями Код, Наименование, ЭтоГруппа; errors — массив ошибок.
// Параметры: code, name — фильтр по коду/наименованию (подстрока); в name слэш: _slash_. group — фильтр по признаку группы (true/false). По умолчанию возвращаются все склады.

Функция GetWarehouses(Запрос) Экспорт
	МассивСкладов = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		// Фильтр по коду склада.
		ИспользоватьФильтрКод = Ложь;
		ШаблонКод = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрКод = Истина; ШаблонКод = "%" + ЗначCode + "%"; Иначе ШаблонКод = "%"; КонецЕсли;

		// Фильтр по наименованию склада.
		ИспользоватьФильтрНаименование = Ложь;
		ШаблонНаименование = "";
		ЗначName = "";
		Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначName) Тогда Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки; КонецЕсли;
		ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
		Если ЗначениеЗаполнено(ЗначName) Тогда ИспользоватьФильтрНаименование = Истина; ШаблонНаименование = "%" + ЗначName + "%"; Иначе ШаблонНаименование = "%"; КонецЕсли;

		// Фильтр по признаку группы (true — только группы, false — только элементы).
		ИспользоватьФильтрГруппа = Ложь;
		ФильтрГруппа = Ложь;
		ЗначGroup = "";
		Попытка ЗначGroup = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("group"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначGroup) Тогда Попытка ЗначGroup = СокрЛП(Строка(Запрос.ПараметрыURL["group"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначGroup) Тогда ИспользоватьФильтрГруппа = Истина; Если ВРег(ЗначGroup) = "TRUE" ИЛИ ЗначGroup = "1" ИЛИ ВРег(ЗначGroup) = "ДА" Тогда ФильтрГруппа = Истина; Иначе ФильтрГруппа = Ложь; КонецЕсли; КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	Склады.Код КАК Код,
		|	Склады.Наименование КАК Наименование,
		|	Склады.ЭтоГруппа КАК ЭтоГруппа
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	(НЕ &ИспользоватьФильтрКод ИЛИ Склады.Код ПОДОБНО &ШаблонКод)
		|	И (НЕ &ИспользоватьФильтрНаименование ИЛИ Склады.Наименование ПОДОБНО &ШаблонНаименование)
		|	И (НЕ &ИспользоватьФильтрГруппа ИЛИ Склады.ЭтоГруппа = &ФильтрГруппа)
		|УПОРЯДОЧИТЬ ПО
		|	Склады.Наименование";
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрКод", ИспользоватьФильтрКод);
		ЗапросБД.УстановитьПараметр("ШаблонКод", ШаблонКод);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНаименование", ИспользоватьФильтрНаименование);
		ЗапросБД.УстановитьПараметр("ШаблонНаименование", ШаблонНаименование);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрГруппа", ИспользоватьФильтрГруппа);
		ЗапросБД.УстановитьПараметр("ФильтрГруппа", ФильтрГруппа);

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Склад = Новый Структура;
			Склад.Вставить("Код", ?(ЗначениеЗаполнено(Выборка.Код), Строка(Выборка.Код), ""));
			Склад.Вставить("Наименование", ?(ЗначениеЗаполнено(Выборка.Наименование), Строка(Выборка.Наименование), ""));
			Склад.Вставить("ЭтоГруппа", Выборка.ЭтоГруппа);
			МассивСкладов.Добавить(Склад);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивСкладов);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
