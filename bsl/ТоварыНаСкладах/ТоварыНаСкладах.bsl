// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Остатки товаров на складах (регистр накопления ТоварыНаСкладах). В JSON: data — массив позиций номенклатуры с полями Код, Наименование, ЕдиницаИзмерения, ВидНоменклатуры, НоменклатурнаяГруппа, ДатаСреза, Остатки (массив {Склад, Количество}); errors — массив ошибок.
// Параметры: code, name — фильтр по коду/наименованию номенклатуры (подстрока; в name слэш: _slash_); warehouse — фильтр по наименованию склада (подстрока, в т.ч. по остаткам); date — дата среза остатков (dd.MM.yyyy или yyyy-MM-dd), если не указан — по умолчанию текущая дата сеанса; full — при true в data попадает вся отфильтрованная номенклатура (в т.ч. с нулевыми остатками), при false только позиции с остатком > 0 хотя бы на одном складе.

Функция GetBalances(Запрос) Экспорт
	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		// Фильтр по коду номенклатуры.
		ИспользоватьФильтрКод = Ложь;
		ШаблонКод = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрКод = Истина; ШаблонКод = "%" + ЗначCode + "%"; Иначе ШаблонКод = "%"; КонецЕсли;

		// Фильтр по наименованию номенклатуры.
		ИспользоватьФильтрНаименование = Ложь;
		ШаблонНаименование = "";
		ЗначName = "";
		Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначName) Тогда Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки; КонецЕсли;
		ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
		Если ЗначениеЗаполнено(ЗначName) Тогда ИспользоватьФильтрНаименование = Истина; ШаблонНаименование = "%" + ЗначName + "%"; Иначе ШаблонНаименование = "%"; КонецЕсли;

		// Фильтр по складу (подстрока в наименовании склада в остатках).
		ИспользоватьФильтрСклад = Ложь;
		ШаблонСклад = "";
		ЗначWarehouse = "";
		Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("warehouse"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначWarehouse) Тогда Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыURL["warehouse"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначWarehouse) Тогда ИспользоватьФильтрСклад = Истина; ШаблонСклад = "%" + ЗначWarehouse + "%"; КонецЕсли;

		// Дата среза остатков. Если параметр date не передан — используется текущая дата сеанса.
		ДатаСреза = КонецДня(ТекущаяДатаСеанса());
		ЗначDate = "";
		Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначDate) Тогда Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначDate) Тогда
			Попытка
				Г = ""; М = ""; Д = "";
				ЧастиТочка = СтрРазделить(ЗначDate, ".", Ложь);
				ЧастиДефис = СтрРазделить(ЗначDate, "-", Ложь);
				Если ЧастиТочка.Количество() = 3 Тогда
					Д = ЧастиТочка[0]; М = ЧастиТочка[1]; Г = ЧастиТочка[2];
				ИначеЕсли ЧастиДефис.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧастиДефис[0])) = 4 Тогда Г = ЧастиДефис[0]; М = ЧастиДефис[1]; Д = ЧастиДефис[2]; Иначе Д = ЧастиДефис[0]; М = ЧастиДефис[1]; Г = ЧастиДефис[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г) Тогда
					Пока СтрДлина(Г) < 4 Цикл Г = "0" + Г; КонецЦикла;
					Пока СтрДлина(М) < 2 Цикл М = "0" + М; КонецЦикла;
					Пока СтрДлина(Д) < 2 Цикл Д = "0" + Д; КонецЦикла;
					ДатаСреза = КонецДня(Дата(Г + М + Д + "000000"));
				Иначе
					МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга date: " + ЗначDate);
			КонецПопытки;
		КонецЕсли;

		// full: включать позиции с нулевыми остатками.
		ВключатьНулевыеОстатки = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ВключатьНулевыеОстатки = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		// Запрос номенклатуры: только элементы (не группы), без удалённых.
		ЗапросНом = Новый Запрос;
		ЗапросНом.Текст =
		"ВЫБРАТЬ
		|	Ном.Ссылка КАК Ссылка,
		|	Ном.Код КАК Код,
		|	Ном.Наименование КАК Наименование,
		|	ПРЕДСТАВЛЕНИЕ(Ном.БазоваяЕдиницаИзмерения) КАК ЕдиницаИзмерения,
		|	ПРЕДСТАВЛЕНИЕ(Ном.ВидНоменклатуры) КАК ВидНоменклатуры,
		|	ПРЕДСТАВЛЕНИЕ(Ном.НоменклатурнаяГруппа) КАК НоменклатурнаяГруппа
		|ИЗ
		|	Справочник.Номенклатура КАК Ном
		|ГДЕ
		|	НЕ Ном.ПометкаУдаления
		|	И НЕ Ном.ЭтоГруппа
		|	И (НЕ &ИспользоватьФильтрКод ИЛИ Ном.Код ПОДОБНО &ШаблонКод)
		|	И (НЕ &ИспользоватьФильтрНаименование ИЛИ Ном.Наименование ПОДОБНО &ШаблонНаименование)
		|УПОРЯДОЧИТЬ ПО
		|	Ном.Наименование";
		ЗапросНом.УстановитьПараметр("ИспользоватьФильтрКод", ИспользоватьФильтрКод);
		ЗапросНом.УстановитьПараметр("ШаблонКод", ШаблонКод);
		ЗапросНом.УстановитьПараметр("ИспользоватьФильтрНаименование", ИспользоватьФильтрНаименование);
		ЗапросНом.УстановитьПараметр("ШаблонНаименование", ШаблонНаименование);

		РезультатНом = ЗапросНом.Выполнить();
		ВыборкаНом = РезультатНом.Выбрать();

		// Остатки на дату: виртуальная таблица Остатки регистра ТоварыНаСкладах.
		ЗапросОст = Новый Запрос;
		ЗапросОст.Текст =
		"ВЫБРАТЬ
		|	Ост.Номенклатура КАК Номенклатура,
		|	ПРЕДСТАВЛЕНИЕ(Ост.Склад) КАК Склад,
		|	Ост.КоличествоОстаток КАК Количество
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаСреза) КАК Ост
		|ГДЕ
		|	Ост.КоличествоОстаток <> 0";
		ЗапросОст.УстановитьПараметр("ДатаСреза", ДатаСреза);
		Попытка
			РезультатОст = ЗапросОст.Выполнить();
		Исключение
			МассивОшибок.Добавить("Ошибка запроса остатков: " + ОписаниеОшибки());
			РезультатОст = Неопределено;
		КонецПопытки;

		// Собираем остатки по номенклатуре: Ссылка -> массив {Склад, Количество}.
		ОстаткиПоНоменклатуре = Новый Соответствие;
		Если РезультатОст <> Неопределено Тогда
			ВыборкаОст = РезультатОст.Выбрать();
			Пока ВыборкаОст.Следующий() Цикл
				КлючНом = ВыборкаОст.Номенклатура.УникальныйИдентификатор();
				МассивОстатков = ОстаткиПоНоменклатуре.Получить(КлючНом);
				Если МассивОстатков = Неопределено Тогда
					МассивОстатков = Новый Массив;
					ОстаткиПоНоменклатуре.Вставить(КлючНом, МассивОстатков);
				КонецЕсли;
				СтрОст = Новый Структура("Склад, Количество", Строка(ВыборкаОст.Склад), ВыборкаОст.Количество);
				МассивОстатков.Добавить(СтрОст);
			КонецЦикла;
		КонецЕсли;

		ШаблонБСЛ_Склад = "";
		Если ИспользоватьФильтрСклад Тогда ШаблонБСЛ_Склад = СтрЗаменить(СтрЗаменить(ШаблонСклад, "%", "*"), "_", "?"); КонецЕсли;
		ПодстрокаСклад = "";
		Если СтрДлина(ШаблонБСЛ_Склад) >= 2 Тогда ПодстрокаСклад = Сред(ШаблонБСЛ_Склад, 2, СтрДлина(ШаблонБСЛ_Склад) - 2); КонецЕсли;

		ДатаСрезаСтр = Формат(ДатаСреза, "ДФ=dd.MM.yyyy");

		Пока ВыборкаНом.Следующий() Цикл
			КлючНом = ВыборкаНом.Ссылка.УникальныйИдентификатор();
			МассивОстатков = ОстаткиПоНоменклатуре.Получить(КлючНом);
			Если МассивОстатков = Неопределено Тогда МассивОстатков = Новый Массив; КонецЕсли;

			// Фильтр по складу: оставить только склады, в наименовании которых есть подстрока.
			Если ИспользоватьФильтрСклад И ЗначениеЗаполнено(ПодстрокаСклад) Тогда
				МассивОстатковОтфильтрованный = Новый Массив;
				Для Каждого СтрОст Из МассивОстатков Цикл
					Если СтрНайти(ВРег(Строка(СтрОст.Склад)), ВРег(ПодстрокаСклад)) > 0 Тогда МассивОстатковОтфильтрованный.Добавить(СтрОст); КонецЕсли;
				КонецЦикла;
				МассивОстатков = МассивОстатковОтфильтрованный;
			КонецЕсли;

			СуммаОстатков = 0;
			Для Каждого СтрОст Из МассивОстатков Цикл СуммаОстатков = СуммаОстатков + СтрОст.Количество; КонецЦикла;
			Если Не ВключатьНулевыеОстатки И СуммаОстатков = 0 Тогда Продолжить; КонецЕсли;

			Позиция = Новый Структура;
			Позиция.Вставить("Код", Строка(ВыборкаНом.Код));
			Если Не ЗначениеЗаполнено(ВыборкаНом.Наименование) Тогда Позиция.Вставить("Наименование", ""); Иначе Позиция.Вставить("Наименование", ВыборкаНом.Наименование); КонецЕсли;
			Если Не ЗначениеЗаполнено(ВыборкаНом.ЕдиницаИзмерения) Тогда Позиция.Вставить("ЕдиницаИзмерения", ""); Иначе Позиция.Вставить("ЕдиницаИзмерения", ВыборкаНом.ЕдиницаИзмерения); КонецЕсли;
			Если Не ЗначениеЗаполнено(ВыборкаНом.ВидНоменклатуры) Тогда Позиция.Вставить("ВидНоменклатуры", ""); Иначе Позиция.Вставить("ВидНоменклатуры", ВыборкаНом.ВидНоменклатуры); КонецЕсли;
			Если Не ЗначениеЗаполнено(ВыборкаНом.НоменклатурнаяГруппа) Тогда Позиция.Вставить("НоменклатурнаяГруппа", ""); Иначе Позиция.Вставить("НоменклатурнаяГруппа", ВыборкаНом.НоменклатурнаяГруппа); КонецЕсли;
			Позиция.Вставить("ДатаСреза", ДатаСрезаСтр);
			Позиция.Вставить("Остатки", МассивОстатков);
			МассивДанных.Добавить(Позиция);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивДанных);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		JSON = Новый ЗаписьJSON;
		JSON.УстановитьСтроку();
		ЗаписатьJSON(JSON, ИтоговыйРезультат);
		JSONСтрока = JSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
