// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Поступление товаров и услуг. В JSON у каждого поступления: Номер, ДатаДокумента, Контрагент, Организация, Склад, Ответственный, СуммаДокумента, Комментарий; при full — Сделка, ТЧ Товары, ТЧ Услуги, Вложения.
// Параметры: from, to; code; date; contractor, org, warehouse, responsible; summ; approved; full (при true — полные Сделка, ТЧ Товары, ТЧ Услуги, Вложения; иначе — сводки по Сделка и Вложения). По умолчанию — базовый набор полей (Номер, ДатаДокумента, Дата, Контрагент, Организация, Склад, Ответственный, СуммаДокумента, Комментарий, Проведен). Все даты в формате dd.MM.yyyy.

Функция GetReceipts(Запрос) Экспорт
	МассивПоступлений = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ДатаНачала = Дата(1, 1, 1);
		ДатаОкончания = Дата(1, 1, 1);
		ИспользоватьПериод = Ложь;

		ЗначFrom = "";
		Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFrom) Тогда Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки; КонецЕсли;
		ЗначTo = "";
		Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначTo) Тогда Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFrom) И ЗначениеЗаполнено(ЗначTo) Тогда
			Попытка
				Г1 = ""; М1 = ""; Д1 = "";
				ЧТ1 = СтрРазделить(ЗначFrom, ".", Ложь); ЧД1 = СтрРазделить(ЗначFrom, "-", Ложь);
				Если ЧТ1.Количество() = 3 Тогда Д1 = ЧТ1[0]; М1 = ЧТ1[1]; Г1 = ЧТ1[2];
				ИначеЕсли ЧД1.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД1[0])) = 4 Тогда Г1 = ЧД1[0]; М1 = ЧД1[1]; Д1 = ЧД1[2]; Иначе Д1 = ЧД1[0]; М1 = ЧД1[1]; Г1 = ЧД1[2]; КонецЕсли;
				КонецЕсли;
				Г2 = ""; М2 = ""; Д2 = "";
				ЧТ2 = СтрРазделить(ЗначTo, ".", Ложь); ЧД2 = СтрРазделить(ЗначTo, "-", Ложь);
				Если ЧТ2.Количество() = 3 Тогда Д2 = ЧТ2[0]; М2 = ЧТ2[1]; Г2 = ЧТ2[2];
				ИначеЕсли ЧД2.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД2[0])) = 4 Тогда Г2 = ЧД2[0]; М2 = ЧД2[1]; Д2 = ЧД2[2]; Иначе Д2 = ЧД2[0]; М2 = ЧД2[1]; Г2 = ЧД2[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г1) И ЗначениеЗаполнено(Г2) Тогда
					Пока СтрДлина(Г1) < 4 Цикл Г1 = "0" + Г1; КонецЦикла; Пока СтрДлина(М1) < 2 Цикл М1 = "0" + М1; КонецЦикла; Пока СтрДлина(Д1) < 2 Цикл Д1 = "0" + Д1; КонецЦикла;
					Пока СтрДлина(Г2) < 4 Цикл Г2 = "0" + Г2; КонецЦикла; Пока СтрДлина(М2) < 2 Цикл М2 = "0" + М2; КонецЦикла; Пока СтрДлина(Д2) < 2 Цикл Д2 = "0" + Д2; КонецЦикла;
					ДатаНачала = Дата(Г1 + М1 + Д1 + "000000");
					ДатаОкончания = КонецДня(Дата(Г2 + М2 + Д2 + "000000"));
					ИспользоватьПериод = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга from/to: " + ЗначFrom + " / " + ЗначTo);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрНомер = Ложь;
		НомерШаблон = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрНомер = Истина; НомерШаблон = "%" + ЗначCode + "%"; Иначе НомерШаблон = "%"; КонецЕсли;

		ДатаФильтр = Дата(1, 1, 1);
		ДатаФильтрКонец = Дата(1, 1, 1);
		ИспользоватьФильтрДата = Ложь;
		ЗначDate = "";
		Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначDate) Тогда Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначDate) Тогда
			Попытка
				Г = ""; М = ""; Д = "";
				ЧастиТочка = СтрРазделить(ЗначDate, ".", Ложь);
				ЧастиДефис = СтрРазделить(ЗначDate, "-", Ложь);
				Если ЧастиТочка.Количество() = 3 Тогда Д = ЧастиТочка[0]; М = ЧастиТочка[1]; Г = ЧастиТочка[2];
				ИначеЕсли ЧастиДефис.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧастиДефис[0])) = 4 Тогда Г = ЧастиДефис[0]; М = ЧастиДефис[1]; Д = ЧастиДефис[2]; Иначе Д = ЧастиДефис[0]; М = ЧастиДефис[1]; Г = ЧастиДефис[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г) Тогда
					Пока СтрДлина(Г) < 4 Цикл Г = "0" + Г; КонецЦикла;
					Пока СтрДлина(М) < 2 Цикл М = "0" + М; КонецЦикла;
					Пока СтрДлина(Д) < 2 Цикл Д = "0" + Д; КонецЦикла;
					ДатаФильтр = Дата(Г + М + Д + "000000");
					ДатаФильтрКонец = КонецДня(ДатаФильтр);
					ИспользоватьФильтрДата = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга date: " + ЗначDate);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрКонтрагент = Ложь;
		ШаблонКонтрагент = "";
		ЗначContractor = "";
		Попытка ЗначContractor = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначContractor) Тогда Попытка ЗначContractor = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначContractor) Тогда ИспользоватьФильтрКонтрагент = Истина; ШаблонКонтрагент = "%" + ЗначContractor + "%"; Иначе ШаблонКонтрагент = "%"; КонецЕсли;

		ИспользоватьФильтрОрганизация = Ложь;
		ШаблонОрганизация = "";
		ЗначOrg = "";
		Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначOrg) Тогда Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначOrg) Тогда ИспользоватьФильтрОрганизация = Истина; ШаблонОрганизация = "%" + ЗначOrg + "%"; Иначе ШаблонОрганизация = "%"; КонецЕсли;

		ИспользоватьФильтрСклад = Ложь;
		ШаблонСклад = "";
		ЗначWarehouse = "";
		Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("warehouse"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначWarehouse) Тогда Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыURL["warehouse"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначWarehouse) Тогда ИспользоватьФильтрСклад = Истина; ШаблонСклад = "%" + ЗначWarehouse + "%"; Иначе ШаблонСклад = "%"; КонецЕсли;

		ИспользоватьФильтрОтветственный = Ложь;
		ШаблонОтветственный = "";
		ЗначResponsible = "";
		Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("responsible"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначResponsible) Тогда Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыURL["responsible"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначResponsible) Тогда ИспользоватьФильтрОтветственный = Истина; ШаблонОтветственный = "%" + ЗначResponsible + "%"; Иначе ШаблонОтветственный = "%"; КонецЕсли;

		ИспользоватьФильтрСумма = Ложь;
		СуммаФильтр = 0;
		ЗначSumm = "";
		Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("summ"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSumm) Тогда Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыURL["summ"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSumm) Тогда Попытка СуммаФильтр = Число(ЗначSumm); ИспользоватьФильтрСумма = Истина; Исключение КонецПопытки; КонецЕсли;

		ИспользоватьФильтрПроведен = Ложь;
		ПроведенФильтр = Ложь;
		ЗначApproved = "";
		Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("approved"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначApproved) Тогда Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыURL["approved"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначApproved) Тогда ИспользоватьФильтрПроведен = Истина; ПроведенФильтр = (ВРег(ЗначApproved) = "1" Или ВРег(ЗначApproved) = "TRUE" Или ВРег(ЗначApproved) = "ДА" Или ВРег(ЗначApproved) = "YES"); КонецЕсли;

		// Параметр full: в 1С ключи ПараметрыURL могут приходить с разным регистром (Full, FULL).
		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	ПТУ.Ссылка КАК Ссылка,
		|	ПТУ.Номер КАК Номер,
		|	ПТУ.Дата КАК ДатаДокумента,
		|	ПТУ.Сделка КАК Сделка,
		|	ПРЕДСТАВЛЕНИЕ(ПТУ.Контрагент) КАК Контрагент,
		|	ПРЕДСТАВЛЕНИЕ(ПТУ.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(ПТУ.СкладОрдер) КАК Склад,
		|	ПРЕДСТАВЛЕНИЕ(ПТУ.Ответственный) КАК Ответственный,
		|	ПТУ.СуммаДокумента КАК СуммаДокумента,
		|	ПТУ.Проведен КАК Проведен,
		|	ПТУ.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ПоступлениеТоваровУслуг КАК ПТУ
		|ГДЕ
		|	(НЕ &ИспользоватьПериод ИЛИ (ПТУ.Дата >= &ДатаНачала И ПТУ.Дата <= &ДатаОкончания))
		|	И (НЕ &ИспользоватьФильтрНомер ИЛИ ПТУ.Номер ПОДОБНО &НомерШаблон)
		|	И (НЕ &ИспользоватьФильтрДата ИЛИ (ПТУ.Дата >= &ДатаФильтр И ПТУ.Дата <= &ДатаФильтрКонец))
		|	И (НЕ &ИспользоватьФильтрСумма ИЛИ ПТУ.СуммаДокумента = &СуммаФильтр)
		|	И (НЕ &ИспользоватьФильтрПроведен ИЛИ ПТУ.Проведен = &ПроведенФильтр)
		|УПОРЯДОЧИТЬ ПО
		|	ПТУ.Дата УБЫВ, ПТУ.Номер УБЫВ";

		ЗапросБД.УстановитьПараметр("ИспользоватьПериод", ИспользоватьПериод);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
		ЗапросБД.УстановитьПараметр("НомерШаблон", НомерШаблон);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
		ЗапросБД.УстановитьПараметр("ДатаФильтр", ДатаФильтр);
		ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", ДатаФильтрКонец);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрСумма", ИспользоватьФильтрСумма);
		ЗапросБД.УстановитьПараметр("СуммаФильтр", СуммаФильтр);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПроведен", ИспользоватьФильтрПроведен);
		ЗапросБД.УстановитьПараметр("ПроведенФильтр", ПроведенФильтр);

		ШаблонБСЛ_Контрагент = СтрЗаменить(СтрЗаменить(ШаблонКонтрагент, "%", "*"), "_", "?");
		ШаблонБСЛ_Организация = СтрЗаменить(СтрЗаменить(ШаблонОрганизация, "%", "*"), "_", "?");
		ШаблонБСЛ_Склад = СтрЗаменить(СтрЗаменить(ШаблонСклад, "%", "*"), "_", "?");
		ШаблонБСЛ_Ответственный = СтрЗаменить(СтрЗаменить(ШаблонОтветственный, "%", "*"), "_", "?");

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Если ИспользоватьФильтрКонтрагент = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Контрагент, 2, СтрДлина(ШаблонБСЛ_Контрагент) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрОрганизация = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Организация, 2, СтрДлина(ШаблонБСЛ_Организация) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрСклад = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Склад, 2, СтрДлина(ШаблонБСЛ_Склад) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Склад)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрОтветственный = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Ответственный, 2, СтрДлина(ШаблонБСЛ_Ответственный) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Ответственный)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;

			Поступление = Новый Структура;
			Поступление.Вставить("Номер", Выборка.Номер);
			СтрокаДаты = ""; Если ЗначениеЗаполнено(Выборка.ДатаДокумента) Тогда СтрокаДаты = Формат(Выборка.ДатаДокумента, "ДФ=dd.MM.yyyy"); КонецЕсли;
			Поступление.Вставить("ДатаДокумента", СтрокаДаты);
			Поступление.Вставить("Дата", СтрокаДаты);
			Если Не ЗначениеЗаполнено(Выборка.Контрагент) Тогда Поступление.Вставить("Контрагент", "Не указан"); Иначе Поступление.Вставить("Контрагент", Выборка.Контрагент); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Организация) Тогда Поступление.Вставить("Организация", "Не указана"); Иначе Поступление.Вставить("Организация", Выборка.Организация); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Склад) Тогда Поступление.Вставить("Склад", "Не указан"); Иначе Поступление.Вставить("Склад", Выборка.Склад); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Ответственный) Тогда Поступление.Вставить("Ответственный", "Не указан"); Иначе Поступление.Вставить("Ответственный", Выборка.Ответственный); КонецЕсли;
			Если ПустаяСтрока(Строка(Выборка.СуммаДокумента)) Или Выборка.СуммаДокумента = Неопределено Тогда Поступление.Вставить("СуммаДокумента", 0); Иначе Поступление.Вставить("СуммаДокумента", Выборка.СуммаДокумента); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Комментарий) Тогда Поступление.Вставить("Комментарий", ""); Иначе Поступление.Вставить("Комментарий", Выборка.Комментарий); КонецЕсли;
			Поступление.Вставить("Проведен", Выборка.Проведен);

			Если ПолныйОтвет Тогда
			// Сделка (документ-основание: заказ поставщику и т.д.).
			СделкаСтр = Новый Структура;
			Если ЗначениеЗаполнено(Выборка.Сделка) Тогда
				Попытка
					СделкаСтр.Вставить("Тип", Выборка.Сделка.Метаданные().Имя);
					СделкаСтр.Вставить("Номер", Выборка.Сделка.Номер);
					ДатаСд = ""; Если ЗначениеЗаполнено(Выборка.Сделка.Дата) Тогда ДатаСд = Формат(Выборка.Сделка.Дата, "ДФ=dd.MM.yyyy"); КонецЕсли;
					СделкаСтр.Вставить("Дата", ДатаСд);
					СделкаСтр.Вставить("НомерДата", Строка(Выборка.Сделка.Номер) + " от " + ДатаСд);
				Исключение
					МассивОшибок.Добавить("Поступление №" + Выборка.Номер + ": не удалось прочитать Сделка — " + ОписаниеОшибки());
				КонецПопытки;
			Иначе
				СделкаСтр.Вставить("Тип", ""); СделкаСтр.Вставить("Номер", ""); СделкаСтр.Вставить("Дата", ""); СделкаСтр.Вставить("НомерДата", "");
			КонецЕсли;
			Поступление.Вставить("Сделка", СделкаСтр);

			// Табличная часть Товары и Услуги — через ПолучитьОбъект() и обход ТЧ (как в receipts.bsl).
			МассивТоваров = Новый Массив;
			МассивУслуг = Новый Массив;
			Попытка
				ОбъектПоступление = Выборка.Ссылка.ПолучитьОбъект();
				Для Каждого СтрокаТЧ Из ОбъектПоступление.Товары Цикл
					Стр = Новый Структура;
					Стр.Вставить("НомерСтроки", Строка(СтрокаТЧ.НомерСтроки));
					Стр.Вставить("Номенклатура", ?(ЗначениеЗаполнено(СтрокаТЧ.Номенклатура), Строка(СтрокаТЧ.Номенклатура.Наименование), ""));
					Стр.Вставить("ХарактеристикаНоменклатуры", ?(ЗначениеЗаполнено(СтрокаТЧ.ХарактеристикаНоменклатуры), Строка(СтрокаТЧ.ХарактеристикаНоменклатуры.Наименование), ""));
					Стр.Вставить("ЕдиницаИзмерения", ?(ЗначениеЗаполнено(СтрокаТЧ.ЕдиницаИзмерения), Строка(СтрокаТЧ.ЕдиницаИзмерения.Наименование), ""));
					Стр.Вставить("Количество", СтрокаТЧ.Количество);
					Стр.Вставить("Цена", СтрокаТЧ.Цена);
					Стр.Вставить("Сумма", СтрокаТЧ.Сумма);
					Стр.Вставить("СтавкаНДС", Строка(СтрокаТЧ.СтавкаНДС));
					Стр.Вставить("СуммаНДС", СтрокаТЧ.СуммаНДС);
					МассивТоваров.Добавить(Стр);
				КонецЦикла;
				Для Каждого СтрокаТЧ Из ОбъектПоступление.Услуги Цикл
					Стр = Новый Структура;
					Стр.Вставить("НомерСтроки", Строка(СтрокаТЧ.НомерСтроки));
					Стр.Вставить("Содержание", Строка(СтрокаТЧ.Содержание));
					Стр.Вставить("Номенклатура", ?(ЗначениеЗаполнено(СтрокаТЧ.Номенклатура), Строка(СтрокаТЧ.Номенклатура.Наименование), ""));
					Стр.Вставить("Количество", СтрокаТЧ.Количество);
					Стр.Вставить("Цена", СтрокаТЧ.Цена);
					Стр.Вставить("Сумма", СтрокаТЧ.Сумма);
					Стр.Вставить("СтавкаНДС", Строка(СтрокаТЧ.СтавкаНДС));
					Стр.Вставить("СуммаНДС", СтрокаТЧ.СуммаНДС);
					МассивУслуг.Добавить(Стр);
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Поступление №" + Выборка.Номер + ": ошибка чтения ТЧ Товары/Услуги — " + ОписаниеОшибки());
			КонецПопытки;
			Поступление.Вставить("Товары", МассивТоваров);
			Поступление.Вставить("Услуги", МассивУслуг);

			// Вложения из хранилища дополнительной информации.
			МассивВложений = Новый Массив;
			ЗапросХДИ = Новый Запрос;
			ЗапросХДИ.Текст = "ВЫБРАТЬ ХДИ.Ссылка КАК Ссылка, ХДИ.ИмяФайла КАК ИмяФайла ИЗ Справочник.ХранилищеДополнительнойИнформации КАК ХДИ ГДЕ ХДИ.Объект = &СсылкаДокумента";
			ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", Выборка.Ссылка);
			Попытка
				РезультатХДИ = ЗапросХДИ.Выполнить();
				ВыборкаХДИ = РезультатХДИ.Выбрать();
				Пока ВыборкаХДИ.Следующий() Цикл
					Попытка
						ЭлементХДИ = ВыборкаХДИ.Ссылка.ПолучитьОбъект();
						ДвоичныеДанные = Неопределено;
						Если ЗначениеЗаполнено(ЭлементХДИ.Хранилище) Тогда ДвоичныеДанные = ЭлементХДИ.Хранилище.Получить(); КонецЕсли;
						ДанныеBase64 = "";
						Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") И ДвоичныеДанные.Размер() > 0 Тогда Попытка ДанныеBase64 = Строка(Base64Строка(ДвоичныеДанные)); Исключение ДанныеBase64 = ""; КонецПопытки; КонецЕсли;
						Вложение = Новый Структура("ИмяФайла", ВыборкаХДИ.ИмяФайла); Вложение.Вставить("Данные", ДанныеBase64);
						МассивВложений.Добавить(Вложение);
					Исключение
						МассивОшибок.Добавить("Поступление №" + Выборка.Номер + ": не удалось прочитать вложение """ + ВыборкаХДИ.ИмяФайла + """ — " + ОписаниеОшибки());
					КонецПопытки;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Поступление №" + Выборка.Номер + ": ошибка запроса вложений — " + ОписаниеОшибки());
			КонецПопытки;
			Поступление.Вставить("Вложения", МассивВложений);

			Иначе
			// Сводки по Сделка и Вложения (без full).
			СделкаЕсть = ЗначениеЗаполнено(Выборка.Сделка);
			КоличествоВложений = 0;
			Попытка
				ЗапросХДИ = Новый Запрос;
				ЗапросХДИ.Текст = "ВЫБРАТЬ КОЛИЧЕСТВО(ХДИ.Ссылка) КАК Количество ИЗ Справочник.ХранилищеДополнительнойИнформации КАК ХДИ ГДЕ ХДИ.Объект = &СсылкаДокумента";
				ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", Выборка.Ссылка);
				РезХДИ = ЗапросХДИ.Выполнить();
				ТХДИ = РезХДИ.Выгрузить();
				Если ТХДИ.Количество() > 0 Тогда КоличествоВложений = ТХДИ[0].Количество; КонецЕсли;
			Исключение КонецПопытки;
			СделкаКратко = Новый Структура("Есть", СделкаЕсть, "Количество", ?(СделкаЕсть, 1, 0));
			ВложенияКратко = Новый Структура("Есть", КоличествоВложений > 0, "Количество", КоличествоВложений);
			Поступление.Вставить("Сделка", СделкаКратко);
			Поступление.Вставить("Вложения", ВложенияКратко);
			КонецЕсли;

			Попытка
				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Поступление);
				ТестоваяЗаписьJSON.Закрыть();
				МассивПоступлений.Добавить(Поступление);
			Исключение
				МассивОшибок.Добавить("Проблема в поступлении №" + Выборка.Номер + " от " + Формат(Выборка.ДатаДокумента, "ДФ=dd.MM.yyyy") + ". Ошибка: " + ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивПоступлений);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		JSON = Новый ЗаписьJSON;
		JSON.УстановитьСтроку();
		ЗаписатьJSON(JSON, ИтоговыйРезультат);
		JSONСтрока = JSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
