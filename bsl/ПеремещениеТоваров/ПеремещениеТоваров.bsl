// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Перемещение товаров (Документ.ПеремещениеТоваров). В JSON: data — массив перемещений (Номер, Дата, СкладОтправитель, СкладПолучатель, Ответственный, Комментарий, Материалы — сводка или ТЧ Товары); errors — массив ошибок.
// Параметры: code — фильтр по номеру (ПОДОБНО); from, to — период по дате документа; date — одна дата (диапазон дня); responsible — подстрока по наименованию ответственного (ПОДОБНО); sender, receiver — подстрока по наименованию склада отправителя/получателя; full (при true — ТЧ Товары; при full требуется code). По умолчанию — базовый набор полей и сводка «N позиций». Даты: dd.MM.yyyy, dd-MM-yyyy, yyyy-MM-dd.

Функция GetTransfers(Запрос) Экспорт
	МассивПеремещений = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ИспользоватьФильтрНомер = Ложь;
		ШаблонНомер = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрНомер = Истина; ШаблонНомер = "%" + ЗначCode + "%"; Иначе ШаблонНомер = "%"; КонецЕсли;

		ДатаНачала = Дата(1, 1, 1);
		ДатаОкончания = Дата(1, 1, 1);
		ИспользоватьПериод = Ложь;
		ЗначFrom = "";
		ЗначTo = "";
		Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFrom) Тогда Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки; КонецЕсли;
		Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначTo) Тогда Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFrom) И ЗначениеЗаполнено(ЗначTo) Тогда
			Попытка
				Г1 = ""; М1 = ""; Д1 = "";
				ЧТ1 = СтрРазделить(ЗначFrom, ".", Ложь); ЧД1 = СтрРазделить(ЗначFrom, "-", Ложь);
				Если ЧТ1.Количество() = 3 Тогда Д1 = ЧТ1[0]; М1 = ЧТ1[1]; Г1 = ЧТ1[2];
				ИначеЕсли ЧД1.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД1[0])) = 4 Тогда Г1 = ЧД1[0]; М1 = ЧД1[1]; Д1 = ЧД1[2]; Иначе Д1 = ЧД1[0]; М1 = ЧД1[1]; Г1 = ЧД1[2]; КонецЕсли;
				КонецЕсли;
				Г2 = ""; М2 = ""; Д2 = "";
				ЧТ2 = СтрРазделить(ЗначTo, ".", Ложь); ЧД2 = СтрРазделить(ЗначTo, "-", Ложь);
				Если ЧТ2.Количество() = 3 Тогда Д2 = ЧТ2[0]; М2 = ЧТ2[1]; Г2 = ЧТ2[2];
				ИначеЕсли ЧД2.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД2[0])) = 4 Тогда Г2 = ЧД2[0]; М2 = ЧД2[1]; Д2 = ЧД2[2]; Иначе Д2 = ЧД2[0]; М2 = ЧД2[1]; Г2 = ЧД2[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г1) И ЗначениеЗаполнено(Г2) Тогда
					Пока СтрДлина(Г1) < 4 Цикл Г1 = "0" + Г1; КонецЦикла; Пока СтрДлина(М1) < 2 Цикл М1 = "0" + М1; КонецЦикла; Пока СтрДлина(Д1) < 2 Цикл Д1 = "0" + Д1; КонецЦикла;
					Пока СтрДлина(Г2) < 4 Цикл Г2 = "0" + Г2; КонецЦикла; Пока СтрДлина(М2) < 2 Цикл М2 = "0" + М2; КонецЦикла; Пока СтрДлина(Д2) < 2 Цикл Д2 = "0" + Д2; КонецЦикла;
					ДатаНачала = Дата(Г1 + М1 + Д1 + "000000");
					ДатаОкончания = КонецДня(Дата(Г2 + М2 + Д2 + "000000"));
					ИспользоватьПериод = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга from/to: " + ЗначFrom + " / " + ЗначTo);
			КонецПопытки;
		КонецЕсли;

		ДатаФильтр = Дата(1, 1, 1);
		ДатаФильтрКонец = Дата(1, 1, 1);
		ИспользоватьФильтрДата = Ложь;
		ЗначDate = "";
		Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначDate) Тогда Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначDate) Тогда
			Попытка
				Г = ""; М = ""; Д = "";
				ЧастиТочка = СтрРазделить(ЗначDate, ".", Ложь);
				ЧастиДефис = СтрРазделить(ЗначDate, "-", Ложь);
				Если ЧастиТочка.Количество() = 3 Тогда Д = ЧастиТочка[0]; М = ЧастиТочка[1]; Г = ЧастиТочка[2];
				ИначеЕсли ЧастиДефис.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧастиДефис[0])) = 4 Тогда Г = ЧастиДефис[0]; М = ЧастиДефис[1]; Д = ЧастиДефис[2]; Иначе Д = ЧастиДефис[0]; М = ЧастиДефис[1]; Г = ЧастиДефис[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г) Тогда
					Пока СтрДлина(Г) < 4 Цикл Г = "0" + Г; КонецЦикла;
					Пока СтрДлина(М) < 2 Цикл М = "0" + М; КонецЦикла;
					Пока СтрДлина(Д) < 2 Цикл Д = "0" + Д; КонецЦикла;
					ДатаФильтр = Дата(Г + М + Д + "000000");
					ДатаФильтрКонец = КонецДня(ДатаФильтр);
					ИспользоватьФильтрДата = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга date: " + ЗначDate);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрОтправитель = Ложь;
		ШаблонОтправитель = "";
		ЗначSender = "";
		Попытка ЗначSender = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("sender"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSender) Тогда Попытка ЗначSender = СокрЛП(Строка(Запрос.ПараметрыURL["sender"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSender) Тогда ИспользоватьФильтрОтправитель = Истина; ШаблонОтправитель = "%" + ЗначSender + "%"; Иначе ШаблонОтправитель = "%"; КонецЕсли;

		ИспользоватьФильтрПолучатель = Ложь;
		ШаблонПолучатель = "";
		ЗначReceiver = "";
		Попытка ЗначReceiver = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("receiver"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначReceiver) Тогда Попытка ЗначReceiver = СокрЛП(Строка(Запрос.ПараметрыURL["receiver"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначReceiver) Тогда ИспользоватьФильтрПолучатель = Истина; ШаблонПолучатель = "%" + ЗначReceiver + "%"; Иначе ШаблонПолучатель = "%"; КонецЕсли;

		ИспользоватьФильтрОтветственный = Ложь;
		ШаблонОтветственный = "";
		ЗначResponsible = "";
		Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("responsible"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначResponsible) Тогда Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыURL["responsible"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначResponsible) Тогда ИспользоватьФильтрОтветственный = Истина; ШаблонОтветственный = "%" + ЗначResponsible + "%"; Иначе ШаблонОтветственный = "%"; КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		Если ПолныйОтвет И Не ИспользоватьФильтрНомер Тогда
			МассивОшибок.Добавить("Параметр full требует указания code");
		КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	ПеремещениеТоваров.Ссылка КАК Ссылка,
		|	ПеремещениеТоваров.Номер КАК Номер,
		|	ПеремещениеТоваров.Дата КАК Дата,
		|	ПеремещениеТоваров.СкладОтправитель.Наименование КАК СкладОтправитель,
		|	ПеремещениеТоваров.СкладПолучатель.Наименование КАК СкладПолучатель,
		|	ПеремещениеТоваров.Ответственный.Наименование КАК Ответственный,
		|	ЕСТЬNULL(КолПозиций.Кол, 0) КАК КоличествоПозиций,
		|	ПеремещениеТоваров.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
		|	ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|		ТЧ.Ссылка КАК Ссылка,
		|		КОЛИЧЕСТВО(*) КАК Кол
		|	ИЗ
		|		Документ.ПеремещениеТоваров.Товары КАК ТЧ
		|	СГРУППИРОВАТЬ ПО
		|		ТЧ.Ссылка) КАК КолПозиций
		|	ПО КолПозиций.Ссылка = ПеремещениеТоваров.Ссылка
		|ГДЕ
		|	(НЕ &ИспользоватьФильтрНомер ИЛИ ПеремещениеТоваров.Номер ПОДОБНО &ШаблонНомер)
		|	И (НЕ &ИспользоватьПериод ИЛИ (ПеремещениеТоваров.Дата >= &ДатаНачала И ПеремещениеТоваров.Дата <= &ДатаОкончания))
		|	И (НЕ &ИспользоватьФильтрДата ИЛИ (ПеремещениеТоваров.Дата >= &ДатаФильтр И ПеремещениеТоваров.Дата <= &ДатаФильтрКонец))
		|	И (НЕ &ИспользоватьФильтрОтправитель ИЛИ ПеремещениеТоваров.СкладОтправитель.Наименование ПОДОБНО &ШаблонОтправитель)
		|	И (НЕ &ИспользоватьФильтрПолучатель ИЛИ ПеремещениеТоваров.СкладПолучатель.Наименование ПОДОБНО &ШаблонПолучатель)
		|	И (НЕ &ИспользоватьФильтрОтветственный ИЛИ ПеремещениеТоваров.Ответственный.Наименование ПОДОБНО &ШаблонОтветственный)
		|УПОРЯДОЧИТЬ ПО
		|	ПеремещениеТоваров.Дата";
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
		ЗапросБД.УстановитьПараметр("ШаблонНомер", ШаблонНомер);
		ЗапросБД.УстановитьПараметр("ИспользоватьПериод", ИспользоватьПериод);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
		ЗапросБД.УстановитьПараметр("ДатаФильтр", ДатаФильтр);
		ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", ДатаФильтрКонец);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрОтправитель", ИспользоватьФильтрОтправитель);
		ЗапросБД.УстановитьПараметр("ШаблонОтправитель", ШаблонОтправитель);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПолучатель", ИспользоватьФильтрПолучатель);
		ЗапросБД.УстановитьПараметр("ШаблонПолучатель", ШаблонПолучатель);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрОтветственный", ИспользоватьФильтрОтветственный);
		ЗапросБД.УстановитьПараметр("ШаблонОтветственный", ШаблонОтветственный);

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Перемещение = Новый Структура;
			Перемещение.Вставить("Номер", ?(ЗначениеЗаполнено(Выборка.Номер), Строка(Выборка.Номер), ""));
			Перемещение.Вставить("Дата", ?(ЗначениеЗаполнено(Выборка.Дата), Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"), ""));
			Перемещение.Вставить("СкладОтправитель", ?(ЗначениеЗаполнено(Выборка.СкладОтправитель), Строка(Выборка.СкладОтправитель), ""));
			Перемещение.Вставить("СкладПолучатель", ?(ЗначениеЗаполнено(Выборка.СкладПолучатель), Строка(Выборка.СкладПолучатель), ""));
			Перемещение.Вставить("Ответственный", ?(ЗначениеЗаполнено(Выборка.Ответственный), Строка(Выборка.Ответственный), ""));
			Перемещение.Вставить("Комментарий", ?(ЗначениеЗаполнено(Выборка.Комментарий), Строка(Выборка.Комментарий), ""));

			К = Выборка.КоличествоПозиций;
			Если ПолныйОтвет Тогда
				Попытка
					ОбъектПеремещение = Выборка.Ссылка.ПолучитьОбъект();
					К = ОбъектПеремещение.Товары.Количество();
					Товары = Новый Массив;
					Для Каждого СтрокаТЧ Из ОбъектПеремещение.Товары Цикл
						Стр = Новый Структура;
						Стр.Вставить("НомерСтроки", Строка(СтрокаТЧ.НомерСтроки));
						Стр.Вставить("Номенклатура", ?(ЗначениеЗаполнено(СтрокаТЧ.Номенклатура), Строка(СтрокаТЧ.Номенклатура.Наименование), ""));
						Стр.Вставить("ХарактеристикаНоменклатуры", ?(ЗначениеЗаполнено(СтрокаТЧ.ХарактеристикаНоменклатуры), Строка(СтрокаТЧ.ХарактеристикаНоменклатуры.Наименование), ""));
						Стр.Вставить("ЕдиницаИзмерения", ?(ЗначениеЗаполнено(СтрокаТЧ.ЕдиницаИзмерения), Строка(СтрокаТЧ.ЕдиницаИзмерения.Наименование), ""));
						Стр.Вставить("Количество", СтрокаТЧ.Количество);
						Товары.Добавить(Стр);
					КонецЦикла;
					Перемещение.Вставить("Товары", Товары);
				Исключение
					МассивОшибок.Добавить("Перемещение №" + Выборка.Номер + " от " + Формат(Выборка.Дата, "ДФ=dd.MM.yyyy") + ": " + ОписаниеОшибки());
					Товары = Новый Массив;
					Перемещение.Вставить("Товары", Товары);
				КонецПопытки;
			КонецЕсли;
			Если Не ПолныйОтвет Тогда
				Ост10 = К - Цел(К / 10) * 10;
				Ост100 = К - Цел(К / 100) * 100;
				Если Ост10 = 1 И Ост100 <> 11 Тогда Слово = "позиция";
				ИначеЕсли (Ост10 = 2 ИЛИ Ост10 = 3 ИЛИ Ост10 = 4) И (Ост100 < 10 ИЛИ Ост100 >= 20) Тогда Слово = "позиции";
				Иначе Слово = "позиций"; КонецЕсли;
				Перемещение.Вставить("Материалы", Строка(К) + " " + Слово);
			КонецЕсли;
			МассивПеремещений.Добавить(Перемещение);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивПеремещений);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
