// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Спецификации номенклатуры (Справочник.СпецификацииНоменклатуры) с комплектующими (ИсходныеКомплектующие) и этапами поставок. В JSON: data — массив спецификаций (Код, ДатаУтверждения, Ответственный, Наименование, ДатаПоставки, стоимости, Материалы — сводка или массив комплектующих); errors — массив ошибок.
// Параметры: code, name — фильтр по коду/наименованию спецификации (ПОДОБНО); material — фильтр по коду/наименованию комплектующего; ngroup — фильтр по номенклатурной группе комплектующего (ПОДОБНО); year, month — фильтр по дате поставки (month только с year); full (при true или при указании material — полный список Материалов, иначе «N позиций»). full требует name, code или material. Даты в формате dd.MM.yyyy.

Функция GetSpecifications(Запрос) Экспорт
	МассивОшибок = Новый Массив;

	Попытка
		ЗначCode = ""; ЗначName = ""; ЗначMaterial = ""; ЗначNGroup = ""; ЗначYear = ""; ЗначMonth = ""; ЗначFull = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначName) Тогда Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки; КонецЕсли;
		ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
		Попытка ЗначMaterial = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("material"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначMaterial) Тогда Попытка ЗначMaterial = СокрЛП(Строка(Запрос.ПараметрыURL["material"])); Исключение КонецПопытки; КонецЕсли;
		ЗначMaterial = СтрЗаменить(ЗначMaterial, "_slash_", "/");
		Попытка ЗначNGroup = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("ngroup"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначNGroup) Тогда Попытка ЗначNGroup = СокрЛП(Строка(Запрос.ПараметрыURL["ngroup"])); Исключение КонецПопытки; КонецЕсли;
		Попытка ЗначYear = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("year"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначYear) Тогда Попытка ЗначYear = СокрЛП(Строка(Запрос.ПараметрыURL["year"])); Исключение КонецПопытки; КонецЕсли;
		Попытка ЗначMonth = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("month"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначMonth) Тогда Попытка ЗначMonth = СокрЛП(Строка(Запрос.ПараметрыURL["month"])); Исключение КонецПопытки; КонецЕсли;
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		ПолныйРежим = ЗначениеЗаполнено(ЗначFull) И (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА");

		ИспользоватьФильтрКод = ЗначениеЗаполнено(ЗначCode);
		ИспользоватьФильтрНаименование = ЗначениеЗаполнено(ЗначName);
		ИспользоватьФильтрМатериал = ЗначениеЗаполнено(ЗначMaterial);
		ИспользоватьФильтрНомГруппа = ЗначениеЗаполнено(ЗначNGroup);
		МатериалИПолный = ИспользоватьФильтрМатериал И ПолныйРежим;
		НомГруппаИПолный = ИспользоватьФильтрНомГруппа И ПолныйРежим;
		ШаблонКод = ?(ИспользоватьФильтрКод, "%" + ЗначCode + "%", "%");
		ШаблонНаименование = ?(ИспользоватьФильтрНаименование, "%" + ЗначName + "%", "%");
		ШаблонМатериал = ?(ИспользоватьФильтрМатериал, "%" + ЗначMaterial + "%", "%");
		ШаблонНомГруппа = ?(ИспользоватьФильтрНомГруппа, "%" + ЗначNGroup + "%", "%");

		Если ПолныйРежим И Не ИспользоватьФильтрКод И Не ИспользоватьФильтрНаименование И Не ИспользоватьФильтрМатериал И Не ИспользоватьФильтрНомГруппа Тогда
			МассивОшибок.Добавить("full требует параметр name, code, material или ngroup");
		КонецЕсли;
		Если ЗначениеЗаполнено(ЗначMonth) И Не ЗначениеЗаполнено(ЗначYear) Тогда
			МассивОшибок.Добавить("month требует параметр year");
		КонецЕсли;

		ИспользоватьФильтрДата = ЗначениеЗаполнено(ЗначYear);
		ДатаНач = Дата(1, 1, 1);
		ДатаКон = Дата(1, 1, 1);
		Если ИспользоватьФильтрДата Тогда
			ГодЧисло = Число(ЗначYear);
			Если СтрДлина(ЗначYear) = 2 Тогда ГодЧисло = 2000 + ГодЧисло; КонецЕсли;
			Если ЗначениеЗаполнено(ЗначMonth) Тогда
				МесяцЧисло = Число(ЗначMonth);
				ДатаНач = Дата(ГодЧисло, МесяцЧисло, 1);
				ДатаКон = КонецМесяца(ДатаНач);
			Иначе
				ДатаНач = Дата(ГодЧисло, 1, 1);
				ДатаКон = Дата(ГодЧисло, 12, 31, 23, 59, 59);
			КонецЕсли;
		КонецЕсли;

		ПоказыватьПолныйСписокМатериалов = (ПолныйРежим И (ИспользоватьФильтрНаименование Или ИспользоватьФильтрКод)) Или ИспользоватьФильтрМатериал Или ИспользоватьФильтрНомГруппа;

		ЗапросДаты = Новый Запрос;
		ЗапросДаты.Текст =
		"ВЫБРАТЬ
		|	ЭтапыПоставок.Ссылка КАК СпецификацияСсылка,
		|	МИНИМУМ(ЭтапыПоставок.ДатаПоставкиПлан) КАК ДатаПоставки
		|ИЗ
		|	Справочник.СпецификацииНоменклатуры.ЭтапыПоставок КАК ЭтапыПоставок
		|СГРУППИРОВАТЬ ПО
		|	ЭтапыПоставок.Ссылка";
		ДатыПоставкиПоСсылке = Новый Соответствие;
		РезультатДаты = ЗапросДаты.Выполнить();
		ВыборкаДаты = РезультатДаты.Выбрать();
		Пока ВыборкаДаты.Следующий() Цикл
			ДатыПоставкиПоСсылке.Вставить(ВыборкаДаты.СпецификацияСсылка, ВыборкаДаты.ДатаПоставки);
		КонецЦикла;

		УсловиеГде = "НЕ СпецификацииНоменклатуры.ЭтоГруппа И НЕ СпецификацииНоменклатуры.ПометкаУдаления";
		Если ИспользоватьФильтрКод Тогда УсловиеГде = УсловиеГде + " И СпецификацииНоменклатуры.Код ПОДОБНО &ШаблонКод"; КонецЕсли;
		Если ИспользоватьФильтрНаименование Тогда УсловиеГде = УсловиеГде + " И СпецификацииНоменклатуры.Наименование ПОДОБНО &ШаблонНаименование"; КонецЕсли;
		Если ИспользоватьФильтрМатериал Тогда
			Если МатериалИПолный Тогда
				УсловиеГде = УсловиеГде + " И СпецификацииНоменклатуры.Ссылка В (ВЫБРАТЬ РАЗЛИЧНЫЕ КомплектующиеПод.Ссылка ИЗ Справочник.СпецификацииНоменклатуры.ИсходныеКомплектующие КАК КомплектующиеПод ГДЕ КомплектующиеПод.Номенклатура.Код ПОДОБНО &ШаблонМатериал ИЛИ КомплектующиеПод.Номенклатура.Наименование ПОДОБНО &ШаблонМатериал)";
			Иначе
				УсловиеГде = УсловиеГде + " И (Комплектующие.Номенклатура.Код ПОДОБНО &ШаблонМатериал ИЛИ Комплектующие.Номенклатура.Наименование ПОДОБНО &ШаблонМатериал)";
			КонецЕсли;
		КонецЕсли;
		Если ИспользоватьФильтрНомГруппа Тогда
			Если НомГруппаИПолный Тогда
				УсловиеГде = УсловиеГде + " И СпецификацииНоменклатуры.Ссылка В (ВЫБРАТЬ РАЗЛИЧНЫЕ КомплектующиеНГ.Ссылка ИЗ Справочник.СпецификацииНоменклатуры.ИсходныеКомплектующие КАК КомплектующиеНГ ГДЕ КомплектующиеНГ.Номенклатура.НоменклатурнаяГруппа.Наименование ПОДОБНО &ШаблонНомГруппа)";
			Иначе
				УсловиеГде = УсловиеГде + " И Комплектующие.Номенклатура.НоменклатурнаяГруппа.Наименование ПОДОБНО &ШаблонНомГруппа";
			КонецЕсли;
		КонецЕсли;
		Если ИспользоватьФильтрДата Тогда УсловиеГде = УсловиеГде + " И СпецификацииНоменклатуры.Ссылка В (ВЫБРАТЬ РАЗЛИЧНЫЕ ЭтапыПоставок.Ссылка ИЗ Справочник.СпецификацииНоменклатуры.ЭтапыПоставок КАК ЭтапыПоставок ГДЕ ЭтапыПоставок.ДатаПоставкиПлан МЕЖДУ &ДатаНач И &ДатаКон)"; КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	СпецификацииНоменклатуры.Ссылка КАК СпецификацияСсылка,
		|	СпецификацииНоменклатуры.Код КАК КодСпецификации,
		|	СпецификацииНоменклатуры.ДатаУтверждения КАК ДатаУтвержденияСпецификации,
		|	СпецификацииНоменклатуры.Ответственный.Наименование КАК ОтветственныйСпецификации,
		|	СпецификацииНоменклатуры.Наименование КАК Наименование,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьРабот, 0) КАК СтоимостьРабот,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьТранспорт, 0) КАК СтоимостьТранспорт,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьНакладные, 0) КАК СтоимостьНакладные,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьАрендаСпецТехники, 0) КАК СтоимостьАрендаСпецТехники,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьТехнологическиеПрисоединения, 0) КАК СтоимостьТехнологическиеПрисоединения,
		|	ЕСТЬNULL(СпецификацииНоменклатуры.СтоимостьПроектныеРаботы, 0) КАК СтоимостьПроектныеРаботы,
		|	Комплектующие.Номенклатура.Код КАК Код,
		|	Комплектующие.Номенклатура.Наименование КАК Материал,
		|	Комплектующие.Количество КАК Количество,
		|	Комплектующие.ЕдиницаИзмерения.Наименование КАК Единица,
		|	ЕСТЬNULL(Комплектующие.Цена, 0) КАК Цена,
		|	ЕСТЬNULL(Комплектующие.Сумма, 0) КАК Сумма,
		|	ЕСТЬNULL(Комплектующие.Номенклатура.НоменклатурнаяГруппа.Наименование, """") КАК НоменклатурнаяГруппа
		|ИЗ
		|	Справочник.СпецификацииНоменклатуры КАК СпецификацииНоменклатуры
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СпецификацииНоменклатуры.ИсходныеКомплектующие КАК Комплектующие
		|	ПО Комплектующие.Ссылка = СпецификацииНоменклатуры.Ссылка
		|ГДЕ
		|	" + УсловиеГде;
		Если ИспользоватьФильтрКод Тогда ЗапросБД.УстановитьПараметр("ШаблонКод", ШаблонКод); КонецЕсли;
		Если ИспользоватьФильтрНаименование Тогда ЗапросБД.УстановитьПараметр("ШаблонНаименование", ШаблонНаименование); КонецЕсли;
		Если ИспользоватьФильтрМатериал Тогда ЗапросБД.УстановитьПараметр("ШаблонМатериал", ШаблонМатериал); КонецЕсли;
		Если ИспользоватьФильтрНомГруппа Тогда ЗапросБД.УстановитьПараметр("ШаблонНомГруппа", ШаблонНомГруппа); КонецЕсли;
		Если ИспользоватьФильтрДата Тогда ЗапросБД.УстановитьПараметр("ДатаНач", ДатаНач); ЗапросБД.УстановитьПараметр("ДатаКон", ДатаКон); КонецЕсли;

		МассивСпецификаций = Новый Массив;
		СпецификацииПоСсылке = Новый Соответствие;
		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			КлючСпецификации = Выборка.СпецификацияСсылка;
			Спецификация = СпецификацииПоСсылке.Получить(КлючСпецификации);
			Если Спецификация = Неопределено Тогда
				Спецификация = Новый Структура;
				Спецификация.Вставить("Код", ?(ЗначениеЗаполнено(Выборка.КодСпецификации), Строка(Выборка.КодСпецификации), ""));
				ДатаУтв = Выборка.ДатаУтвержденияСпецификации;
				Спецификация.Вставить("ДатаУтверждения", ?(ЗначениеЗаполнено(ДатаУтв), Формат(ДатаУтв, "ДФ=dd.MM.yyyy"), ""));
				Спецификация.Вставить("Ответственный", ?(ЗначениеЗаполнено(Выборка.ОтветственныйСпецификации), Строка(Выборка.ОтветственныйСпецификации), ""));
				Спецификация.Вставить("Наименование", Строка(Выборка.Наименование));
				ДатаПоставки = ДатыПоставкиПоСсылке.Получить(КлючСпецификации);
				Спецификация.Вставить("ДатаПоставки", ?(ЗначениеЗаполнено(ДатаПоставки), Формат(ДатаПоставки, "ДФ=dd.MM.yyyy"), ""));
				Попытка Спецификация.Вставить("СтоимостьРабот", Число(Выборка.СтоимостьРабот)); Исключение Спецификация.Вставить("СтоимостьРабот", 0); КонецПопытки;
				Попытка Спецификация.Вставить("СтоимостьТранспорт", Число(Выборка.СтоимостьТранспорт)); Исключение Спецификация.Вставить("СтоимостьТранспорт", 0); КонецПопытки;
				Попытка Спецификация.Вставить("СтоимостьНакладные", Число(Выборка.СтоимостьНакладные)); Исключение Спецификация.Вставить("СтоимостьНакладные", 0); КонецПопытки;
				Попытка Спецификация.Вставить("СтоимостьАрендаСпецТехники", Число(Выборка.СтоимостьАрендаСпецТехники)); Исключение Спецификация.Вставить("СтоимостьАрендаСпецТехники", 0); КонецПопытки;
				Попытка Спецификация.Вставить("СтоимостьТехнологическиеПрисоединения", Число(Выборка.СтоимостьТехнологическиеПрисоединения)); Исключение Спецификация.Вставить("СтоимостьТехнологическиеПрисоединения", 0); КонецПопытки;
				Попытка Спецификация.Вставить("СтоимостьПроектныеРаботы", Число(Выборка.СтоимостьПроектныеРаботы)); Исключение Спецификация.Вставить("СтоимостьПроектныеРаботы", 0); КонецПопытки;
				Спецификация.Вставить("Материалы", Новый Массив);
				МассивСпецификаций.Добавить(Спецификация);
				СпецификацииПоСсылке.Вставить(КлючСпецификации, Спецификация);
			КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.Код) Или ЗначениеЗаполнено(Выборка.Материал) Тогда
				Комплектующее = Новый Структура;
				Комплектующее.Вставить("Код", ?(ЗначениеЗаполнено(Выборка.Код), Строка(Выборка.Код), ""));
				Комплектующее.Вставить("Материал", ?(ЗначениеЗаполнено(Выборка.Материал), Строка(Выборка.Материал), ""));
				Комплектующее.Вставить("Количество", Выборка.Количество);
				Комплектующее.Вставить("Единица", ?(ЗначениеЗаполнено(Выборка.Единица), Строка(Выборка.Единица), ""));
				Попытка Комплектующее.Вставить("Цена", Число(Выборка.Цена)); Исключение Комплектующее.Вставить("Цена", 0); КонецПопытки;
				Попытка Комплектующее.Вставить("Сумма", Число(Выборка.Сумма)); Исключение Комплектующее.Вставить("Сумма", 0); КонецПопытки;
				Комплектующее.Вставить("НоменклатурнаяГруппа", ?(ЗначениеЗаполнено(Выборка.НоменклатурнаяГруппа), Строка(Выборка.НоменклатурнаяГруппа), ""));
				Спецификация["Материалы"].Добавить(Комплектующее);
			КонецЕсли;
		КонецЦикла;

		Если Не ПоказыватьПолныйСписокМатериалов Тогда
			Для Каждого Спецификация Из МассивСпецификаций Цикл
				К = Спецификация["Материалы"].Количество();
				Ост10 = К - Цел(К / 10) * 10;
				Ост100 = К - Цел(К / 100) * 100;
				Если Ост10 = 1 И Ост100 <> 11 Тогда Слово = "позиция";
				ИначеЕсли (Ост10 = 2 ИЛИ Ост10 = 3 ИЛИ Ост10 = 4) И (Ост100 < 10 ИЛИ Ост100 >= 20) Тогда Слово = "позиции";
				Иначе Слово = "позиций"; КонецЕсли;
				Спецификация.Вставить("Материалы", Строка(К) + " " + Слово);
			КонецЦикла;
		КонецЕсли;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивСпецификаций);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
