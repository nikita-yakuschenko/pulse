Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра) Экспорт
	Значение = "";
	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;
	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;
	Возврат Значение;
КонецФункции

Функция ПолучитьПСПоПодстроке(Значение, КраяШаблона) Экспорт
	Если Значение = "" Тогда
		Возврат "";
	КонецЕсли;
	ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + Значение + "%", "%", "*"), "_", "?");
	Возврат Сред(ШаблонБСЛ, КраяШаблона, СтрДлина(ШаблонБСЛ) - КраяШаблона);
КонецФункции

Функция GetOrgBankAccounts(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначОрг = ПолучитьСтроковойПараметр(Запрос, "org");

	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	БС.Наименование          КАК Наименование,
		|	БС.Код                   КАК Код,
		|	БС.Владелец              КАК Организация,
		|	БС.Банк                  КАК Банк,
		|	БС.НомерСчета            КАК НомерСчета,
		|	БС.ВалютаДенежныхСредств КАК Валюта,
		|	БС.ТекстНазначения       КАК НазначениеСчета
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БС
		|ГДЕ
		|	БС.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	БС.Владелец,
		|	БС.Наименование";

		Выборка = Запрос1С.Выполнить().Выбрать();

	ПС = "";
	КраяШаблона = 2;
	HTTPСтатусОшибки = 500;
	HTTPСтатусУспеха = 200;

	ЗначБанк = ПолучитьСтроковойПараметр(Запрос, "bank");
	ЗначНомерСчета = ПолучитьСтроковойПараметр(Запрос, "account");
	ЗначВалюта = ПолучитьСтроковойПараметр(Запрос, "currency");

	ПС = ПолучитьПСПоПодстроке(ЗначОрг, КраяШаблона);
	ПСБанк = ПолучитьПСПоПодстроке(ЗначБанк, КраяШаблона);
	ПСНомерСчета = ПолучитьПСПоПодстроке(ЗначНомерСчета, КраяШаблона);
	ПСВалюта = ПолучитьПСПоПодстроке(ЗначВалюта, КраяШаблона);

		Пока Выборка.Следующий() Цикл
			Попытка
				ОтклонитьЗапись =
					(ПС <> "" И СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0)
					Или (ПСБанк <> "" И СтрНайти(ВРег(Строка(Выборка.Банк)), ВРег(ПСБанк)) <= 0)
					Или (ПСНомерСчета <> "" И СтрНайти(ВРег(Строка(Выборка.НомерСчета)), ВРег(ПСНомерСчета)) <= 0)
					Или (ПСВалюта <> "" И СтрНайти(ВРег(Строка(Выборка.Валюта)), ВРег(ПСВалюта)) <= 0);
				Если ОтклонитьЗапись Тогда
					Продолжить;
				КонецЕсли;

				Стр = Новый Структура;
				Стр.Вставить("Наименование",    Выборка.Наименование);
				Стр.Вставить("Код",             Выборка.Код);
				Стр.Вставить("Организация",     Строка(Выборка.Организация));
				Стр.Вставить("Банк",            Строка(Выборка.Банк));
				Стр.Вставить("НомерСчета",      Выборка.НомерСчета);
				Стр.Вставить("Валюта",          Строка(Выборка.Валюта));
				Стр.Вставить("НазначениеСчета", Строка(Выборка.НазначениеСчета));

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Стр);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДанных.Добавить(Стр);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(HTTPСтатусОшибки);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДанных);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
