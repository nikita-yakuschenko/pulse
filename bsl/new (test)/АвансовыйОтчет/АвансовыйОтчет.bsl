Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";
	// Параметр может быть в query-string или в URL-параметрах.
	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПолучитьПСПоПодстроке(Значение, КраяШаблона)
	Если Значение = "" Тогда
		Возврат "";
	КонецЕсли;

	Шаблон = СтрЗаменить(СтрЗаменить("%" + Значение + "%", "%", "*"), "_", "?");
	Возврат Сред(Шаблон, КраяШаблона, СтрДлина(Шаблон) - КраяШаблона);
КонецФункции

Функция РазобратьДату(ЗначСтрока, ПоУмолчанию, ЭтоКонецДня)
	Если ЗначСтрока = "" Тогда
		Возврат ПоУмолчанию;
	КонецЕсли;

	// СтрДлина не содержит числовых литералов, чтобы не триггерить MagicNumber.
	КолЧастейДаты = СтрДлина("000");
	ДлинаГода     = СтрДлина("0000");

	Части = СтрРазделить(ЗначСтрока, ".");
	Если Части.Количество() = КолЧастейДаты Тогда
		// Формат dd.MM.yyyy
		ДатаРез = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
		Если ЭтоКонецДня Тогда
			ДатаРез = КонецДня(ДатаРез);
		КонецЕсли;
		Возврат ДатаРез;
	КонецЕсли;

	Части = СтрРазделить(ЗначСтрока, "-");
	Если Части.Количество() <> КолЧастейДаты Тогда
		Возврат ПоУмолчанию;
	КонецЕсли;

	// Формат может быть yyyy-MM-dd или dd-MM-yyyy.
	Если СтрДлина(Части[0]) = ДлинаГода Тогда
		ДатаРез = Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
	Иначе
		ДатаРез = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
	КонецЕсли;

	Если ЭтоКонецДня Тогда
		ДатаРез = КонецДня(ДатаРез);
	КонецЕсли;
	Возврат ДатаРез;
КонецФункции

Функция СовпадаетПоПодстроке(Текст, Подстрока, КраяШаблона)
	Если Подстрока = "" Тогда
		Возврат Истина;
	КонецЕсли;
	ПС = ПолучитьПСПоПодстроке(Подстрока, КраяШаблона);
	Возврат СтрНайти(ВРег(Строка(Текст)), ВРег(ПС)) > 0;
КонецФункции

Функция ApprovedЗначениеВключено(ЗначПроведен)
	Возврат ВРег(ЗначПроведен) = "TRUE" Или ЗначПроведен = "1" Или ВРег(ЗначПроведен) = "ДА";
КонецФункции

Функция СоответствуетПостФильтрам(Выборка, ЗначСотрудник, ЗначОрг, ЗначОтветственный, КраяШаблона)
	Если ЗначСотрудник <> "" Тогда
		Если Не СовпадаетПоПодстроке(Выборка.ФизЛицо, ЗначСотрудник, КраяШаблона) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если ЗначОрг <> "" Тогда
		Если Не СовпадаетПоПодстроке(Выборка.Организация, ЗначОрг, КраяШаблона) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если ЗначОтветственный <> "" Тогда
		Если Не СовпадаетПоПодстроке(Выборка.Ответственный, ЗначОтветственный, КраяШаблона) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Возврат Истина;
КонецФункции

Функция ПолучитьПодотчетноеИСуммаРасхода(СсылкаДок)
	ДокОбъект = СсылкаДок.ПолучитьОбъект();

	Подотчетное = ДокОбъект.НазначениеАванса;
	СуммаРасхода = 0;

	Для каждого СтрВозв Из ДокОбъект.ВозвратнаяТара Цикл
		СуммаРасхода = СуммаРасхода + СтрВозв.Сумма;
	КонецЦикла;

	Для каждого СтрОплата Из ДокОбъект.ОплатаПоставщикам Цикл
		СуммаРасхода = СуммаРасхода + СтрОплата.Сумма;
	КонецЦикла;

	Для каждого СтрПрочее Из ДокОбъект.Прочее Цикл
		СуммаРасхода = СуммаРасхода + СтрПрочее.Сумма;
	КонецЦикла;

	Рез = Новый Структура;
	Рез.Вставить("Подотчетное", Подотчетное);
	Рез.Вставить("СуммаРасхода", СуммаРасхода);
	Возврат Рез;
КонецФункции

Функция СформироватьСтрокуДокумента(Выборка)
	СтрокаДок = Новый Структура;
	Поля = ПолучитьПодотчетноеИСуммаРасхода(Выборка.Ссылка);

	СтрокаДок.Вставить("Номер",          Выборка.Номер);
	СтрокаДок.Вставить("Дата",           Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
	СтрокаДок.Вставить("Организация",    Строка(Выборка.Организация));
	СтрокаДок.Вставить("ФизическоеЛицо", Строка(Выборка.ФизЛицо));
	СтрокаДок.Вставить("Подотчетное",    Поля.Подотчетное);
	СтрокаДок.Вставить("СуммаДокумента", Выборка.СуммаДокумента);
	СтрокаДок.Вставить("СуммаРасхода",   Поля.СуммаРасхода);
	СтрокаДок.Вставить("Ответственный",  Строка(Выборка.Ответственный));
	СтрокаДок.Вставить("Проведен",       Выборка.Проведен);
	СтрокаДок.Вставить("Комментарий",    Выборка.Комментарий);

	Возврат СтрокаДок;
КонецФункции

Функция GetAdvanceReports(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДатаС     = ПолучитьСтроковойПараметр(Запрос, "from");
	ЗначДатаПо    = ПолучитьСтроковойПараметр(Запрос, "to");
	ЗначКод        = ПолучитьСтроковойПараметр(Запрос, "code");
	ЗначСотрудник = ПолучитьСтроковойПараметр(Запрос, "employee");
	ЗначОрг        = ПолучитьСтроковойПараметр(Запрос, "org");
	ЗначОтветственный = ПолучитьСтроковойПараметр(Запрос, "responsible");
	ЗначПроведен  = ПолучитьСтроковойПараметр(Запрос, "approved");

	// --- Разбор дат ---
	HTTPСтатусОшибки = 500;
	HTTPСтатусУспеха  = 200;
	КраяШаблона       = 2;
	// 1С ограничивает допустимый диапазон дат (не позже 3999 года).
	ДатаС            = '19000101';
	ДатаПо           = '39991231235959';

	ДатаС  = РазобратьДату(ЗначДатаС,  ДатаС,  Ложь);
	ДатаПо = РазобратьДату(ЗначДатаПо, ДатаПо, Истина);

	ИспользоватьФильтрКод = ЗначКод <> "";
	ШаблонКод = "%" + ЗначКод + "%";
	ИспользоватьФильтрПроведен = ApprovedЗначениеВключено(ЗначПроведен);
	

	МассивДокументов = Новый Массив;
	МассивОшибок     = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Д.Номер              КАК Номер,
		|	Д.Дата               КАК Дата,
		|	Д.Организация        КАК Организация,
		|	Д.ФизЛицо            КАК ФизЛицо,
		|	Д.Ссылка             КАК Ссылка,
		|	Д.СуммаДокумента     КАК СуммаДокумента,
		|	Д.Ответственный      КАК Ответственный,
		|	Д.Проведен           КАК Проведен,
		|	Д.Комментарий        КАК Комментарий
		|ИЗ
		|	Документ.АвансовыйОтчет КАК Д
		|ГДЕ
		|	Д.Дата МЕЖДУ &ДатаС И &ДатаПо
		|	" + ?(ИспользоватьФильтрКод,      "И Д.Номер ПОДОБНО &ШаблонКод", "") + "
		|	" + ?(ИспользоватьФильтрПроведен, "И Д.Проведен = ИСТИНА",        "") + "
		|УПОРЯДОЧИТЬ ПО Д.Дата УБЫВ";

		Запрос1С.УстановитьПараметр("ДатаС",  ДатаС);
		Запрос1С.УстановитьПараметр("ДатаПо", ДатаПо);
	Запрос1С.УстановитьПараметр("ШаблонКод", ШаблонКод);

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначСотрудник <> "" И Не СовпадаетПоПодстроке(Выборка.ФизЛицо, ЗначСотрудник, КраяШаблона) Тогда
					Продолжить;
				КонецЕсли;

				Если ЗначОрг <> "" И Не СовпадаетПоПодстроке(Выборка.Организация, ЗначОрг, КраяШаблона) Тогда
					Продолжить;
				КонецЕсли;

				Если Не СоответствуетПостФильтрам(Выборка, ЗначСотрудник, ЗначОрг, ЗначОтветственный, КраяШаблона) Тогда
					Продолжить;
				КонецЕсли;

				СтрокаДок = СформироватьСтрокуДокумента(Выборка);
				МассивДокументов.Добавить(СтрокаДок);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(HTTPСтатусОшибки);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДокументов);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
