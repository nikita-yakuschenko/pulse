Функция GetOrganizations(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначНаим = "";
	Попытка
		ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name")));
	Исключение
	КонецПопытки;
	Если ЗначНаим = "" Тогда
		Попытка ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначИНН = "";
	Попытка
		ЗначИНН = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("inn")));
	Исключение
	КонецПопытки;
	Если ЗначИНН = "" Тогда
		Попытка ЗначИНН = СокрЛП(Строка(Запрос.ПараметрыURL["inn"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Запрос ---
	МассивОрганизаций = Новый Массив;
	МассивОшибок      = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Орг.Наименование     КАК Наименование,
		|	Орг.НаименованиеПолное КАК НаименованиеПолное,
		|	Орг.ИНН              КАК ИНН,
		|	Орг.КПП              КАК КПП,
		|	Орг.Префикс          КАК Префикс,
		|	Орг.ЮридическоеФизическоеЛицо КАК ЮрФизЛицо,
		|	Орг.ОсновнойБанковскийСчет КАК БанковскийСчет
		|ИЗ
		|	Справочник.Организации КАК Орг
		|ГДЕ
		|	Орг.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	Орг.Наименование";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначНаим <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНаим + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Наименование)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначИНН <> "" Тогда
					Если СтрНайти(Выборка.ИНН, ЗначИНН) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаОрг = Новый Структура;
				СтрокаОрг.Вставить("Наименование",        Выборка.Наименование);
				СтрокаОрг.Вставить("НаименованиеПолное",  Выборка.НаименованиеПолное);
				СтрокаОрг.Вставить("ИНН",                 Выборка.ИНН);
				СтрокаОрг.Вставить("КПП",                 Выборка.КПП);
				СтрокаОрг.Вставить("Префикс",             Выборка.Префикс);
				СтрокаОрг.Вставить("ЮрФизЛицо",           Строка(Выборка.ЮрФизЛицо));
				СтрокаОрг.Вставить("БанковскийСчет",      Строка(Выборка.БанковскийСчет));

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаОрг);
				ТестоваяЗаписьJSON.Закрыть();

				МассивОрганизаций.Добавить(СтрокаОрг);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивОрганизаций);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
