Функция GetPrices(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДата = "";
	Попытка
		ЗначДата = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date")));
	Исключение
	КонецПопытки;
	Если ЗначДата = "" Тогда
		Попытка ЗначДата = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначТипЦен = "";
	Попытка
		ЗначТипЦен = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("pricetype")));
	Исключение
	КонецПопытки;
	Если ЗначТипЦен = "" Тогда
		Попытка ЗначТипЦен = СокрЛП(Строка(Запрос.ПараметрыURL["pricetype"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначНоменклатура = "";
	Попытка
		ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("item")));
	Исключение
	КонецПопытки;
	Если ЗначНоменклатура = "" Тогда
		Попытка ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыURL["item"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор даты среза ---
	ДатаСреза = ТекущаяДата();

	Если ЗначДата <> "" Тогда
		Попытка
			ЧастиД = СтрРазделить(ЗначДата, ".");
			Если ЧастиД.Количество() = 3 Тогда
				ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
			Иначе
				ЧастиД = СтрРазделить(ЗначДата, "-");
				Если ЧастиД.Количество() = 3 Тогда
					Если СтрДлина(ЧастиД[0]) = 4 Тогда
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[0]), Число(ЧастиД[1]), Число(ЧастиД[2])));
					Иначе
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	// --- Запрос ---
	МассивЦен    = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Ср.ТипЦен         КАК ТипЦен,
		|	Ср.Номенклатура    КАК Номенклатура,
		|	Ср.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		|	Ср.Цена            КАК Цена,
		|	Ср.Валюта          КАК Валюта,
		|	Ср.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Ср.Период          КАК Период
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСреза, ) КАК Ср
		|УПОРЯДОЧИТЬ ПО
		|	Ср.ТипЦен,
		|	Ср.Номенклатура";

		Запрос1С.УстановитьПараметр("ДатаСреза", ДатаСреза);

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначТипЦен <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначТипЦен + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.ТипЦен)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначНоменклатура <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНоменклатура + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Номенклатура)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаЦены = Новый Структура;
				СтрокаЦены.Вставить("ТипЦен",                   Строка(Выборка.ТипЦен));
				СтрокаЦены.Вставить("Номенклатура",             Строка(Выборка.Номенклатура));
				СтрокаЦены.Вставить("ХарактеристикаНоменклатуры", Строка(Выборка.ХарактеристикаНоменклатуры));
				СтрокаЦены.Вставить("Цена",                     Выборка.Цена);
				СтрокаЦены.Вставить("Валюта",                   Строка(Выборка.Валюта));
				СтрокаЦены.Вставить("ЕдиницаИзмерения",         Строка(Выборка.ЕдиницаИзмерения));
				СтрокаЦены.Вставить("Период",                   Формат(Выборка.Период, "ДФ=dd.MM.yyyy"));

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаЦены);
				ТестоваяЗаписьJSON.Закрыть();

				МассивЦен.Добавить(СтрокаЦены);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивЦен);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
