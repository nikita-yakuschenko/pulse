Функция GetContractors(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначНаим = "";
	Попытка
		ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name")));
	Исключение
	КонецПопытки;
	Если ЗначНаим = "" Тогда
		Попытка ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначИНН = "";
	Попытка
		ЗначИНН = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("inn")));
	Исключение
	КонецПопытки;
	Если ЗначИНН = "" Тогда
		Попытка ЗначИНН = СокрЛП(Строка(Запрос.ПараметрыURL["inn"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначПоставщик = "";
	Попытка
		ЗначПоставщик = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("supplier")));
	Исключение
	КонецПопытки;
	Если ЗначПоставщик = "" Тогда
		Попытка ЗначПоставщик = СокрЛП(Строка(Запрос.ПараметрыURL["supplier"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначПокупатель = "";
	Попытка
		ЗначПокупатель = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("buyer")));
	Исключение
	КонецПопытки;
	Если ЗначПокупатель = "" Тогда
		Попытка ЗначПокупатель = СокрЛП(Строка(Запрос.ПараметрыURL["buyer"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Флаги ---
	ФильтрПоставщик = Ложь;
	ФильтрПокупатель = Ложь;

	Если ВРег(ЗначПоставщик) = "TRUE" Или ЗначПоставщик = "1" Или ВРег(ЗначПоставщик) = "ДА" Тогда
		ФильтрПоставщик = Истина;
	КонецЕсли;

	Если ВРег(ЗначПокупатель) = "TRUE" Или ЗначПокупатель = "1" Или ВРег(ЗначПокупатель) = "ДА" Тогда
		ФильтрПокупатель = Истина;
	КонецЕсли;

	// --- Запрос ---
	МассивКонтрагентов = Новый Массив;
	МассивОшибок       = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Кт.Наименование          КАК Наименование,
		|	Кт.НаименованиеПолное    КАК НаименованиеПолное,
		|	Кт.ИНН                   КАК ИНН,
		|	Кт.КПП                   КАК КПП,
		|	Кт.ЮридическоеФизическоеЛицо КАК ЮрФизЛицо,
		|	Кт.ЭтоПоставщик          КАК ЭтоПоставщик,
		|	Кт.ЭтоПокупатель         КАК ЭтоПокупатель,
		|	Кт.Телефоны              КАК Телефоны,
		|	Кт.АдресЭлектроннойПочты КАК Email,
		|	Кт.Комментарий           КАК Комментарий
		|ИЗ
		|	Справочник.Контрагенты КАК Кт
		|ГДЕ
		|	Кт.ПометкаУдаления = ЛОЖЬ
		|	И Кт.ЭтоГруппа = ЛОЖЬ
		|	" + ?(ФильтрПоставщик, "И Кт.ЭтоПоставщик = ИСТИНА", "") + "
		|	" + ?(ФильтрПокупатель, "И Кт.ЭтоПокупатель = ИСТИНА", "") + "
		|УПОРЯДОЧИТЬ ПО
		|	Кт.Наименование";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначНаим <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНаим + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Наименование)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначИНН <> "" Тогда
					Если СтрНайти(Выборка.ИНН, ЗначИНН) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаКт = Новый Структура;
				СтрокаКт.Вставить("Наименование",       Выборка.Наименование);
				СтрокаКт.Вставить("НаименованиеПолное", Выборка.НаименованиеПолное);
				СтрокаКт.Вставить("ИНН",                Выборка.ИНН);
				СтрокаКт.Вставить("КПП",                Выборка.КПП);
				СтрокаКт.Вставить("ЮрФизЛицо",         Строка(Выборка.ЮрФизЛицо));
				СтрокаКт.Вставить("ЭтоПоставщик",       Выборка.ЭтоПоставщик);
				СтрокаКт.Вставить("ЭтоПокупатель",      Выборка.ЭтоПокупатель);
				СтрокаКт.Вставить("Телефоны",           Выборка.Телефоны);
				СтрокаКт.Вставить("Email",              Выборка.Email);
				СтрокаКт.Вставить("Комментарий",        Выборка.Комментарий);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаКт);
				ТестоваяЗаписьJSON.Закрыть();

				МассивКонтрагентов.Добавить(СтрокаКт);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивКонтрагентов);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
