Функция GetContracts(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначНаим = "";
	Попытка
		ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name")));
	Исключение
	КонецПопытки;
	Если ЗначНаим = "" Тогда
		Попытка ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКонтрагент = "";
	Попытка
		ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor")));
	Исключение
	КонецПопытки;
	Если ЗначКонтрагент = "" Тогда
		Попытка ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначВидДоговора = "";
	Попытка
		ЗначВидДоговора = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("kind")));
	Исключение
	КонецПопытки;
	Если ЗначВидДоговора = "" Тогда
		Попытка ЗначВидДоговора = СокрЛП(Строка(Запрос.ПараметрыURL["kind"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Запрос ---
	МассивДоговоров = Новый Массив;
	МассивОшибок    = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Дог.Наименование       КАК Наименование,
		|	Дог.Владелец           КАК Контрагент,
		|	Дог.Организация        КАК Организация,
		|	Дог.ВидДоговора        КАК ВидДоговора,
		|	Дог.Валюта             КАК Валюта,
		|	Дог.СуммаДоговора      КАК СуммаДоговора,
		|	Дог.ДатаНачала         КАК ДатаНачала,
		|	Дог.ДатаОкончания      КАК ДатаОкончания,
		|	Дог.Комментарий        КАК Комментарий
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК Дог
		|ГДЕ
		|	Дог.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	Дог.Владелец,
		|	Дог.Наименование";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначНаим <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНаим + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Наименование)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначКонтрагент <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначКонтрагент + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначВидДоговора <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначВидДоговора + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.ВидДоговора)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаДог = Новый Структура;
				СтрокаДог.Вставить("Наименование",   Выборка.Наименование);
				СтрокаДог.Вставить("Контрагент",     Строка(Выборка.Контрагент));
				СтрокаДог.Вставить("Организация",    Строка(Выборка.Организация));
				СтрокаДог.Вставить("ВидДоговора",    Строка(Выборка.ВидДоговора));
				СтрокаДог.Вставить("Валюта",         Строка(Выборка.Валюта));
				СтрокаДог.Вставить("СуммаДоговора",  Выборка.СуммаДоговора);
				СтрокаДог.Вставить("ДатаНачала",     ?(ЗначениеЗаполнено(Выборка.ДатаНачала),    Формат(Выборка.ДатаНачала,    "ДФ=dd.MM.yyyy"), ""));
				СтрокаДог.Вставить("ДатаОкончания",  ?(ЗначениеЗаполнено(Выборка.ДатаОкончания), Формат(Выборка.ДатаОкончания, "ДФ=dd.MM.yyyy"), ""));
				СтрокаДог.Вставить("Комментарий",    Выборка.Комментарий);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаДог);
				ТестоваяЗаписьJSON.Закрыть();

				МассивДоговоров.Добавить(СтрокаДог);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДоговоров);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
