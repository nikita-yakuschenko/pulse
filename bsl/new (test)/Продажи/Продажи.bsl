Функция GetSalesSummary(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДатаС = "";
	Попытка
		ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from")));
	Исключение
	КонецПопытки;
	Если ЗначДатаС = "" Тогда
		Попытка ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначДатаПо = "";
	Попытка
		ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to")));
	Исключение
	КонецПопытки;
	Если ЗначДатаПо = "" Тогда
		Попытка ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКонтрагент = "";
	Попытка
		ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor")));
	Исключение
	КонецПопытки;
	Если ЗначКонтрагент = "" Тогда
		Попытка ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначНоменклатура = "";
	Попытка
		ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("item")));
	Исключение
	КонецПопытки;
	Если ЗначНоменклатура = "" Тогда
		Попытка ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыURL["item"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначНомГруппа = "";
	Попытка
		ЗначНомГруппа = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("nomgroup")));
	Исключение
	КонецПопытки;
	Если ЗначНомГруппа = "" Тогда
		Попытка ЗначНомГруппа = СокрЛП(Строка(Запрос.ПараметрыURL["nomgroup"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор дат ---
	ДатаС    = НачалоГода(ТекущаяДата());
	ДатаПо   = КонецДня(ТекущаяДата());

	Если ЗначДатаС <> "" Тогда
		Попытка
			ЧастиС = СтрРазделить(ЗначДатаС, ".");
			Если ЧастиС.Количество() = 3 Тогда
				ДатаС = Дата(Число(ЧастиС[2]), Число(ЧастиС[1]), Число(ЧастиС[0]));
			Иначе
				ЧастиС = СтрРазделить(ЗначДатаС, "-");
				Если ЧастиС.Количество() = 3 Тогда
					Если СтрДлина(ЧастиС[0]) = 4 Тогда
						ДатаС = Дата(Число(ЧастиС[0]), Число(ЧастиС[1]), Число(ЧастиС[2]));
					Иначе
						ДатаС = Дата(Число(ЧастиС[2]), Число(ЧастиС[1]), Число(ЧастиС[0]));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Если ЗначДатаПо <> "" Тогда
		Попытка
			ЧастиПо = СтрРазделить(ЗначДатаПо, ".");
			Если ЧастиПо.Количество() = 3 Тогда
				ДатаПо = КонецДня(Дата(Число(ЧастиПо[2]), Число(ЧастиПо[1]), Число(ЧастиПо[0])));
			Иначе
				ЧастиПо = СтрРазделить(ЗначДатаПо, "-");
				Если ЧастиПо.Количество() = 3 Тогда
					Если СтрДлина(ЧастиПо[0]) = 4 Тогда
						ДатаПо = КонецДня(Дата(Число(ЧастиПо[0]), Число(ЧастиПо[1]), Число(ЧастиПо[2])));
					Иначе
						ДатаПо = КонецДня(Дата(Число(ЧастиПо[2]), Число(ЧастиПо[1]), Число(ЧастиПо[0])));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	// --- Запрос оборотов ---
	МассивПродаж = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Об.Контрагент                   КАК Контрагент,
		|	Об.Организация                  КАК Организация,
		|	Об.Номенклатура                 КАК Номенклатура,
		|	Об.ХарактеристикаНоменклатуры   КАК ХарактеристикаНоменклатуры,
		|	Об.НоменклатурнаяГруппа         КАК НоменклатурнаяГруппа,
		|	Об.КоличествоОборот             КАК Количество,
		|	Об.СуммаВыручкиОборот           КАК СуммаВыручки,
		|	Об.СуммаВыручкиБезНДСОборот     КАК СуммаВыручкиБезНДС,
		|	Об.СебестоимостьОборот          КАК Себестоимость
		|ИЗ
		|	РегистрНакопления.Продажи.Обороты(&ДатаС, &ДатаПо, Авто, ) КАК Об
		|УПОРЯДОЧИТЬ ПО
		|	Об.Организация,
		|	Об.Контрагент,
		|	Об.Номенклатура";

		Запрос1С.УстановитьПараметр("ДатаС",  ДатаС);
		Запрос1С.УстановитьПараметр("ДатаПо", ДатаПо);

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначКонтрагент <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначКонтрагент + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначНоменклатура <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНоменклатура + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Номенклатура)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначНомГруппа <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНомГруппа + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.НоменклатурнаяГруппа)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаПродаж = Новый Структура;
				СтрокаПродаж.Вставить("Контрагент",                  Строка(Выборка.Контрагент));
				СтрокаПродаж.Вставить("Организация",                 Строка(Выборка.Организация));
				СтрокаПродаж.Вставить("Номенклатура",                Строка(Выборка.Номенклатура));
				СтрокаПродаж.Вставить("ХарактеристикаНоменклатуры", Строка(Выборка.ХарактеристикаНоменклатуры));
				СтрокаПродаж.Вставить("НоменклатурнаяГруппа",       Строка(Выборка.НоменклатурнаяГруппа));
				СтрокаПродаж.Вставить("Количество",                  Выборка.Количество);
				СтрокаПродаж.Вставить("СуммаВыручки",               Выборка.СуммаВыручки);
				СтрокаПродаж.Вставить("СуммаВыручкиБезНДС",         Выборка.СуммаВыручкиБезНДС);
				СтрокаПродаж.Вставить("Себестоимость",               Выборка.Себестоимость);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаПродаж);
				ТестоваяЗаписьJSON.Закрыть();

				МассивПродаж.Добавить(СтрокаПродаж);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивПродаж);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
