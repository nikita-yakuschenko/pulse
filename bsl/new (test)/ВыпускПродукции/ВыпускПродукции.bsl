// HTTP-сервис. Выпуск продукции (Документ.ВыпускПродукции).
// Параметры: from, to, code, org, warehouse, subdivision, responsible, approved, full (при true — ТЧ Продукция + Материалы).

Функция GetProduction(Запрос) Экспорт
	МассивДокументов = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ДатаНачала = Дата(1, 1, 1);
		ДатаОкончания = Дата(1, 1, 1);
		ИспользоватьПериод = Ложь;
		ЗначFrom = "";
		Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFrom) Тогда Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки; КонецЕсли;
		ЗначTo = "";
		Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначTo) Тогда Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFrom) И ЗначениеЗаполнено(ЗначTo) Тогда
			Попытка
				Г1 = ""; М1 = ""; Д1 = "";
				ЧТ1 = СтрРазделить(ЗначFrom, ".", Ложь); ЧД1 = СтрРазделить(ЗначFrom, "-", Ложь);
				Если ЧТ1.Количество() = 3 Тогда Д1 = ЧТ1[0]; М1 = ЧТ1[1]; Г1 = ЧТ1[2];
				ИначеЕсли ЧД1.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД1[0])) = 4 Тогда Г1 = ЧД1[0]; М1 = ЧД1[1]; Д1 = ЧД1[2]; Иначе Д1 = ЧД1[0]; М1 = ЧД1[1]; Г1 = ЧД1[2]; КонецЕсли;
				КонецЕсли;
				Г2 = ""; М2 = ""; Д2 = "";
				ЧТ2 = СтрРазделить(ЗначTo, ".", Ложь); ЧД2 = СтрРазделить(ЗначTo, "-", Ложь);
				Если ЧТ2.Количество() = 3 Тогда Д2 = ЧТ2[0]; М2 = ЧТ2[1]; Г2 = ЧТ2[2];
				ИначеЕсли ЧД2.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД2[0])) = 4 Тогда Г2 = ЧД2[0]; М2 = ЧД2[1]; Д2 = ЧД2[2]; Иначе Д2 = ЧД2[0]; М2 = ЧД2[1]; Г2 = ЧД2[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г1) И ЗначениеЗаполнено(Г2) Тогда
					Пока СтрДлина(Г1) < 4 Цикл Г1 = "0" + Г1; КонецЦикла; Пока СтрДлина(М1) < 2 Цикл М1 = "0" + М1; КонецЦикла; Пока СтрДлина(Д1) < 2 Цикл Д1 = "0" + Д1; КонецЦикла;
					Пока СтрДлина(Г2) < 4 Цикл Г2 = "0" + Г2; КонецЦикла; Пока СтрДлина(М2) < 2 Цикл М2 = "0" + М2; КонецЦикла; Пока СтрДлина(Д2) < 2 Цикл Д2 = "0" + Д2; КонецЦикла;
					ДатаНачала = Дата(Г1 + М1 + Д1 + "000000");
					ДатаОкончания = КонецДня(Дата(Г2 + М2 + Д2 + "000000"));
					ИспользоватьПериод = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга from/to: " + ЗначFrom + " / " + ЗначTo);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрНомер = Ложь; НомерШаблон = "%";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрНомер = Истина; НомерШаблон = "%" + ЗначCode + "%"; КонецЕсли;

		ИспользоватьФильтрПроведен = Ложь; ПроведенФильтр = Ложь;
		ЗначApproved = "";
		Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("approved"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначApproved) Тогда Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыURL["approved"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначApproved) Тогда ИспользоватьФильтрПроведен = Истина; ПроведенФильтр = (ВРег(ЗначApproved) = "1" Или ВРег(ЗначApproved) = "TRUE" Или ВРег(ЗначApproved) = "ДА" Или ВРег(ЗначApproved) = "YES"); КонецЕсли;

		ИспользоватьФильтрОрганизация = Ложь; ШаблонОрганизация = "%";
		ЗначOrg = "";
		Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначOrg) Тогда Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначOrg) Тогда ИспользоватьФильтрОрганизация = Истина; ШаблонОрганизация = "%" + ЗначOrg + "%"; КонецЕсли;

		ИспользоватьФильтрСклад = Ложь; ШаблонСклад = "%";
		ЗначWarehouse = "";
		Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("warehouse"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначWarehouse) Тогда Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыURL["warehouse"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначWarehouse) Тогда ИспользоватьФильтрСклад = Истина; ШаблонСклад = "%" + ЗначWarehouse + "%"; КонецЕсли;

		ИспользоватьФильтрПодразделение = Ложь; ШаблонПодразделение = "%";
		ЗначSubdivision = "";
		Попытка ЗначSubdivision = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("subdivision"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSubdivision) Тогда Попытка ЗначSubdivision = СокрЛП(Строка(Запрос.ПараметрыURL["subdivision"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSubdivision) Тогда ИспользоватьФильтрПодразделение = Истина; ШаблонПодразделение = "%" + ЗначSubdivision + "%"; КонецЕсли;

		ИспользоватьФильтрОтветственный = Ложь; ШаблонОтветственный = "%";
		ЗначResponsible = "";
		Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("responsible"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначResponsible) Тогда Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыURL["responsible"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначResponsible) Тогда ИспользоватьФильтрОтветственный = Истина; ШаблонОтветственный = "%" + ЗначResponsible + "%"; КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	Д.Ссылка КАК Ссылка,
		|	Д.Номер КАК Номер,
		|	Д.Дата КАК Дата,
		|	ПРЕДСТАВЛЕНИЕ(Д.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(Д.Склад) КАК Склад,
		|	ПРЕДСТАВЛЕНИЕ(Д.Подразделение) КАК Подразделение,
		|	ПРЕДСТАВЛЕНИЕ(Д.Ответственный) КАК Ответственный,
		|	Д.Проведен КАК Проведен,
		|	Д.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ВыпускПродукции КАК Д
		|ГДЕ
		|	(НЕ &ИспользоватьПериод ИЛИ (Д.Дата >= &ДатаНачала И Д.Дата <= &ДатаОкончания))
		|	И (НЕ &ИспользоватьФильтрНомер ИЛИ Д.Номер ПОДОБНО &НомерШаблон)
		|	И (НЕ &ИспользоватьФильтрПроведен ИЛИ Д.Проведен = &ПроведенФильтр)
		|УПОРЯДОЧИТЬ ПО
		|	Д.Дата УБЫВ, Д.Номер УБЫВ";
		ЗапросБД.УстановитьПараметр("ИспользоватьПериод", ИспользоватьПериод);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
		ЗапросБД.УстановитьПараметр("НомерШаблон", НомерШаблон);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПроведен", ИспользоватьФильтрПроведен);
		ЗапросБД.УстановитьПараметр("ПроведенФильтр", ПроведенФильтр);

		ШаблонБСЛ_Организация    = СтрЗаменить(СтрЗаменить(ШаблонОрганизация, "%", "*"), "_", "?");
		ШаблонБСЛ_Склад          = СтрЗаменить(СтрЗаменить(ШаблонСклад, "%", "*"), "_", "?");
		ШаблонБСЛ_Подразделение  = СтрЗаменить(СтрЗаменить(ШаблонПодразделение, "%", "*"), "_", "?");
		ШаблонБСЛ_Ответственный  = СтрЗаменить(СтрЗаменить(ШаблонОтветственный, "%", "*"), "_", "?");

		Выборка = ЗапросБД.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если ИспользоватьФильтрОрганизация Тогда
				ПС = Сред(ШаблонБСЛ_Организация, 2, СтрДлина(ШаблонБСЛ_Организация) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрСклад Тогда
				ПС = Сред(ШаблонБСЛ_Склад, 2, СтрДлина(ШаблонБСЛ_Склад) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Склад)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрПодразделение Тогда
				ПС = Сред(ШаблонБСЛ_Подразделение, 2, СтрДлина(ШаблонБСЛ_Подразделение) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Подразделение)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрОтветственный Тогда
				ПС = Сред(ШаблонБСЛ_Ответственный, 2, СтрДлина(ШаблонБСЛ_Ответственный) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Ответственный)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;

			Д = Новый Структура;
			Д.Вставить("Номер", Выборка.Номер);
			Д.Вставить("Дата", Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
			Д.Вставить("Организация", ?(ЗначениеЗаполнено(Выборка.Организация), Строка(Выборка.Организация), "Не указана"));
			Д.Вставить("Склад", ?(ЗначениеЗаполнено(Выборка.Склад), Строка(Выборка.Склад), "Не указан"));
			Д.Вставить("Подразделение", ?(ЗначениеЗаполнено(Выборка.Подразделение), Строка(Выборка.Подразделение), "Не указано"));
			Д.Вставить("Ответственный", ?(ЗначениеЗаполнено(Выборка.Ответственный), Строка(Выборка.Ответственный), "Не указан"));
			Д.Вставить("Проведен", Выборка.Проведен);
			Д.Вставить("Комментарий", ?(ЗначениеЗаполнено(Выборка.Комментарий), Строка(Выборка.Комментарий), ""));

			Если ПолныйОтвет Тогда
				МассивПродукции = Новый Массив;
				Попытка
					ЗапросТЧ = Новый Запрос;
					ЗапросТЧ.Текст =
					"ВЫБРАТЬ
					|	ПРЕДСТАВЛЕНИЕ(П.Номенклатура) КАК Номенклатура,
					|	ПРЕДСТАВЛЕНИЕ(П.ХарактеристикаНоменклатуры) КАК ХарактеристикаНоменклатуры,
					|	П.Количество КАК Количество,
					|	ПРЕДСТАВЛЕНИЕ(П.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
					|	ПРЕДСТАВЛЕНИЕ(П.Спецификация) КАК Спецификация,
					|	ПРЕДСТАВЛЕНИЕ(П.Заказ) КАК Заказ,
					|	ПРЕДСТАВЛЕНИЕ(П.НоменклатурнаяГруппа) КАК НоменклатурнаяГруппа
					|ИЗ
					|	Документ.ВыпускПродукции.Продукция КАК П
					|ГДЕ П.Ссылка = &Ссылка
					|УПОРЯДОЧИТЬ ПО П.НомерСтроки";
					ЗапросТЧ.УстановитьПараметр("Ссылка", Выборка.Ссылка);
					ВыборкаТЧ = ЗапросТЧ.Выполнить().Выбрать();
					Пока ВыборкаТЧ.Следующий() Цикл
						Стр = Новый Структура;
						Стр.Вставить("Номенклатура", ?(ЗначениеЗаполнено(ВыборкаТЧ.Номенклатура), Строка(ВыборкаТЧ.Номенклатура), "Не указана"));
						Стр.Вставить("ХарактеристикаНоменклатуры", ?(ЗначениеЗаполнено(ВыборкаТЧ.ХарактеристикаНоменклатуры), Строка(ВыборкаТЧ.ХарактеристикаНоменклатуры), ""));
						Стр.Вставить("Количество", ?(ВыборкаТЧ.Количество = Неопределено, 0, ВыборкаТЧ.Количество));
						Стр.Вставить("ЕдиницаИзмерения", ?(ЗначениеЗаполнено(ВыборкаТЧ.ЕдиницаИзмерения), Строка(ВыборкаТЧ.ЕдиницаИзмерения), ""));
						Стр.Вставить("Спецификация", ?(ЗначениеЗаполнено(ВыборкаТЧ.Спецификация), Строка(ВыборкаТЧ.Спецификация), ""));
						Стр.Вставить("Заказ", ?(ЗначениеЗаполнено(ВыборкаТЧ.Заказ), Строка(ВыборкаТЧ.Заказ), ""));
						Стр.Вставить("НоменклатурнаяГруппа", ?(ЗначениеЗаполнено(ВыборкаТЧ.НоменклатурнаяГруппа), Строка(ВыборкаТЧ.НоменклатурнаяГруппа), ""));
						МассивПродукции.Добавить(Стр);
					КонецЦикла;
				Исключение
					МассивОшибок.Добавить("Выпуск №" + Выборка.Номер + ": ошибка ТЧ Продукция — " + ОписаниеОшибки());
				КонецПопытки;
				Д.Вставить("Продукция", МассивПродукции);
			Иначе
				КолПродукции = 0;
				Попытка
					ЗапросКол = Новый Запрос;
					ЗапросКол.Текст = "ВЫБРАТЬ КОЛИЧЕСТВО(*) КАК Кол ИЗ Документ.ВыпускПродукции.Продукция КАК П ГДЕ П.Ссылка = &Ссылка";
					ЗапросКол.УстановитьПараметр("Ссылка", Выборка.Ссылка);
					ТКол = ЗапросКол.Выполнить().Выгрузить();
					Если ТКол.Количество() > 0 Тогда КолПродукции = ТКол[0].Кол; КонецЕсли;
				Исключение КонецПопытки;
				ПродКратко = Новый Структура; ПродКратко.Вставить("Есть", КолПродукции > 0); ПродКратко.Вставить("Количество", КолПродукции);
				Д.Вставить("Продукция", ПродКратко);
			КонецЕсли;

			Попытка
				ТестJSON = Новый ЗаписьJSON; ТестJSON.УстановитьСтроку(); ЗаписатьJSON(ТестJSON, Д); ТестJSON.Закрыть();
				МассивДокументов.Добавить(Д);
			Исключение
				МассивОшибок.Добавить("Выпуск №" + Выборка.Номер + ": " + ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивДокументов);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		JSON = Новый ЗаписьJSON; JSON.УстановитьСтроку(); ЗаписатьJSON(JSON, ИтоговыйРезультат); JSONСтрока = JSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ДанныеОшибки = Новый Структура("error", ОписаниеОшибки());
		JSONОшибки = Новый ЗаписьJSON; JSONОшибки.УстановитьСтроку(); ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
