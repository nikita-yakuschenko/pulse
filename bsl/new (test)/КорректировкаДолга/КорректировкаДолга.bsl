Функция GetDebtAdjustments(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДатаС = "";
	Попытка
		ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from")));
	Исключение
	КонецПопытки;
	Если ЗначДатаС = "" Тогда
		Попытка ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначДатаПо = "";
	Попытка
		ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to")));
	Исключение
	КонецПопытки;
	Если ЗначДатаПо = "" Тогда
		Попытка ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКод = "";
	Попытка
		ЗначКод = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code")));
	Исключение
	КонецПопытки;
	Если ЗначКод = "" Тогда
		Попытка ЗначКод = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКонтрагент = "";
	Попытка
		ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor")));
	Исключение
	КонецПопытки;
	Если ЗначКонтрагент = "" Тогда
		Попытка ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначПроведен = "";
	Попытка
		ЗначПроведен = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("approved")));
	Исключение
	КонецПопытки;
	Если ЗначПроведен = "" Тогда
		Попытка ЗначПроведен = СокрЛП(Строка(Запрос.ПараметрыURL["approved"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор дат ---
	ДатаС  = '00010101';
	ДатаПо = '99991231235959';

	Если ЗначДатаС <> "" Тогда
		Попытка
			ЧастиС = СтрРазделить(ЗначДатаС, ".");
			Если ЧастиС.Количество() = 3 Тогда
				ДатаС = Дата(Число(ЧастиС[2]), Число(ЧастиС[1]), Число(ЧастиС[0]));
			Иначе
				ЧастиС = СтрРазделить(ЗначДатаС, "-");
				Если ЧастиС.Количество() = 3 Тогда
					Если СтрДлина(ЧастиС[0]) = 4 Тогда
						ДатаС = Дата(Число(ЧастиС[0]), Число(ЧастиС[1]), Число(ЧастиС[2]));
					Иначе
						ДатаС = Дата(Число(ЧастиС[2]), Число(ЧастиС[1]), Число(ЧастиС[0]));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Если ЗначДатаПо <> "" Тогда
		Попытка
			ЧастиПо = СтрРазделить(ЗначДатаПо, ".");
			Если ЧастиПо.Количество() = 3 Тогда
				ДатаПо = КонецДня(Дата(Число(ЧастиПо[2]), Число(ЧастиПо[1]), Число(ЧастиПо[0])));
			Иначе
				ЧастиПо = СтрРазделить(ЗначДатаПо, "-");
				Если ЧастиПо.Количество() = 3 Тогда
					Если СтрДлина(ЧастиПо[0]) = 4 Тогда
						ДатаПо = КонецДня(Дата(Число(ЧастиПо[0]), Число(ЧастиПо[1]), Число(ЧастиПо[2])));
					Иначе
						ДатаПо = КонецДня(Дата(Число(ЧастиПо[2]), Число(ЧастиПо[1]), Число(ЧастиПо[0])));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	ИспользоватьФильтрКод      = Ложь; ШаблонКод = "%";
	ИспользоватьФильтрПроведен = Ложь;

	Если ЗначКод <> "" Тогда
		ИспользоватьФильтрКод = Истина;
		ШаблонКод = "%" + ЗначКод + "%";
	КонецЕсли;
	Если ВРег(ЗначПроведен) = "TRUE" Или ЗначПроведен = "1" Или ВРег(ЗначПроведен) = "ДА" Тогда
		ИспользоватьФильтрПроведен = Истина;
	КонецЕсли;

	МассивДокументов = Новый Массив;
	МассивОшибок     = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Д.Номер              КАК Номер,
		|	Д.Дата               КАК Дата,
		|	Д.Организация        КАК Организация,
		|	Д.Контрагент         КАК Контрагент,
		|	Д.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	Д.КонтрагентКредитор КАК КонтрагентКредитор,
		|	Д.ДоговорКонтрагентаКредитора КАК ДоговорКредитора,
		|	Д.СуммаДокумента     КАК СуммаДокумента,
		|	Д.ВидОперации        КАК ВидОперации,
		|	Д.Проведен           КАК Проведен,
		|	Д.Комментарий        КАК Комментарий
		|ИЗ
		|	Документ.КорректировкаДолга КАК Д
		|ГДЕ
		|	Д.Дата МЕЖДУ &ДатаС И &ДатаПо
		|	" + ?(ИспользоватьФильтрКод,      "И Д.Номер ПОДОБНО &ШаблонКод", "") + "
		|	" + ?(ИспользоватьФильтрПроведен, "И Д.Проведен = ИСТИНА",        "") + "
		|УПОРЯДОЧИТЬ ПО Д.Дата УБЫВ";

		Запрос1С.УстановитьПараметр("ДатаС",  ДатаС);
		Запрос1С.УстановитьПараметр("ДатаПо", ДатаПо);
		Если ИспользоватьФильтрКод Тогда
			Запрос1С.УстановитьПараметр("ШаблонКод", ШаблонКод);
		КонецЕсли;

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначКонтрагент <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначКонтрагент + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;
				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;

				СтрокаДок = Новый Структура;
				СтрокаДок.Вставить("Номер",              Выборка.Номер);
				СтрокаДок.Вставить("Дата",               Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
				СтрокаДок.Вставить("Организация",        Строка(Выборка.Организация));
				СтрокаДок.Вставить("Контрагент",         Строка(Выборка.Контрагент));
				СтрокаДок.Вставить("ДоговорКонтрагента", Строка(Выборка.ДоговорКонтрагента));
				СтрокаДок.Вставить("КонтрагентКредитор", Строка(Выборка.КонтрагентКредитор));
				СтрокаДок.Вставить("ДоговорКредитора",   Строка(Выборка.ДоговорКредитора));
				СтрокаДок.Вставить("СуммаДокумента",     Выборка.СуммаДокумента);
				СтрокаДок.Вставить("ВидОперации",        Строка(Выборка.ВидОперации));
				СтрокаДок.Вставить("Проведен",           Выборка.Проведен);
				СтрокаДок.Вставить("Комментарий",        Выборка.Комментарий);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаДок);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДокументов.Добавить(СтрокаДок);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДокументов);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
