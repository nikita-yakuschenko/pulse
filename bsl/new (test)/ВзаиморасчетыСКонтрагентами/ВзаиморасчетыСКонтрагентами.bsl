Функция GetDebts(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДата = "";
	Попытка
		ЗначДата = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date")));
	Исключение
	КонецПопытки;
	Если ЗначДата = "" Тогда
		Попытка ЗначДата = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКонтрагент = "";
	Попытка
		ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor")));
	Исключение
	КонецПопытки;
	Если ЗначКонтрагент = "" Тогда
		Попытка ЗначКонтрагент = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначДоговор = "";
	Попытка
		ЗначДоговор = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contract")));
	Исключение
	КонецПопытки;
	Если ЗначДоговор = "" Тогда
		Попытка ЗначДоговор = СокрЛП(Строка(Запрос.ПараметрыURL["contract"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор даты среза ---
	ДатаСреза = ТекущаяДата();

	Если ЗначДата <> "" Тогда
		Попытка
			ЧастиД = СтрРазделить(ЗначДата, ".");
			Если ЧастиД.Количество() = 3 Тогда
				ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
			Иначе
				ЧастиД = СтрРазделить(ЗначДата, "-");
				Если ЧастиД.Количество() = 3 Тогда
					Если СтрДлина(ЧастиД[0]) = 4 Тогда
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[0]), Число(ЧастиД[1]), Число(ЧастиД[2])));
					Иначе
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	// --- Запрос остатков ---
	МассивДолгов = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Ост.Контрагент            КАК Контрагент,
		|	Ост.Организация           КАК Организация,
		|	Ост.ДоговорКонтрагента    КАК ДоговорКонтрагента,
		|	Ост.СуммаВзаиморасчетовОстаток КАК Сумма
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(&ДатаСреза, ) КАК Ост
		|УПОРЯДОЧИТЬ ПО
		|	Ост.Контрагент";

		Запрос1С.УстановитьПараметр("ДатаСреза", ДатаСреза);

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначКонтрагент <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначКонтрагент + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначДоговор <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначДоговор + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.ДоговорКонтрагента)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаДолга = Новый Структура;
				СтрокаДолга.Вставить("Контрагент",         Строка(Выборка.Контрагент));
				СтрокаДолга.Вставить("Организация",        Строка(Выборка.Организация));
				СтрокаДолга.Вставить("ДоговорКонтрагента", Строка(Выборка.ДоговорКонтрагента));
				СтрокаДолга.Вставить("Сумма",              Выборка.Сумма);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаДолга);
				ТестоваяЗаписьJSON.Закрыть();

				МассивДолгов.Добавить(СтрокаДолга);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДолгов);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
