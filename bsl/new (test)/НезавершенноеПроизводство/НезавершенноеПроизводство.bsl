Функция GetWIP(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДата = "";
	Попытка
		ЗначДата = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date")));
	Исключение
	КонецПопытки;
	Если ЗначДата = "" Тогда
		Попытка ЗначДата = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначПодразделение = "";
	Попытка
		ЗначПодразделение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("subdivision")));
	Исключение
	КонецПопытки;
	Если ЗначПодразделение = "" Тогда
		Попытка ЗначПодразделение = СокрЛП(Строка(Запрос.ПараметрыURL["subdivision"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначНоменклатура = "";
	Попытка
		ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("item")));
	Исключение
	КонецПопытки;
	Если ЗначНоменклатура = "" Тогда
		Попытка ЗначНоменклатура = СокрЛП(Строка(Запрос.ПараметрыURL["item"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор даты среза ---
	ДатаСреза = ТекущаяДата();

	Если ЗначДата <> "" Тогда
		Попытка
			ЧастиД = СтрРазделить(ЗначДата, ".");
			Если ЧастиД.Количество() = 3 Тогда
				ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
			Иначе
				ЧастиД = СтрРазделить(ЗначДата, "-");
				Если ЧастиД.Количество() = 3 Тогда
					Если СтрДлина(ЧастиД[0]) = 4 Тогда
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[0]), Число(ЧастиД[1]), Число(ЧастиД[2])));
					Иначе
						ДатаСреза = КонецДня(Дата(Число(ЧастиД[2]), Число(ЧастиД[1]), Число(ЧастиД[0])));
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	// --- Запрос ---
	МассивОстатков = Новый Массив;
	МассивОшибок   = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	Ост.Номенклатура                   КАК Номенклатура,
		|	Ост.ХарактеристикаНоменклатуры     КАК ХарактеристикаНоменклатуры,
		|	Ост.Организация                    КАК Организация,
		|	Ост.ПодразделениеОрганизации       КАК Подразделение,
		|	Ост.КоличествоОстаток              КАК Количество,
		|	Ост.СтоимостьОстаток               КАК Стоимость
		|ИЗ
		|	РегистрНакопления.НезавершенноеПроизводство.Остатки(&ДатаСреза, ) КАК Ост
		|УПОРЯДОЧИТЬ ПО
		|	Ост.Организация,
		|	Ост.Номенклатура";

		Запрос1С.УстановитьПараметр("ДатаСреза", ДатаСреза);

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				// --- Пост-фильтры ---
				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначПодразделение <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначПодразделение + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Подразделение)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				Если ЗначНоменклатура <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНоменклатура + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Номенклатура)), ВРег(ПС)) <= 0 Тогда
						Продолжить;
					КонецЕсли;
				КонецЕсли;

				// --- Формирование строки ---
				СтрокаОст = Новый Структура;
				СтрокаОст.Вставить("Номенклатура",                Строка(Выборка.Номенклатура));
				СтрокаОст.Вставить("ХарактеристикаНоменклатуры", Строка(Выборка.ХарактеристикаНоменклатуры));
				СтрокаОст.Вставить("Организация",                Строка(Выборка.Организация));
				СтрокаОст.Вставить("Подразделение",              Строка(Выборка.Подразделение));
				СтрокаОст.Вставить("Количество",                 Выборка.Количество);
				СтрокаОст.Вставить("Стоимость",                  Выборка.Стоимость);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, СтрокаОст);
				ТестоваяЗаписьJSON.Закрыть();

				МассивОстатков.Добавить(СтрокаОст);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	// --- Формирование ответа ---
	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивОстатков);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
