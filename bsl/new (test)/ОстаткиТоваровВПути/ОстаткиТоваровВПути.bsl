Функция GetGoodsInTransit(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДатаСреза = "";
	Попытка
		ЗначДатаСреза = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date")));
	Исключение
	КонецПопытки;
	Если ЗначДатаСреза = "" Тогда
		Попытка ЗначДатаСреза = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ДатаСреза = ТекущаяДата();

	Если ЗначДатаСреза <> "" Тогда
		Попытка
			Части = СтрРазделить(ЗначДатаСреза, ".");
			Если Частей(Части) = 3 Тогда
				ДатаСреза = КонецДня(Дата(Число(Части[2]), Число(Части[1]), Число(Части[0])));
			Иначе
				Части = СтрРазделить(ЗначДатаСреза, "-");
				ДатаСреза = КонецДня(?(Длина(Части[0]) = 4, Дата(Число(Части[0]), Число(Части[1]), Число(Части[2])), Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]))));
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.УстановитьПараметр("ДатаСреза", ДатаСреза);
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	О.Организация    КАК Организация,
		|	О.Контрагент     КАК Контрагент,
		|	О.Номенклатура   КАК Номенклатура,
		|	О.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		|	О.КоличествоОстаток КАК КоличествоОстаток,
		|	О.СуммаОстаток   КАК СуммаОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыОрганизацийВПути.Остатки(&ДатаСреза, ) КАК О
		|УПОРЯДОЧИТЬ ПО
		|	О.Организация, О.Контрагент, О.Номенклатура";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначОрг <> "" Тогда
					ПС = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ПС, 2, СтрДлина(ПС) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;
				Стр = Новый Структура;
				Стр.Вставить("Организация",                Строка(Выборка.Организация));
				Стр.Вставить("Контрагент",                 Строка(Выборка.Контрагент));
				Стр.Вставить("Номенклатура",               Строка(Выборка.Номенклатура));
				Стр.Вставить("ХарактеристикаНоменклатуры", Строка(Выборка.ХарактеристикаНоменклатуры));
				Стр.Вставить("КоличествоОстаток",          Выборка.КоличествоОстаток);
				Стр.Вставить("СуммаОстаток",               Выборка.СуммаОстаток);
				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Стр);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДанных.Добавить(Стр);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДанных);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
