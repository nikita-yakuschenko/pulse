Функция GetVATInvoicesOut(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДатаС = "";
	Попытка
		ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("datefrom")));
	Исключение
	КонецПопытки;
	Если ЗначДатаС = "" Тогда
		Попытка ЗначДатаС = СокрЛП(Строка(Запрос.ПараметрыURL["datefrom"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначДатаПо = "";
	Попытка
		ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("dateto")));
	Исключение
	КонецПопытки;
	Если ЗначДатаПо = "" Тогда
		Попытка ЗначДатаПо = СокрЛП(Строка(Запрос.ПараметрыURL["dateto"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначКонтр = "";
	Попытка
		ЗначКонтр = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("contractor")));
	Исключение
	КонецПопытки;
	Если ЗначКонтр = "" Тогда
		Попытка ЗначКонтр = СокрЛП(Строка(Запрос.ПараметрыURL["contractor"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор дат ---
	ДатаС  = НачалоМесяца(ТекущаяДата());
	ДатаПо = ТекущаяДата();

	Если ЗначДатаС <> "" Тогда
		Попытка
			Части = СтрРазделить(ЗначДатаС, ".");
			Если Частей(Части) = 3 Тогда
				ДатаС = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
			Иначе
				Части = СтрРазделить(ЗначДатаС, "-");
				Если Длина(Части[0]) = 4 Тогда
					ДатаС = Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
				Иначе
					ДатаС = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	Если ЗначДатаПо <> "" Тогда
		Попытка
			Части = СтрРазделить(ЗначДатаПо, ".");
			Если Частей(Части) = 3 Тогда
				ДатаПо = КонецДня(Дата(Число(Части[2]), Число(Части[1]), Число(Части[0])));
			Иначе
				Части = СтрРазделить(ЗначДатаПо, "-");
				Если Длина(Части[0]) = 4 Тогда
					ДатаПо = КонецДня(Дата(Число(Части[0]), Число(Части[1]), Число(Части[2])));
				Иначе
					ДатаПо = КонецДня(Дата(Число(Части[2]), Число(Части[1]), Число(Части[0])));
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.УстановитьПараметр("ДатаС",  ДатаС);
		Запрос1С.УстановитьПараметр("ДатаПо", ДатаПо);
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	СФ.Ссылка              КАК Ссылка,
		|	СФ.Дата                КАК Дата,
		|	СФ.Номер               КАК Номер,
		|	СФ.Организация         КАК Организация,
		|	СФ.Контрагент          КАК Контрагент,
		|	СФ.ДокументОснование   КАК ДокументОснование,
		|	СФ.СуммаДокумента      КАК СуммаДокумента,
		|	СФ.СуммаНДС            КАК СуммаНДС,
		|	СФ.Проведен            КАК Проведен
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СФ
		|ГДЕ
		|	СФ.Дата МЕЖДУ &ДатаС И &ДатаПо
		|	И СФ.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	СФ.Дата УБЫВ,
		|	СФ.Номер";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначКонтр <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначКонтр + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;

				Стр = Новый Структура;
				Стр.Вставить("Ссылка",            Строка(Выборка.Ссылка));
				Стр.Вставить("Дата",              Выборка.Дата);
				Стр.Вставить("Номер",             Выборка.Номер);
				Стр.Вставить("Организация",       Строка(Выборка.Организация));
				Стр.Вставить("Контрагент",        Строка(Выборка.Контрагент));
				Стр.Вставить("ДокументОснование", Строка(Выборка.ДокументОснование));
				Стр.Вставить("СуммаДокумента",    Выборка.СуммаДокумента);
				Стр.Вставить("СуммаНДС",          Выборка.СуммаНДС);
				Стр.Вставить("Проведен",          Выборка.Проведен);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Стр);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДанных.Добавить(Стр);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДанных);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
