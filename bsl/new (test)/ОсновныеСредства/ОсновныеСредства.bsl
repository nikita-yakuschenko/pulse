Функция GetFixedAssets(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначДата = "";
	Попытка
		ЗначДата = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date")));
	Исключение
	КонецПопытки;
	Если ЗначДата = "" Тогда
		Попытка ЗначДата = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначНаим = "";
	Попытка
		ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name")));
	Исключение
	КонецПопытки;
	Если ЗначНаим = "" Тогда
		Попытка ЗначНаим = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки;
	КонецЕсли;

	// --- Разбор даты среза ---
	ДатаСреза = ТекущаяДата();

	Если ЗначДата <> "" Тогда
		Попытка
			Части = СтрРазделить(ЗначДата, ".");
			Если Частей(Части) = 3 Тогда
				ДатаСреза = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
			Иначе
				Части = СтрРазделить(ЗначДата, "-");
				Если Длина(Части[0]) = 4 Тогда
					ДатаСреза = Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));
				Иначе
					ДатаСреза = Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;

	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.УстановитьПараметр("ДатаСреза", КонецДня(ДатаСреза));
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	ОС.Организация              КАК Организация,
		|	ОС.ОсновноеСредство         КАК ОсновноеСредство,
		|	ОС.ПодразделениеОрганизации КАК Подразделение,
		|	ОС.СтоимостьОстаток         КАК Стоимость,
		|	ОС.НакопленнаяАмортизацияОстаток КАК НакопленнаяАмортизация
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&ДатаСреза, &ДатаСреза, , , Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ОС)) КАК ОС
		|УПОРЯДОЧИТЬ ПО
		|	ОС.Организация,
		|	ОС.ОсновноеСредство";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначОрг <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;
				Если ЗначНаим <> "" Тогда
					ШаблонБСЛ = СтрЗаменить(СтрЗаменить("%" + ЗначНаим + "%", "%", "*"), "_", "?");
					ПС = Сред(ШаблонБСЛ, 2, СтрДлина(ШаблонБСЛ) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.ОсновноеСредство)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;

				Стр = Новый Структура;
				Стр.Вставить("Организация",          Строка(Выборка.Организация));
				Стр.Вставить("ОсновноеСредство",     Строка(Выборка.ОсновноеСредство));
				Стр.Вставить("Подразделение",         Строка(Выборка.Подразделение));
				Стр.Вставить("Стоимость",             Выборка.Стоимость);
				Стр.Вставить("НакопленнаяАмортизация", Выборка.НакопленнаяАмортизация);

				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Стр);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДанных.Добавить(Стр);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДанных);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
