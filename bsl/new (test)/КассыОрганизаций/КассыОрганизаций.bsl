Функция GetCashRegisters(Запрос) Экспорт

	// --- Чтение параметров ---
	ЗначПоиск = "";
	Попытка
		ЗначПоиск = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("search")));
	Исключение
	КонецПопытки;
	Если ЗначПоиск = "" Тогда
		Попытка ЗначПоиск = СокрЛП(Строка(Запрос.ПараметрыURL["search"])); Исключение КонецПопытки;
	КонецЕсли;

	ЗначОрг = "";
	Попытка
		ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org")));
	Исключение
	КонецПопытки;
	Если ЗначОрг = "" Тогда
		Попытка ЗначОрг = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки;
	КонецЕсли;

	МассивДанных = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		Запрос1С = Новый Запрос;
		Запрос1С.Текст =
		"ВЫБРАТЬ
		|	К.Ссылка       КАК Ссылка,
		|	К.Наименование КАК Наименование,
		|	К.Код          КАК Код,
		|	К.Организация  КАК Организация,
		|	К.Валюта       КАК Валюта
		|ИЗ
		|	Справочник.КассыОрганизаций КАК К
		|ГДЕ
		|	К.ПометкаУдаления = ЛОЖЬ
		|УПОРЯДОЧИТЬ ПО
		|	К.Наименование";

		Выборка = Запрос1С.Выполнить().Выбрать();

		Пока Выборка.Следующий() Цикл
			Попытка
				Если ЗначПоиск <> "" Тогда
					ПС = СтрЗаменить(СтрЗаменить("%" + ЗначПоиск + "%", "%", "*"), "_", "?");
					ПС = Сред(ПС, 2, СтрДлина(ПС) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Наименование)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;
				Если ЗначОрг <> "" Тогда
					ПС = СтрЗаменить(СтрЗаменить("%" + ЗначОрг + "%", "%", "*"), "_", "?");
					ПС = Сред(ПС, 2, СтрДлина(ПС) - 2);
					Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПС)) <= 0 Тогда Продолжить; КонецЕсли;
				КонецЕсли;
				Стр = Новый Структура;
				Стр.Вставить("Ссылка",       Строка(Выборка.Ссылка));
				Стр.Вставить("Наименование", Строка(Выборка.Наименование));
				Стр.Вставить("Код",          Строка(Выборка.Код));
				Стр.Вставить("Организация",  Строка(Выборка.Организация));
				Стр.Вставить("Валюта",       Строка(Выборка.Валюта));
				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, Стр);
				ТестоваяЗаписьJSON.Закрыть();
				МассивДанных.Добавить(Стр);
			Исключение
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	Исключение
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		ОшибкаСтруктура = Новый Структура("error", ОписаниеОшибки());
		ЗаписьJSON = Новый ЗаписьJSON; ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ОшибкаСтруктура);
		Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
		Возврат Ответ;
	КонецПопытки;

	ИтоговыйРезультат = Новый Структура;
	ИтоговыйРезультат.Вставить("data",   МассивДанных);
	ИтоговыйРезультат.Вставить("errors", МассивОшибок);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	НастройкиJSON = Новый НастройкиСериализацииJSON;
	НастройкиJSON.ФорматДатыJSON = ФорматДатыJSON.ISO;
	ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат, НастройкиJSON);
	ТелоОтвета = ЗаписьJSON.Закрыть();

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции
