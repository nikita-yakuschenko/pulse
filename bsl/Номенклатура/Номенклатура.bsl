// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Номенклатура (Справочник.Номенклатура) — элементы (не группы), без помеченных на удаление. В JSON: data — дерево; errors — массив ошибок.
// Параметры: code, name, group, type, ngroup, article, supplier, service. В name слэш в query: _slash_.

Функция GetMaterials(Запрос) Экспорт
	МассивОшибок = Новый Массив;

	Попытка
		// Фильтр по коду.
		ИспользоватьФильтрКод = Ложь; ШаблонКод = "%";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрКод = Истина; ШаблонКод = "%" + ЗначCode + "%"; КонецЕсли;

		// Фильтр по наименованию.
		ИспользоватьФильтрНаименование = Ложь; ШаблонНаименование = "%";
		ЗначName = "";
		Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначName) Тогда Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки; КонецЕсли;
		ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
		Если ЗначениеЗаполнено(ЗначName) Тогда ИспользоватьФильтрНаименование = Истина; ШаблонНаименование = "%" + ЗначName + "%"; КонецЕсли;

		// Фильтр по родительской группе (подстрока в наименовании непосредственного родителя).
		ИспользоватьФильтрГруппа = Ложь; ШаблонГруппа = "%";
		ЗначGroup = "";
		Попытка ЗначGroup = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("group"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначGroup) Тогда Попытка ЗначGroup = СокрЛП(Строка(Запрос.ПараметрыURL["group"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначGroup) Тогда ИспользоватьФильтрГруппа = Истина; ШаблонГруппа = "%" + ЗначGroup + "%"; КонецЕсли;

		// Фильтр по виду номенклатуры.
		ИспользоватьФильтрТип = Ложь; ШаблонТип = "%";
		ЗначType = "";
		Попытка ЗначType = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("type"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначType) Тогда Попытка ЗначType = СокрЛП(Строка(Запрос.ПараметрыURL["type"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначType) Тогда ИспользоватьФильтрТип = Истина; ШаблонТип = "%" + ЗначType + "%"; КонецЕсли;

		// Фильтр по номенклатурной группе.
		ИспользоватьФильтрНомГруппа = Ложь; ШаблонНомГруппа = "%";
		ЗначNGroup = "";
		Попытка ЗначNGroup = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("ngroup"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначNGroup) Тогда Попытка ЗначNGroup = СокрЛП(Строка(Запрос.ПараметрыURL["ngroup"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначNGroup) Тогда ИспользоватьФильтрНомГруппа = Истина; ШаблонНомГруппа = "%" + ЗначNGroup + "%"; КонецЕсли;

		// Фильтр по артикулу.
		ИспользоватьФильтрАртикул = Ложь; ШаблонАртикул = "%";
		ЗначArticle = "";
		Попытка ЗначArticle = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("article"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначArticle) Тогда Попытка ЗначArticle = СокрЛП(Строка(Запрос.ПараметрыURL["article"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначArticle) Тогда ИспользоватьФильтрАртикул = Истина; ШаблонАртикул = "%" + ЗначArticle + "%"; КонецЕсли;

		// Фильтр по основному поставщику (подстрока в наименовании).
		ИспользоватьФильтрПоставщик = Ложь; ШаблонПоставщик = "%";
		ЗначSupplier = "";
		Попытка ЗначSupplier = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("supplier"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSupplier) Тогда Попытка ЗначSupplier = СокрЛП(Строка(Запрос.ПараметрыURL["supplier"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSupplier) Тогда ИспользоватьФильтрПоставщик = Истина; ШаблонПоставщик = "%" + ЗначSupplier + "%"; КонецЕсли;

		// Фильтр по признаку «Услуга» (true/false).
		ИспользоватьФильтрУслуга = Ложь; ФильтрУслуга = Ложь;
		ЗначService = "";
		Попытка ЗначService = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("service"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначService) Тогда Попытка ЗначService = СокрЛП(Строка(Запрос.ПараметрыURL["service"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначService) Тогда ИспользоватьФильтрУслуга = Истина; Если ВРег(ЗначService) = "TRUE" ИЛИ ЗначService = "1" ИЛИ ВРег(ЗначService) = "ДА" Тогда ФильтрУслуга = Истина; Иначе ФильтрУслуга = Ложь; КонецЕсли; КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Код КАК Код,
		|	Номенклатура.Наименование КАК Наименование,
		|	Номенклатура.Артикул КАК Артикул,
		|	Номенклатура.БазоваяЕдиницаИзмерения.Наименование КАК ЕдиницаИзмерения,
		|	Номенклатура.ВидНоменклатуры.Наименование КАК ВидНоменклатуры,
		|	Номенклатура.НоменклатурнаяГруппа.Наименование КАК НоменклатурнаяГруппа,
		|	Номенклатура.ОсновнойПоставщик.Наименование КАК ОсновнойПоставщик,
		|	Номенклатура.Услуга КАК Услуга,
		|	Номенклатура.Родитель КАК Родитель
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ПометкаУдаления = ЛОЖЬ
		|	И Номенклатура.ЭтоГруппа = ЛОЖЬ
		|	И (НЕ &ИспользоватьФильтрКод ИЛИ Номенклатура.Код ПОДОБНО &ШаблонКод)
		|	И (НЕ &ИспользоватьФильтрНаименование ИЛИ Номенклатура.Наименование ПОДОБНО &ШаблонНаименование)
		|	И (НЕ &ИспользоватьФильтрГруппа ИЛИ Номенклатура.Родитель.Наименование ПОДОБНО &ШаблонГруппа)
		|	И (НЕ &ИспользоватьФильтрТип ИЛИ Номенклатура.ВидНоменклатуры.Наименование ПОДОБНО &ШаблонТип)
		|	И (НЕ &ИспользоватьФильтрНомГруппа ИЛИ Номенклатура.НоменклатурнаяГруппа.Наименование ПОДОБНО &ШаблонНомГруппа)
		|	И (НЕ &ИспользоватьФильтрАртикул ИЛИ Номенклатура.Артикул ПОДОБНО &ШаблонАртикул)
		|	И (НЕ &ИспользоватьФильтрПоставщик ИЛИ Номенклатура.ОсновнойПоставщик.Наименование ПОДОБНО &ШаблонПоставщик)
		|	И (НЕ &ИспользоватьФильтрУслуга ИЛИ Номенклатура.Услуга = &ФильтрУслуга)
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура.Наименование";
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрКод", ИспользоватьФильтрКод);
		ЗапросБД.УстановитьПараметр("ШаблонКод", ШаблонКод);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНаименование", ИспользоватьФильтрНаименование);
		ЗапросБД.УстановитьПараметр("ШаблонНаименование", ШаблонНаименование);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрГруппа", ИспользоватьФильтрГруппа);
		ЗапросБД.УстановитьПараметр("ШаблонГруппа", ШаблонГруппа);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрТип", ИспользоватьФильтрТип);
		ЗапросБД.УстановитьПараметр("ШаблонТип", ШаблонТип);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомГруппа", ИспользоватьФильтрНомГруппа);
		ЗапросБД.УстановитьПараметр("ШаблонНомГруппа", ШаблонНомГруппа);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрАртикул", ИспользоватьФильтрАртикул);
		ЗапросБД.УстановитьПараметр("ШаблонАртикул", ШаблонАртикул);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПоставщик", ИспользоватьФильтрПоставщик);
		ЗапросБД.УстановитьПараметр("ШаблонПоставщик", ШаблонПоставщик);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрУслуга", ИспользоватьФильтрУслуга);
		ЗапросБД.УстановитьПараметр("ФильтрУслуга", ФильтрУслуга);

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		ГруппыПоКоду = Новый Соответствие;
		КорневыеУзлы = Новый Массив;

		Пока Выборка.Следующий() Цикл
			ЦепочкаРодителей = Новый Массив;
			ТекущийРодитель = Выборка.Родитель;
			Пока ЗначениеЗаполнено(ТекущийРодитель) Цикл
				ЦепочкаРодителей.Вставить(0, ТекущийРодитель);
				ТекущийРодитель = ТекущийРодитель.Родитель;
			КонецЦикла;

			ТекущийМассивДетей = КорневыеУзлы;
			Для Каждого ЭлементЦепочки Из ЦепочкаРодителей Цикл
				КодГруппы = СокрЛП(Строка(ЭлементЦепочки.Код));
				УзелГруппы = ГруппыПоКоду.Получить(КодГруппы);
				Если УзелГруппы = Неопределено Тогда
					УзелГруппы = Новый Структура;
					УзелГруппы.Вставить("Код", КодГруппы);
					УзелГруппы.Вставить("Наименование", СокрЛП(Строка(ЭлементЦепочки.Наименование)));
					УзелГруппы.Вставить("ЭтоГруппа", Истина);
					УзелГруппы.Вставить("Дети", Новый Массив);
					ГруппыПоКоду.Вставить(КодГруппы, УзелГруппы);
					ТекущийМассивДетей.Добавить(УзелГруппы);
				КонецЕсли;
				ТекущийМассивДетей = УзелГруппы.Дети;
			КонецЦикла;

			Материал = Новый Структура;
			Материал.Вставить("Код", СокрЛП(Строка(Выборка.Код)));
			Материал.Вставить("Наименование", СокрЛП(Строка(Выборка.Наименование)));
			Материал.Вставить("Артикул", ?(ЗначениеЗаполнено(Выборка.Артикул), СокрЛП(Строка(Выборка.Артикул)), ""));
			Материал.Вставить("ЭтоГруппа", Ложь);
			Материал.Вставить("Услуга", Выборка.Услуга);
			Материал.Вставить("ЕдиницаИзмерения", СокрЛП(Строка(Выборка.ЕдиницаИзмерения)));
			Материал.Вставить("ВидНоменклатуры", СокрЛП(Строка(Выборка.ВидНоменклатуры)));
			Материал.Вставить("НоменклатурнаяГруппа", СокрЛП(Строка(Выборка.НоменклатурнаяГруппа)));
			Материал.Вставить("ОсновнойПоставщик", ?(ЗначениеЗаполнено(Выборка.ОсновнойПоставщик), СокрЛП(Строка(Выборка.ОсновнойПоставщик)), ""));
			ТекущийМассивДетей.Добавить(Материал);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", КорневыеУзлы);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
