				ЗаказПоставщику.Вставить("Вложения", ВложенияКратко);
			КонецЕсли;

			Попытка
				ТестоваяЗаписьJSON = Новый ЗаписьJSON;
				ТестоваяЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ТестоваяЗаписьJSON, ЗаказПоставщику);
