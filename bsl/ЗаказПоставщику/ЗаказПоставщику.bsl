						МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": не удалось прочитать вложение """ + ВыборкаХДИ.ИмяФайла + """ — " + ОписаниеОшибки());
					КонецПопытки;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": ошибка запроса вложений — " + ОписаниеОшибки());
			КонецПопытки;
			ЗаказПоставщику.Вставить("Вложения", МассивВложений);

			Иначе
			// Облегчённый режим: только наличие и количество связей и вложений.
				КоличествоПоступлений = 0;
				КоличествоЗакрытий = 0;
				КоличествоЗаявок = 0;
				КоличествоВложений = 0;
				ДобавленныеПоступления = Новый Соответствие;
