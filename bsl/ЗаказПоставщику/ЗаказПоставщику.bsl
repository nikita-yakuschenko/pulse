				Попытка
					ЗапросПоступ = Новый Запрос;
					ЗапросПоступ.Текст = "ВЫБРАТЬ ПТУ.Номер КАК Номер, ПТУ.Дата КАК Дата ИЗ Документ.ПоступлениеТоваровУслуг КАК ПТУ ГДЕ ПТУ.Сделка = &ЗП ОБЪЕДИНИТЬ ВСЕ ВЫБРАТЬ ПТУ2.Номер, ПТУ2.Дата ИЗ Документ.ПоступлениеТоваровУслуг КАК ПТУ2 ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ТЧ ПО ПТУ2.Ссылка = ТЧ.Ссылка И ТЧ.ЗаказПоставщику = &ЗП";
					ЗапросПоступ.УстановитьПараметр("ЗП", Выборка.Ссылка);
					РезПоступ = ЗапросПоступ.Выполнить();
					ВыборкаПоступ = РезПоступ.Выбрать();
					Пока ВыборкаПоступ.Следующий() Цикл
						КлючНомерДата = Строка(ВыборкаПоступ.Номер) + "|" + ?(ЗначениеЗаполнено(ВыборкаПоступ.Дата), Формат(ВыборкаПоступ.Дата, "ДФ=yyyyMMdd"), "");
						Если ДобавленныеПоступления.Получить(КлючНомерДата) = Неопределено Тогда ДобавленныеПоступления.Вставить(КлючНомерДата, Истина); КоличествоПоступлений = КоличествоПоступлений + 1; КонецЕсли;
					КонецЦикла;
				Исключение КонецПопытки;
				Попытка
					ЗапросЗакр = Новый Запрос;
					ЗапросЗакр.Текст = "ВЫБРАТЬ Закр.Ссылка КАК Ссылка ИЗ Документ.ЗакрытиеЗаказовПоставщикам КАК Закр ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗакрытиеЗаказовПоставщикам.Заказы КАК ЗТЧ ПО Закр.Ссылка = ЗТЧ.Ссылка И ЗТЧ.ЗаказПоставщику = &ЗП";
					ЗапросЗакр.УстановитьПараметр("ЗП", Выборка.Ссылка);
					РезЗакр = ЗапросЗакр.Выполнить();
					КоличествоЗакрытий = РезЗакр.Выгрузить().Количество();
				Исключение КонецПопытки;
				Попытка
					ЗапросЗаяв = Новый Запрос;
					ЗапросЗаяв.Текст = "ВЫБРАТЬ ЗР.Номер КАК Номер, ЗР.ДатаРасхода КАК Дата ИЗ Документ.ЗаявкаНаРасходованиеСредств КАК ЗР ГДЕ ЗР.ДокументОснование = &ЗП ОБЪЕДИНИТЬ ВСЕ ВЫБРАТЬ ЗР2.Номер, ЗР2.ДатаРасхода КАК Дата ИЗ Документ.ЗаявкаНаРасходованиеСредств КАК ЗР2 ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеСредств.РасшифровкаПлатежа КАК РП ПО ЗР2.Ссылка = РП.Ссылка И РП.Сделка = &ЗП";
					ЗапросЗаяв.УстановитьПараметр("ЗП", Выборка.Ссылка);
					РезЗаяв = ЗапросЗаяв.Выполнить();
					ВыборкаЗаяв = РезЗаяв.Выбрать();
