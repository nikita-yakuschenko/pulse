						КлючНомерДата = Строка(ВыборкаЗаяв.Номер) + "|" + ?(ЗначениеЗаполнено(ВыборкаЗаяв.Дата), Формат(ВыборкаЗаяв.Дата, "ДФ=yyyyMMdd"), "");
						Если ДобавленныеЗаявки.Получить(КлючНомерДата) = Неопределено Тогда ДобавленныеЗаявки.Вставить(КлючНомерДата, Истина); КоличествоЗаявок = КоличествоЗаявок + 1; КонецЕсли;
					КонецЦикла;
				Исключение КонецПопытки;
				Попытка
					ЗапросХДИ = Новый Запрос;
