// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Заказы поставщикам с вложениями и связанными документами: ПоступлениеТоваровУслуг, ЗакрытиеЗаказовПоставщикам, ЗаявкаНаРасходованиеСредств.
// В JSON у каждого заказа: обычные поля, затем «СвязанныеДокументы» (Поступления, ЗакрытияЗаказов, ЗаявкаНаРасходованиеСредств), затем «Вложения».
// Параметры: from, to; code; date; supplier, org, warehouse, responsible, comment; summ; approved; full (при true — полный ответ: ТЧ Товары, связи, вложения; иначе — сводки по связям и вложениям). По умолчанию — базовый набор полей (Номер, Дата, Контрагент, Организация, Склад, Ответственный, СуммаДокумента, Проведен, Комментарий, ДатаОплаты, ДатаПоступления).

Функция GetSOrders(Запрос) Экспорт
	МассивЗаказов = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ДатаНачала = Дата(1, 1, 1);
		ДатаОкончания = Дата(1, 1, 1);
		ИспользоватьПериод = Ложь;

		ЗначFrom = "";
		Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("from"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFrom) Тогда Попытка ЗначFrom = СокрЛП(Строка(Запрос.ПараметрыURL["from"])); Исключение КонецПопытки; КонецЕсли;
		ЗначTo = "";
		Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("to"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначTo) Тогда Попытка ЗначTo = СокрЛП(Строка(Запрос.ПараметрыURL["to"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFrom) И ЗначениеЗаполнено(ЗначTo) Тогда
			Попытка
				Г1 = ""; М1 = ""; Д1 = "";
				ЧТ1 = СтрРазделить(ЗначFrom, ".", Ложь); ЧД1 = СтрРазделить(ЗначFrom, "-", Ложь);
				Если ЧТ1.Количество() = 3 Тогда Д1 = ЧТ1[0]; М1 = ЧТ1[1]; Г1 = ЧТ1[2];
				ИначеЕсли ЧД1.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД1[0])) = 4 Тогда Г1 = ЧД1[0]; М1 = ЧД1[1]; Д1 = ЧД1[2]; Иначе Д1 = ЧД1[0]; М1 = ЧД1[1]; Г1 = ЧД1[2]; КонецЕсли;
				КонецЕсли;
				Г2 = ""; М2 = ""; Д2 = "";
				ЧТ2 = СтрРазделить(ЗначTo, ".", Ложь); ЧД2 = СтрРазделить(ЗначTo, "-", Ложь);
				Если ЧТ2.Количество() = 3 Тогда Д2 = ЧТ2[0]; М2 = ЧТ2[1]; Г2 = ЧТ2[2];
				ИначеЕсли ЧД2.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧД2[0])) = 4 Тогда Г2 = ЧД2[0]; М2 = ЧД2[1]; Д2 = ЧД2[2]; Иначе Д2 = ЧД2[0]; М2 = ЧД2[1]; Г2 = ЧД2[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г1) И ЗначениеЗаполнено(Г2) Тогда
					Пока СтрДлина(Г1) < 4 Цикл Г1 = "0" + Г1; КонецЦикла; Пока СтрДлина(М1) < 2 Цикл М1 = "0" + М1; КонецЦикла; Пока СтрДлина(Д1) < 2 Цикл Д1 = "0" + Д1; КонецЦикла;
					Пока СтрДлина(Г2) < 4 Цикл Г2 = "0" + Г2; КонецЦикла; Пока СтрДлина(М2) < 2 Цикл М2 = "0" + М2; КонецЦикла; Пока СтрДлина(Д2) < 2 Цикл Д2 = "0" + Д2; КонецЦикла;
					ДатаНачала = Дата(Г1 + М1 + Д1 + "000000");
					ДатаОкончания = КонецДня(Дата(Г2 + М2 + Д2 + "000000"));
					ИспользоватьПериод = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга from/to: " + ЗначFrom + " / " + ЗначTo);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрНомер = Ложь;
		НомерШаблон = "";
		ЗначCode = "";
		ЗначCode = "";
		Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("code"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначCode) Тогда Попытка ЗначCode = СокрЛП(Строка(Запрос.ПараметрыURL["code"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначCode) Тогда ИспользоватьФильтрНомер = Истина; НомерШаблон = "%" + ЗначCode + "%"; Иначе НомерШаблон = "%"; КонецЕсли;

		ДатаФильтр = Дата(1, 1, 1);
		ДатаФильтрКонец = Дата(1, 1, 1);
		ИспользоватьФильтрДата = Ложь;
		ЗначDate = "";
		Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("date"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначDate) Тогда Попытка ЗначDate = СокрЛП(Строка(Запрос.ПараметрыURL["date"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначDate) Тогда
			Попытка
				Г = ""; М = ""; Д = "";
				ЧастиТочка = СтрРазделить(ЗначDate, ".", Ложь);
				ЧастиДефис = СтрРазделить(ЗначDate, "-", Ложь);
				Если ЧастиТочка.Количество() = 3 Тогда Д = ЧастиТочка[0]; М = ЧастиТочка[1]; Г = ЧастиТочка[2];
				ИначеЕсли ЧастиДефис.Количество() = 3 Тогда
					Если СтрДлина(СокрЛП(ЧастиДефис[0])) = 4 Тогда Г = ЧастиДефис[0]; М = ЧастиДефис[1]; Д = ЧастиДефис[2]; Иначе Д = ЧастиДефис[0]; М = ЧастиДефис[1]; Г = ЧастиДефис[2]; КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Г) Тогда
					Пока СтрДлина(Г) < 4 Цикл Г = "0" + Г; КонецЦикла;
					Пока СтрДлина(М) < 2 Цикл М = "0" + М; КонецЦикла;
					Пока СтрДлина(Д) < 2 Цикл Д = "0" + Д; КонецЦикла;
					ДатаФильтр = Дата(Г + М + Д + "000000");
					ДатаФильтрКонец = КонецДня(ДатаФильтр);
					ИспользоватьФильтрДата = Истина;
				Иначе
					МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
				КонецЕсли;
			Исключение
				МассивОшибок.Добавить("Ошибка парсинга date: " + ЗначDate);
			КонецПопытки;
		КонецЕсли;

		ИспользоватьФильтрКонтрагент = Ложь;
		ШаблонКонтрагент = "";
		ЗначSupplier = "";
		ЗначSupplier = "";
		Попытка ЗначSupplier = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("supplier"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSupplier) Тогда Попытка ЗначSupplier = СокрЛП(Строка(Запрос.ПараметрыURL["supplier"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSupplier) Тогда ИспользоватьФильтрКонтрагент = Истина; ШаблонКонтрагент = "%" + ЗначSupplier + "%"; Иначе ШаблонКонтрагент = "%"; КонецЕсли;

		ИспользоватьФильтрОрганизация = Ложь;
		ШаблонОрганизация = "";
		ЗначOrg = "";
		ЗначOrg = "";
		Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("org"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначOrg) Тогда Попытка ЗначOrg = СокрЛП(Строка(Запрос.ПараметрыURL["org"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначOrg) Тогда ИспользоватьФильтрОрганизация = Истина; ШаблонОрганизация = "%" + ЗначOrg + "%"; Иначе ШаблонОрганизация = "%"; КонецЕсли;

		ИспользоватьФильтрСклад = Ложь;
		ШаблонСклад = "";
		ЗначWarehouse = "";
		ЗначWarehouse = "";
		Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("warehouse"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначWarehouse) Тогда Попытка ЗначWarehouse = СокрЛП(Строка(Запрос.ПараметрыURL["warehouse"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначWarehouse) Тогда ИспользоватьФильтрСклад = Истина; ШаблонСклад = "%" + ЗначWarehouse + "%"; Иначе ШаблонСклад = "%"; КонецЕсли;

		ИспользоватьФильтрОтветственный = Ложь;
		ШаблонОтветственный = "";
		ЗначResponsible = "";
		ЗначResponsible = "";
		Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("responsible"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначResponsible) Тогда Попытка ЗначResponsible = СокрЛП(Строка(Запрос.ПараметрыURL["responsible"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначResponsible) Тогда ИспользоватьФильтрОтветственный = Истина; ШаблонОтветственный = "%" + ЗначResponsible + "%"; Иначе ШаблонОтветственный = "%"; КонецЕсли;

		ИспользоватьФильтрСумма = Ложь;
		СуммаФильтр = 0;
		ЗначSumm = "";
		ЗначSumm = "";
		Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("summ"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначSumm) Тогда Попытка ЗначSumm = СокрЛП(Строка(Запрос.ПараметрыURL["summ"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначSumm) Тогда Попытка СуммаФильтр = Число(ЗначSumm); ИспользоватьФильтрСумма = Истина; Исключение КонецПопытки; КонецЕсли;

		ИспользоватьФильтрПроведен = Ложь;
		ПроведенФильтр = Ложь;
		ЗначApproved = "";
		ЗначApproved = "";
		Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("approved"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначApproved) Тогда Попытка ЗначApproved = СокрЛП(Строка(Запрос.ПараметрыURL["approved"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначApproved) Тогда ИспользоватьФильтрПроведен = Истина; ПроведенФильтр = (ВРег(ЗначApproved) = "1" Или ВРег(ЗначApproved) = "TRUE" Или ВРег(ЗначApproved) = "ДА" Или ВРег(ЗначApproved) = "YES"); КонецЕсли;

		ИспользоватьФильтрКомментарий = Ложь;
		ШаблонКомментарий = "";
		ЗначComment = "";
		ЗначComment = "";
		Попытка ЗначComment = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("comment"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначComment) Тогда Попытка ЗначComment = СокрЛП(Строка(Запрос.ПараметрыURL["comment"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначComment) Тогда ИспользоватьФильтрКомментарий = Истина; ШаблонКомментарий = "%" + ЗначComment + "%"; Иначе ШаблонКомментарий = "%"; КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	ЗП.Ссылка КАК Ссылка,
		|	ЗП.Номер КАК Номер,
		|	ЗП.Дата КАК Дата,
		|	ЗП.ДатаОплаты КАК ДатаОплаты,
		|	ЗП.ДатаПоступления КАК ДатаПоступления,
		|	ПРЕДСТАВЛЕНИЕ(ЗП.Контрагент) КАК Контрагент,
		|	ПРЕДСТАВЛЕНИЕ(ЗП.Организация) КАК Организация,
		|	ПРЕДСТАВЛЕНИЕ(ЗП.Склад) КАК Склад,
		|	ПРЕДСТАВЛЕНИЕ(ЗП.Ответственный) КАК Ответственный,
		|	ЗП.СуммаДокумента КАК СуммаДокумента,
		|	ЗП.Проведен КАК Проведен,
		|	ЗП.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ЗаказПоставщику КАК ЗП
		|ГДЕ
		|	(НЕ &ИспользоватьПериод ИЛИ (ЗП.Дата >= &ДатаНачала И ЗП.Дата <= &ДатаОкончания))
		|	И (НЕ &ИспользоватьФильтрНомер ИЛИ ЗП.Номер ПОДОБНО &НомерШаблон)
		|	И (НЕ &ИспользоватьФильтрДата ИЛИ (ЗП.Дата >= &ДатаФильтр И ЗП.Дата <= &ДатаФильтрКонец))
		|	И (НЕ &ИспользоватьФильтрСумма ИЛИ ЗП.СуммаДокумента = &СуммаФильтр)
		|	И (НЕ &ИспользоватьФильтрПроведен ИЛИ ЗП.Проведен = &ПроведенФильтр)
		|УПОРЯДОЧИТЬ ПО
		|	ЗП.Дата УБЫВ, ЗП.Номер УБЫВ";

		ЗапросБД.УстановитьПараметр("ИспользоватьПериод", ИспользоватьПериод);
		ЗапросБД.УстановитьПараметр("ДатаНачала", ДатаНачала);
		ЗапросБД.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
		ЗапросБД.УстановитьПараметр("НомерШаблон", НомерШаблон);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
		ЗапросБД.УстановитьПараметр("ДатаФильтр", ДатаФильтр);
		ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", ДатаФильтрКонец);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрСумма", ИспользоватьФильтрСумма);
		ЗапросБД.УстановитьПараметр("СуммаФильтр", СуммаФильтр);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрПроведен", ИспользоватьФильтрПроведен);
		ЗапросБД.УстановитьПараметр("ПроведенФильтр", ПроведенФильтр);

		ШаблонБСЛ_Контрагент = СтрЗаменить(СтрЗаменить(ШаблонКонтрагент, "%", "*"), "_", "?");
		ШаблонБСЛ_Организация = СтрЗаменить(СтрЗаменить(ШаблонОрганизация, "%", "*"), "_", "?");
		ШаблонБСЛ_Склад = СтрЗаменить(СтрЗаменить(ШаблонСклад, "%", "*"), "_", "?");
		ШаблонБСЛ_Ответственный = СтрЗаменить(СтрЗаменить(ШаблонОтветственный, "%", "*"), "_", "?");
		ШаблонБСЛ_Комментарий = СтрЗаменить(СтрЗаменить(ШаблонКомментарий, "%", "*"), "_", "?");

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Если ИспользоватьФильтрКонтрагент = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Контрагент, 2, СтрДлина(ШаблонБСЛ_Контрагент) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрОрганизация = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Организация, 2, СтрДлина(ШаблонБСЛ_Организация) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрСклад = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Склад, 2, СтрДлина(ШаблонБСЛ_Склад) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Склад)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрОтветственный = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Ответственный, 2, СтрДлина(ШаблонБСЛ_Ответственный) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Ответственный)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;
			Если ИспользоватьФильтрКомментарий = Истина Тогда
				ПодстрокаПоиска = Сред(ШаблонБСЛ_Комментарий, 2, СтрДлина(ШаблонБСЛ_Комментарий) - 2);
				Если СтрНайти(ВРег(Строка(Выборка.Комментарий)), ВРег(ПодстрокаПоиска)) <= 0 Тогда Продолжить; КонецЕсли;
			КонецЕсли;

			ЗаказПоставщику = Новый Структура;
			ЗаказПоставщику.Вставить("Номер", Выборка.Номер);
			ЗаказПоставщику.Вставить("Дата", Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
			Если Не ЗначениеЗаполнено(Выборка.Контрагент) Тогда ЗаказПоставщику.Вставить("Контрагент", "Не указан"); Иначе ЗаказПоставщику.Вставить("Контрагент", Выборка.Контрагент); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Организация) Тогда ЗаказПоставщику.Вставить("Организация", "Не указана"); Иначе ЗаказПоставщику.Вставить("Организация", Выборка.Организация); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Ответственный) Тогда ЗаказПоставщику.Вставить("Ответственный", "Не указан"); Иначе ЗаказПоставщику.Вставить("Ответственный", Выборка.Ответственный); КонецЕсли;
			Если ПустаяСтрока(Строка(Выборка.СуммаДокумента)) Или Выборка.СуммаДокумента = Неопределено Тогда ЗаказПоставщику.Вставить("СуммаДокумента", 0); Иначе ЗаказПоставщику.Вставить("СуммаДокумента", Выборка.СуммаДокумента); КонецЕсли;
			Если Не ЗначениеЗаполнено(Выборка.Склад) Тогда ЗаказПоставщику.Вставить("Склад", "Не указан"); Иначе ЗаказПоставщику.Вставить("Склад", Выборка.Склад); КонецЕсли;
			ЗаказПоставщику.Вставить("Проведен", Выборка.Проведен);
			Если Не ЗначениеЗаполнено(Выборка.Комментарий) Тогда ЗаказПоставщику.Вставить("Комментарий", ""); Иначе ЗаказПоставщику.Вставить("Комментарий", Выборка.Комментарий); КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ДатаОплаты) Тогда ЗаказПоставщику.Вставить("ДатаОплаты", Формат(Выборка.ДатаОплаты, "ДФ=dd.MM.yyyy")); Иначе ЗаказПоставщику.Вставить("ДатаОплаты", ""); КонецЕсли;
			Если ЗначениеЗаполнено(Выборка.ДатаПоступления) Тогда ЗаказПоставщику.Вставить("ДатаПоступления", Формат(Выборка.ДатаПоступления, "ДФ=dd.MM.yyyy")); Иначе ЗаказПоставщику.Вставить("ДатаПоступления", ""); КонецЕсли;

			Если ПолныйОтвет Тогда
			// Табличная часть Товары: номенклатура, количество, цена, сумма, даты из шапки уже добавлены выше (ДатаОплаты, ДатаПоступления).
			МассивТоваров = Новый Массив;
			Попытка
				ЗапросТЧ = Новый Запрос;
				ЗапросТЧ.Текст =
				"ВЫБРАТЬ
				|	Т.Номенклатура КАК НоменклатураСсылка,
				|	ПРЕДСТАВЛЕНИЕ(Т.Номенклатура) КАК Номенклатура,
				|	ПРЕДСТАВЛЕНИЕ(Т.ХарактеристикаНоменклатуры) КАК ХарактеристикаНоменклатуры,
				|	Т.Количество КАК Количество,
				|	Т.Цена КАК Цена,
				|	Т.Сумма КАК Сумма,
				|	ПРЕДСТАВЛЕНИЕ(Т.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
				|	Т.КоличествоМест КАК КоличествоМест,
				|	Т.Коэффициент КАК Коэффициент,
				|	Т.ПлановаяСебестоимость КАК ПлановаяСебестоимость,
				|	Т.СуммаНДС КАК СуммаНДС,
				|	ПРЕДСТАВЛЕНИЕ(Т.СтавкаНДС) КАК СтавкаНДС,
				|	ПРЕДСТАВЛЕНИЕ(Т.Спецификация) КАК Спецификация
				|ИЗ
				|	Документ.ЗаказПоставщику.Товары КАК Т
				|ГДЕ
				|	Т.Ссылка = &ЗаказПоставщику
				|УПОРЯДОЧИТЬ ПО
				|	Т.НомерСтроки";
				ЗапросТЧ.УстановитьПараметр("ЗаказПоставщику", Выборка.Ссылка);
				РезТЧ = ЗапросТЧ.Выполнить();
				ВыборкаТЧ = РезТЧ.Выбрать();
				Пока ВыборкаТЧ.Следующий() Цикл
					СтрокаТовара = Новый Структура;
					Если Не ЗначениеЗаполнено(ВыборкаТЧ.НоменклатураСсылка) Тогда СтрокаТовара.Вставить("Номенклатура", "Не указана"); Иначе СтрокаТовара.Вставить("Номенклатура", ВыборкаТЧ.Номенклатура); КонецЕсли;
					Если Не ЗначениеЗаполнено(ВыборкаТЧ.ХарактеристикаНоменклатуры) Тогда СтрокаТовара.Вставить("ХарактеристикаНоменклатуры", ""); Иначе СтрокаТовара.Вставить("ХарактеристикаНоменклатуры", ВыборкаТЧ.ХарактеристикаНоменклатуры); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.Количество)) Или ВыборкаТЧ.Количество = Неопределено Тогда СтрокаТовара.Вставить("Количество", 0); Иначе СтрокаТовара.Вставить("Количество", ВыборкаТЧ.Количество); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.Цена)) Или ВыборкаТЧ.Цена = Неопределено Тогда СтрокаТовара.Вставить("Цена", 0); Иначе СтрокаТовара.Вставить("Цена", ВыборкаТЧ.Цена); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.Сумма)) Или ВыборкаТЧ.Сумма = Неопределено Тогда СтрокаТовара.Вставить("Сумма", 0); Иначе СтрокаТовара.Вставить("Сумма", ВыборкаТЧ.Сумма); КонецЕсли;
					Если Не ЗначениеЗаполнено(ВыборкаТЧ.ЕдиницаИзмерения) Тогда СтрокаТовара.Вставить("ЕдиницаИзмерения", ""); Иначе СтрокаТовара.Вставить("ЕдиницаИзмерения", ВыборкаТЧ.ЕдиницаИзмерения); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.КоличествоМест)) Или ВыборкаТЧ.КоличествоМест = Неопределено Тогда СтрокаТовара.Вставить("КоличествоМест", 0); Иначе СтрокаТовара.Вставить("КоличествоМест", ВыборкаТЧ.КоличествоМест); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.Коэффициент)) Или ВыборкаТЧ.Коэффициент = Неопределено Тогда СтрокаТовара.Вставить("Коэффициент", 0); Иначе СтрокаТовара.Вставить("Коэффициент", ВыборкаТЧ.Коэффициент); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.ПлановаяСебестоимость)) Или ВыборкаТЧ.ПлановаяСебестоимость = Неопределено Тогда СтрокаТовара.Вставить("ПлановаяСебестоимость", 0); Иначе СтрокаТовара.Вставить("ПлановаяСебестоимость", ВыборкаТЧ.ПлановаяСебестоимость); КонецЕсли;
					Если ПустаяСтрока(Строка(ВыборкаТЧ.СуммаНДС)) Или ВыборкаТЧ.СуммаНДС = Неопределено Тогда СтрокаТовара.Вставить("СуммаНДС", 0); Иначе СтрокаТовара.Вставить("СуммаНДС", ВыборкаТЧ.СуммаНДС); КонецЕсли;
					Если Не ЗначениеЗаполнено(ВыборкаТЧ.СтавкаНДС) Тогда СтрокаТовара.Вставить("СтавкаНДС", ""); Иначе СтрокаТовара.Вставить("СтавкаНДС", ВыборкаТЧ.СтавкаНДС); КонецЕсли;
					Если Не ЗначениеЗаполнено(ВыборкаТЧ.Спецификация) Тогда СтрокаТовара.Вставить("Спецификация", ""); Иначе СтрокаТовара.Вставить("Спецификация", ВыборкаТЧ.Спецификация); КонецЕсли;
					МассивТоваров.Добавить(СтрокаТовара);
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": ошибка запроса табличной части Товары — " + ОписаниеОшибки());
			КонецПопытки;
			ЗаказПоставщику.Вставить("Товары", МассивТоваров);

			// Связанные документы (полный список): уникальность по паре Номер+Дата (специфика нумерации 1С). В каждую запись добавляем поле НомерДата для однозначной идентификации.
			МассивПоступлений = Новый Массив;
			МассивЗакрытий = Новый Массив;
			МассивЗаявок = Новый Массив;

			// Поступление товаров и услуг: связь по реквизиту Сделка или по ТЧ Товары.ЗаказПоставщику (УПП).
			Попытка
				ЗапросПоступ = Новый Запрос;
				ЗапросПоступ.Текст =
				"ВЫБРАТЬ
				|	ПТУ.Ссылка КАК Ссылка,
				|	ПТУ.Номер КАК Номер,
				|	ПТУ.Дата КАК Дата
				|ИЗ
				|	Документ.ПоступлениеТоваровУслуг КАК ПТУ
				|ГДЕ
				|	ПТУ.Сделка = &ЗаказПоставщику
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ПТУ2.Ссылка,
				|	ПТУ2.Номер,
				|	ПТУ2.Дата
				|ИЗ
				|	Документ.ПоступлениеТоваровУслуг КАК ПТУ2
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ТЧ
				|		ПО ПТУ2.Ссылка = ТЧ.Ссылка
				|			И ТЧ.ЗаказПоставщику = &ЗаказПоставщику";
				ЗапросПоступ.УстановитьПараметр("ЗаказПоставщику", Выборка.Ссылка);
				РезПоступ = ЗапросПоступ.Выполнить();
				ВыборкаПоступ = РезПоступ.Выбрать();
				ДобавленныеПоступления = Новый Соответствие;
				Пока ВыборкаПоступ.Следующий() Цикл
					ДатаСтр = "";
					Если ЗначениеЗаполнено(ВыборкаПоступ.Дата) Тогда Попытка ДатаСтр = Формат(ВыборкаПоступ.Дата, "ДФ=dd.MM.yyyy"); Исключение КонецПопытки; КонецЕсли;
					КлючНомерДата = Строка(ВыборкаПоступ.Номер) + "|" + ?(ЗначениеЗаполнено(ВыборкаПоступ.Дата), Формат(ВыборкаПоступ.Дата, "ДФ=yyyyMMdd"), "");
					Если ДобавленныеПоступления.Получить(КлючНомерДата) = Неопределено Тогда
						ДобавленныеПоступления.Вставить(КлючНомерДата, Истина);
						НомерДатаСтр = Строка(ВыборкаПоступ.Номер) + " от " + ДатаСтр;
						ЭтПоступ = Новый Структура;
						ЭтПоступ.Вставить("Номер", ВыборкаПоступ.Номер);
						ЭтПоступ.Вставить("Дата", ДатаСтр);
						ЭтПоступ.Вставить("НомерДата", НомерДатаСтр);
						МассивПоступлений.Добавить(ЭтПоступ);
					КонецЕсли;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": ошибка запроса поступлений — " + ОписаниеОшибки());
			КонецПопытки;

			// Закрытие заказов поставщикам: ТЧ Заказы.ЗаказПоставщику.
			Попытка
				ЗапросЗакр = Новый Запрос;
				ЗапросЗакр.Текст =
				"ВЫБРАТЬ
				|	Закр.Ссылка КАК Ссылка,
				|	Закр.Номер КАК Номер,
				|	Закр.Дата КАК Дата
				|ИЗ
				|	Документ.ЗакрытиеЗаказовПоставщикам КАК Закр
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗакрытиеЗаказовПоставщикам.Заказы КАК ЗТЧ
				|		ПО Закр.Ссылка = ЗТЧ.Ссылка
				|			И ЗТЧ.ЗаказПоставщику = &ЗаказПоставщику";
				ЗапросЗакр.УстановитьПараметр("ЗаказПоставщику", Выборка.Ссылка);
				РезЗакр = ЗапросЗакр.Выполнить();
				ВыборкаЗакр = РезЗакр.Выбрать();
				Пока ВыборкаЗакр.Следующий() Цикл
					ДатаСтр = "";
					Если ЗначениеЗаполнено(ВыборкаЗакр.Дата) Тогда Попытка ДатаСтр = Формат(ВыборкаЗакр.Дата, "ДФ=dd.MM.yyyy"); Исключение КонецПопытки; КонецЕсли;
					НомерДатаСтр = Строка(ВыборкаЗакр.Номер) + " от " + ДатаСтр;
					ЭтЗакр = Новый Структура;
					ЭтЗакр.Вставить("Номер", ВыборкаЗакр.Номер);
					ЭтЗакр.Вставить("Дата", ДатаСтр);
					ЭтЗакр.Вставить("НомерДата", НомерДатаСтр);
					МассивЗакрытий.Добавить(ЭтЗакр);
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": ошибка запроса закрытий заказов — " + ОписаниеОшибки());
			КонецПопытки;

			// Заявка на расходование средств: реквизит ДокументОснование или ТЧ РасшифровкаПлатежа.Сделка.
			Попытка
				ЗапросЗаяв = Новый Запрос;
				ЗапросЗаяв.Текст =
				"ВЫБРАТЬ
				|	ЗР.Ссылка КАК Ссылка,
				|	ЗР.Номер КАК Номер,
				|	ЗР.ДатаРасхода КАК Дата
				|ИЗ
				|	Документ.ЗаявкаНаРасходованиеСредств КАК ЗР
				|ГДЕ
				|	ЗР.ДокументОснование = &ЗаказПоставщику
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ЗР2.Ссылка,
				|	ЗР2.Номер,
				|	ЗР2.ДатаРасхода КАК Дата
				|ИЗ
				|	Документ.ЗаявкаНаРасходованиеСредств КАК ЗР2
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеСредств.РасшифровкаПлатежа КАК РП
				|		ПО ЗР2.Ссылка = РП.Ссылка
				|			И РП.Сделка = &ЗаказПоставщику";
				ЗапросЗаяв.УстановитьПараметр("ЗаказПоставщику", Выборка.Ссылка);
				РезЗаяв = ЗапросЗаяв.Выполнить();
				ВыборкаЗаяв = РезЗаяв.Выбрать();
				ДобавленныеЗаявки = Новый Соответствие;
				Пока ВыборкаЗаяв.Следующий() Цикл
					ДатаСтр = "";
					Если ЗначениеЗаполнено(ВыборкаЗаяв.Дата) Тогда Попытка ДатаСтр = Формат(ВыборкаЗаяв.Дата, "ДФ=dd.MM.yyyy"); Исключение КонецПопытки; КонецЕсли;
					КлючНомерДата = Строка(ВыборкаЗаяв.Номер) + "|" + ?(ЗначениеЗаполнено(ВыборкаЗаяв.Дата), Формат(ВыборкаЗаяв.Дата, "ДФ=yyyyMMdd"), "");
					Если ДобавленныеЗаявки.Получить(КлючНомерДата) = Неопределено Тогда
						ДобавленныеЗаявки.Вставить(КлючНомерДата, Истина);
						НомерДатаСтр = Строка(ВыборкаЗаяв.Номер) + " от " + ДатаСтр;
						ЭтЗаяв = Новый Структура;
						ЭтЗаяв.Вставить("Номер", ВыборкаЗаяв.Номер);
						ЭтЗаяв.Вставить("Дата", ДатаСтр);
						ЭтЗаяв.Вставить("НомерДата", НомерДатаСтр);
						МассивЗаявок.Добавить(ЭтЗаяв);
					КонецЕсли;
				КонецЦикла;
			Исключение
				МассивОшибок.Добавить("Заказ №" + Выборка.Номер + ": ошибка запроса заявок на расходование — " + ОписаниеОшибки());
			КонецПопытки;

			СвязанныеДокументы = Новый Структура;
			СвязанныеДокументы.Вставить("Поступления", МассивПоступлений);
			СвязанныеДокументы.Вставить("ЗакрытияЗаказов", МассивЗакрытий);
			СвязанныеДокументы.Вставить("ЗаявкаНаРасходованиеСредств", МассивЗаявок);
			ЗаказПоставщику.Вставить("СвязанныеДокументы", СвязанныеДокументы);

			// Вложения из хранилища дополнительной информации.
			МассивВложений = Новый Массив;
			ЗапросХДИ = Новый Запрос;
			ЗапросХДИ.Текст = "ВЫБРАТЬ ХДИ.Ссылка КАК Ссылка, ХДИ.ИмяФайла КАК ИмяФайла ИЗ Справочник.ХранилищеДополнительнойИнформации КАК ХДИ ГДЕ ХДИ.Объект = &СсылкаДокумента";
			ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", Выборка.Ссылка);
			Попытка
				РезультатХДИ = ЗапросХДИ.Выполнить();
				ВыборкаХДИ = РезультатХДИ.Выбрать();
				Пока ВыборкаХДИ.Следующий() Цикл
					Попытка
						ЭлементХДИ = ВыборкаХДИ.Ссылка.ПолучитьОбъект();
						ДвоичныеДанные = Неопределено;
						Если ЗначениеЗаполнено(ЭлементХДИ.Хранилище) Тогда ДвоичныеДанные = ЭлементХДИ.Хранилище.Получить(); КонецЕсли;
						ДанныеBase64 = "";
						Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") И ДвоичныеДанные.Размер() > 0 Тогда Попытка ДанныеBase64 = Строка(Base64Строка(ДвоичныеДанные)); Исключение ДанныеBase64 = ""; КонецПопытки; КонецЕсли;
						Вложение = Новый Структура("ИмяФайла", ВыборкаХДИ.ИмяФайла); Вложение.Вставить("Данные", ДанныеBase64);
