Функция ПолучитьСтроковойПараметр(Запрос, ИмяПараметра)
	Значение = "";

	Попытка
		Значение = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить(ИмяПараметра)));
	Исключение
		Значение = "";
	КонецПопытки;

	Если Значение = "" Тогда
		Попытка
			Значение = СокрЛП(Строка(Запрос.ПараметрыURL[ИмяПараметра]));
		Исключение
			Значение = "";
		КонецПопытки;
	КонецЕсли;

	Возврат Значение;
КонецФункции

Функция ПреобразоватьВБулево(СтрокаЛог)
	Если ПустаяСтрока(СтрокаЛог) Тогда
		Возврат Ложь;
	КонецЕсли;

	Стр = ВРег(СокрЛП(СтрокаЛог));

	Если Стр = "1" Тогда
		Возврат Истина;
	КонецЕсли;
	Если Стр = "TRUE" Тогда
		Возврат Истина;
	КонецЕсли;
	Если Стр = "YES" Тогда
		Возврат Истина;
	КонецЕсли;
	Если Стр = "ДА" Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
КонецФункции

Функция РазобратьДатуСтрокой(ЗначДата, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня)
	Результат = Новый Структура;
	Результат.Вставить("Ок", Ложь);
	Результат.Вставить("Г", "");
	Результат.Вставить("М", "");
	Результат.Вставить("Д", "");

	Если Не ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат Результат;
	КонецЕсли;

	Г = "";
	М = "";
	Д = "";

	ЧастиТочка = СтрРазделить(ЗначДата, ".", Ложь);
	ЧастиДефис = СтрРазделить(ЗначДата, "-", Ложь);

	Если ЧастиТочка.Количество() = КолЧастейДаты Тогда
		Д = ЧастиТочка[0];
		М = ЧастиТочка[1];
		Г = ЧастиТочка[2];
	ИначеЕсли ЧастиДефис.Количество() = КолЧастейДаты Тогда
		Если СтрДлина(СокрЛП(ЧастиДефис[0])) = ДлинаГода Тогда
			Г = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Д = ЧастиДефис[2];
		Иначе
			Д = ЧастиДефис[0];
			М = ЧастиДефис[1];
			Г = ЧастиДефис[2];
		КонецЕсли;
	Иначе
		Возврат Результат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Г) Тогда
		Возврат Результат;
	КонецЕсли;

	Пока СтрДлина(Г) < ДлинаГода Цикл
		Г = "0" + Г;
	КонецЦикла;
	Пока СтрДлина(М) < ДлинаМесяца Цикл
		М = "0" + М;
	КонецЦикла;
	Пока СтрДлина(Д) < ДлинаДня Цикл
		Д = "0" + Д;
	КонецЦикла;

	Результат.Вставить("Ок", Истина);
	Результат.Вставить("Г", Г);
	Результат.Вставить("М", М);
	Результат.Вставить("Д", Д);

	Возврат Результат;
КонецФункции

Функция РазобратьПериодFromTo(ЗначFrom, ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	ДатаНачала = Дата(1, 1, 1);
	ДатаОкончания = Дата(1, 1, 1);
	ИспользоватьПериод = Ложь;

	ПериодРезультат = Новый Структура;
	ПериодРезультат.Вставить("ИспользоватьПериод", ИспользоватьПериод);
	ПериодРезультат.Вставить("ДатаНачала", ДатаНачала);
	ПериодРезультат.Вставить("ДатаОкончания", ДатаОкончания);

	Если Не ЗначениеЗаполнено(ЗначFrom) Или Не ЗначениеЗаполнено(ЗначTo) Тогда
		Возврат ПериодРезультат;
	КонецЕсли;

	П1 = РазобратьДатуСтрокой(ЗначFrom, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
	П2 = РазобратьДатуСтрокой(ЗначTo, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);

	Если П1.Ок И П2.Ок Тогда
		ДатаНачала = Дата(П1.Г + П1.М + П1.Д + "000000");
		ДатаОкончания = КонецДня(Дата(П2.Г + П2.М + П2.Д + "000000"));
		ИспользоватьПериод = Истина;
	Иначе
		МассивОшибок.Добавить("Некорректный формат from/to: " + ЗначFrom + " / " + ЗначTo);
	КонецЕсли;

	ПериодРезультат.Вставить("ИспользоватьПериод", ИспользоватьПериод);
	ПериодРезультат.Вставить("ДатаНачала", ДатаНачала);
	ПериодРезультат.Вставить("ДатаОкончания", ДатаОкончания);

	Возврат ПериодРезультат;
КонецФункции

Функция ПохожеНаЧисло(СтрокаЧисло)
	Если СтрокаЧисло = "" Тогда
		Возврат Ложь;
	КонецЕсли;

	ТекстЧисла = СтрЗаменить(СтрокаЧисло, ",", ".");
	ЕстьТочка = Ложь;

	Для Индекс = 1 По СтрДлина(ТекстЧисла) Цикл
		Символ = Сред(ТекстЧисла, Индекс, 1);

		Если Символ = "." Тогда
			Если ЕстьТочка Тогда
				Возврат Ложь;
			КонецЕсли;
			ЕстьТочка = Истина;
		ИначеЕсли Символ >= "0" И Символ <= "9" Тогда
			Продолжить;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Возврат Истина;
КонецФункции

Функция СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок)
	Фильтры = Новый Структура;

	ЗначFrom = ПолучитьСтроковойПараметр(Запрос, "from");
	ЗначTo = ПолучитьСтроковойПараметр(Запрос, "to");

	ПериодРезультат = РазобратьПериодFromTo(
		ЗначFrom,
		ЗначTo,
		КолЧастейДаты,
		ДлинаГода,
		ДлинаМесяца,
		ДлинаДня,
		МассивОшибок);

	Фильтры.Вставить("ИспользоватьПериод", ПериодРезультат.ИспользоватьПериод);
	Фильтры.Вставить("ДатаНачала", ПериодРезультат.ДатаНачала);
	Фильтры.Вставить("ДатаОкончания", ПериодРезультат.ДатаОкончания);

	ЗначCode = ПолучитьСтроковойПараметр(Запрос, "code");
	ИспользоватьФильтрНомер = ЗначCode <> "";
	НомерШаблон = "%";
	Если ИспользоватьФильтрНомер Тогда
		НомерШаблон = "%" + ЗначCode + "%";
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрНомер", ИспользоватьФильтрНомер);
	Фильтры.Вставить("НомерШаблон", НомерШаблон);

	ИспользоватьФильтрДата = Ложь;
	ДатаФильтр = Дата(1, 1, 1);
	ДатаФильтрКонец = Дата(1, 1, 1);
	ЗначDate = ПолучитьСтроковойПараметр(Запрос, "date");
	Если ЗначDate <> "" Тогда
		П = РазобратьДатуСтрокой(ЗначDate, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня);
		Если П.Ок Тогда
			ДатаФильтр = Дата(П.Г + П.М + П.Д + "000000");
			ДатаФильтрКонец = КонецДня(ДатаФильтр);
			ИспользоватьФильтрДата = Истина;
		Иначе
			МассивОшибок.Добавить("Некорректный параметр date: " + ЗначDate);
		КонецЕсли;
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрДата", ИспользоватьФильтрДата);
	Фильтры.Вставить("ДатаФильтр", ДатаФильтр);
	Фильтры.Вставить("ДатаФильтрКонец", ДатаФильтрКонец);

	ЗначSumm = ПолучитьСтроковойПараметр(Запрос, "summ");
	ИспользоватьФильтрСумма = ПохожеНаЧисло(ЗначSumm);
	СуммаФильтр = 0;
	Если ИспользоватьФильтрСумма Тогда
		СуммаФильтр = Число(ЗначSumm);
	КонецЕсли;
	Фильтры.Вставить("ИспользоватьФильтрСумма", ИспользоватьФильтрСумма);
	Фильтры.Вставить("СуммаФильтр", СуммаФильтр);

	ЗначApproved = ПолучитьСтроковойПараметр(Запрос, "approved");
	ИспользоватьФильтрПроведен = ЗначApproved <> "";
	ПроведенФильтр = ПреобразоватьВБулево(ЗначApproved);
	Фильтры.Вставить("ИспользоватьФильтрПроведен", ИспользоватьФильтрПроведен);
	Фильтры.Вставить("ПроведенФильтр", ПроведенФильтр);

	ЗначFullНижний = "full";
	ПерваяБуква = 1;
	НачалоОстатка = 2;
	ЛевFullНижний = Лев(ЗначFullНижний, ПерваяБуква);
	ОстатокFullНижний = Сред(ЗначFullНижний, НачалоОстатка, СтрДлина(ЗначFullНижний) - ПерваяБуква);
	ПолныйПараметрСЗаглавной = ВРег(ЛевFullНижний) + ОстатокFullНижний;
	ПолныйПараметрВерхний = ВРег(ЗначFullНижний);

	ЗначFull = ПолучитьСтроковойПараметр(Запрос, ЗначFullНижний);
	Если ЗначFull = "" Тогда
		ЗначFull = ПолучитьСтроковойПараметр(Запрос, ПолныйПараметрСЗаглавной);
	КонецЕсли;
	Если ЗначFull = "" Тогда
		ЗначFull = ПолучитьСтроковойПараметр(Запрос, ПолныйПараметрВерхний);
	КонецЕсли;

	ПолныйОтвет = ПреобразоватьВБулево(ЗначFull);
	Если ЗначFull <> "" Тогда
		СтрFull = ВРег(СокрЛП(ЗначFull));
		Если СтрFull = "FULL" Тогда
			ПолныйОтвет = Истина;
		КонецЕсли;
	КонецЕсли;
	Фильтры.Вставить("ПолныйОтвет", ПолныйОтвет);

	ЗначSupplier = ПолучитьСтроковойПараметр(Запрос, "supplier");
	Фильтры.Вставить("ИспользоватьФильтрКонтрагент", ЗначSupplier <> "");
	Фильтры.Вставить("ПодстрокаКонтрагент", ЗначSupplier);

	ЗначOrg = ПолучитьСтроковойПараметр(Запрос, "org");
	Фильтры.Вставить("ИспользоватьФильтрОрганизация", ЗначOrg <> "");
	Фильтры.Вставить("ПодстрокаОрганизация", ЗначOrg);

	ЗначWarehouse = ПолучитьСтроковойПараметр(Запрос, "warehouse");
	Фильтры.Вставить("ИспользоватьФильтрСклад", ЗначWarehouse <> "");
	Фильтры.Вставить("ПодстрокаСклад", ЗначWarehouse);

	ЗначResponsible = ПолучитьСтроковойПараметр(Запрос, "responsible");
	Фильтры.Вставить("ИспользоватьФильтрОтветственный", ЗначResponsible <> "");
	Фильтры.Вставить("ПодстрокаОтветственный", ЗначResponsible);

	ЗначComment = ПолучитьСтроковойПараметр(Запрос, "comment");
	Фильтры.Вставить("ИспользоватьФильтрКомментарий", ЗначComment <> "");
	Фильтры.Вставить("ПодстрокаКомментарий", ЗначComment);

	Возврат Фильтры;
КонецФункции

Функция ПроходитПостФильтры(Выборка, Фильтры)
	Если Фильтры.ИспользоватьФильтрКонтрагент Тогда
		Если СтрНайти(ВРег(Строка(Выборка.Контрагент)), ВРег(Фильтры.ПодстрокаКонтрагент)) <= 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрОрганизация Тогда
		Если СтрНайти(ВРег(Строка(Выборка.Организация)), ВРег(Фильтры.ПодстрокаОрганизация)) <= 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрСклад Тогда
		Если СтрНайти(ВРег(Строка(Выборка.Склад)), ВРег(Фильтры.ПодстрокаСклад)) <= 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрОтветственный Тогда
		Если СтрНайти(ВРег(Строка(Выборка.Ответственный)), ВРег(Фильтры.ПодстрокаОтветственный)) <= 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрКомментарий Тогда
		Если СтрНайти(ВРег(Строка(Выборка.Комментарий)), ВРег(Фильтры.ПодстрокаКомментарий)) <= 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Возврат Истина;
КонецФункции

Функция СформироватьТоварыПолногоОтвета(СсылкаЗаказа)
	МассивТоваров = Новый Массив;
	ОбъектЗаказа = СсылкаЗаказа.ПолучитьОбъект();

	Для каждого СтрТЧ Из ОбъектЗаказа.Товары Цикл
		МассивТоваров.Добавить(СформироватьСтрокуТовараПолногоОтвета(СтрТЧ));
	КонецЦикла;

	Возврат МассивТоваров;
КонецФункции

Функция СформироватьСтрокуТовараПолногоОтвета(СтрТЧ)
	СтрокаТовара = Новый Структура;

	Ноль = 0;
	ПустаяСтрока = "";
	СтрокаНеУказано = "Не указано";

	СтрокаТовара.Вставить(
		"Номенклатура",
		НаименованиеИлиПоУмолчанию(СтрТЧ.Номенклатура, СтрокаНеУказано));

	СтрокаТовара.Вставить(
		"ХарактеристикаНоменклатуры",
		НаименованиеИлиПоУмолчанию(СтрТЧ.ХарактеристикаНоменклатуры, ПустаяСтрока));

	СтрокаТовара.Вставить(
		"Количество",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.Количество, Ноль));

	СтрокаТовара.Вставить(
		"Цена",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.Цена, Ноль));

	СтрокаТовара.Вставить(
		"Сумма",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.Сумма, Ноль));

	СтрокаТовара.Вставить(
		"ЕдиницаИзмерения",
		НаименованиеИлиПоУмолчанию(СтрТЧ.ЕдиницаИзмерения, ПустаяСтрока));

	СтрокаТовара.Вставить(
		"КоличествоМест",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.КоличествоМест, Ноль));

	СтрокаТовара.Вставить(
		"Коэффициент",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.Коэффициент, Ноль));

	СтрокаТовара.Вставить(
		"ПлановаяСебестоимость",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.ПлановаяСебестоимость, Ноль));

	СтрокаТовара.Вставить(
		"СуммаНДС",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.СуммаНДС, Ноль));

	СтрокаТовара.Вставить(
		"СтавкаНДС",
		ЗначениеИлиПоУмолчаниюЕслиНеопределено(СтрТЧ.СтавкаНДС, ПустаяСтрока));

	СтрокаТовара.Вставить(
		"Спецификация",
		НаименованиеИлиПоУмолчанию(СтрТЧ.Спецификация, ПустаяСтрока));

	Возврат СтрокаТовара;
КонецФункции

Функция НаименованиеИлиПоУмолчанию(СсылкаОбъекта, ПоУмолчанию)
	Если ЗначениеЗаполнено(СсылкаОбъекта) Тогда
		Возврат СсылкаОбъекта.Наименование;
	КонецЕсли;
	Возврат ПоУмолчанию;
КонецФункции

Функция ЗначениеИлиПоУмолчаниюЕслиНеопределено(Значение, ПоУмолчанию)
	Если Значение = Неопределено Тогда
		Возврат ПоУмолчанию;
	КонецЕсли;
	Возврат Значение;
КонецФункции

Функция ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Значение, ПоУмолчанию)
	Если ЗначениеЗаполнено(Значение) Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат ПоУмолчанию;
КонецФункции

Функция СформироватьСводкуСвязейИВложений(КлючЕсть, КлючКоличество)
	СвязанныеДокументы = Новый Структура;

	СводкаПустая = Новый Структура;
	СводкаПустая.Вставить(КлючЕсть, Ложь);
	СводкаПустая.Вставить(КлючКоличество, 0);

	СвязанныеДокументы.Вставить("Поступления", СводкаПустая);
	СвязанныеДокументы.Вставить("ЗакрытияЗаказов", СводкаПустая);
	СвязанныеДокументы.Вставить("ЗаявкаНаРасходованиеСредств", СводкаПустая);

	Вложения = Новый Структура;
	Вложения.Вставить(КлючЕсть, Ложь);
	Вложения.Вставить(КлючКоличество, 0);

	Результат = Новый Структура;
	Результат.Вставить("СвязанныеДокументы", СвязанныеДокументы);
	Результат.Вставить("Вложения", Вложения);
	Возврат Результат;
КонецФункции

Функция СформироватьВложенияИзХранилища(СсылкаДокумента, НомерЗаказа, МассивОшибок, ТекстНеУказано)
	МассивВложений = Новый Массив;

	ЗапросХДИ = Новый Запрос;
	ЗапросХДИ.Текст =
	"ВЫБРАТЬ
	|	ХДИ.Ссылка КАК Ссылка,
	|	ХДИ.ИмяФайла КАК ИмяФайла
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХДИ
	|ГДЕ
	|	ХДИ.Объект = &СсылкаДокумента";

	ЗапросХДИ.УстановитьПараметр("СсылкаДокумента", СсылкаДокумента);

	Попытка
		РезультатХДИ = ЗапросХДИ.Выполнить();
		ВыборкаХДИ = РезультатХДИ.Выбрать();

		Пока ВыборкаХДИ.Следующий() Цикл
			ИмяФайла = ?(ЗначениеЗаполнено(ВыборкаХДИ.ИмяФайла), ВыборкаХДИ.ИмяФайла, ТекстНеУказано);

			ИдентификаторХранилища = "";
			Попытка
				ИдентификаторХранилища = Строка(ВыборкаХДИ.Ссылка.УникальныйИдентификатор());
			Исключение
				ИдентификаторХранилища = "";
			КонецПопытки;

			Если ИмяФайла <> "" И ИдентификаторХранилища <> "" Тогда
				Вложение = Новый Структура;
				Вложение.Вставить("ЕстьВложение", Истина);
				Вложение.Вставить("ИмяФайла", ИмяФайла);
				Вложение.Вставить("ИдентификаторХранилища", ИдентификаторХранилища);
				МассивВложений.Добавить(Вложение);
			КонецЕсли;
		КонецЦикла;
	Исключение
		МассивОшибок.Добавить("Ошибка запроса вложений для заказа №" + НомерЗаказа + " - " + ОписаниеОшибки());
	КонецПопытки;

	Возврат МассивВложений;
КонецФункции

Функция СформироватьЗаказИзВыборки(Выборка, Фильтры, МассивОшибок, КлючЕсть, КлючКоличество, ТекстНеУказано)
	ЗаказПоставщику = Новый Структура;

	ЗаказПоставщику.Вставить("Номер", Выборка.Номер);
	ЗаказПоставщику.Вставить("Дата", Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));

	ЗаказПоставщику.Вставить("Контрагент", ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Выборка.Контрагент, ТекстНеУказано));
	ЗаказПоставщику.Вставить("Организация", ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Выборка.Организация, ТекстНеУказано));
	ЗаказПоставщику.Вставить("Ответственный", ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Выборка.Ответственный, ТекстНеУказано));
	ЗаказПоставщику.Вставить("СуммаДокумента", ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Выборка.СуммаДокумента, 0));
	ЗаказПоставщику.Вставить("Склад", ЗначениеИлиПоУмолчаниюЕслиНеЗаполнено(Выборка.Склад, ТекстНеУказано));

	ЗаказПоставщику.Вставить("Проведен", Выборка.Проведен);

	Если ЗначениеЗаполнено(Выборка.Комментарий) Тогда
		ЗаказПоставщику.Вставить("Комментарий", Выборка.Комментарий);
	Иначе
		ЗаказПоставщику.Вставить("Комментарий", "");
	КонецЕсли;

	Если ЗначениеЗаполнено(Выборка.ДатаОплаты) Тогда
		ЗаказПоставщику.Вставить("ДатаОплаты", Формат(Выборка.ДатаОплаты, "ДФ=dd.MM.yyyy"));
	Иначе
		ЗаказПоставщику.Вставить("ДатаОплаты", "");
	КонецЕсли;

	Если ЗначениеЗаполнено(Выборка.ДатаПоступления) Тогда
		ЗаказПоставщику.Вставить("ДатаПоступления", Формат(Выборка.ДатаПоступления, "ДФ=dd.MM.yyyy"));
	Иначе
		ЗаказПоставщику.Вставить("ДатаПоступления", "");
	КонецЕсли;

	Сводка = СформироватьСводкуСвязейИВложений(КлючЕсть, КлючКоличество);
	ЗаказПоставщику.Вставить("СвязанныеДокументы", Сводка.СвязанныеДокументы);
	Если Фильтры.ПолныйОтвет Тогда
		ЗаказПоставщику.Вставить(
			"Вложения",
			СформироватьВложенияИзХранилища(Выборка.Ссылка, Выборка.Номер, МассивОшибок, ТекстНеУказано));
	Иначе
		ЗаказПоставщику.Вставить("Вложения", Сводка.Вложения);
	КонецЕсли;

	Если Фильтры.ПолныйОтвет Тогда
		Попытка
			ЗаказПоставщику.Вставить("Товары", СформироватьТоварыПолногоОтвета(Выборка.Ссылка));
		Исключение
			МассивОшибок.Добавить("Проблема в заказе №" + Выборка.Номер + ". Ошибка: " + ОписаниеОшибки());
			ЗаказПоставщику.Вставить("Товары", Новый Массив);
		КонецПопытки;
	КонецЕсли;

	Возврат ЗаказПоставщику;
КонецФункции

Функция ПолучитьВыборкуЗаказов(Фильтры)
	ЗапросБД = Новый Запрос;
	УсловияГде = "";

	Если Фильтры.ИспользоватьПериод Тогда
		УсловияГде = УсловияГде
			+ "
			|	И ЗП.Дата >= &ДатаНачала
			|	И ЗП.Дата <= &ДатаОкончания";
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрНомер Тогда
		УсловияГде = УсловияГде
			+ "
			|	И ЗП.Номер ПОДОБНО &НомерШаблон";
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрДата Тогда
		УсловияГде = УсловияГде
			+ "
			|	И ЗП.Дата >= &ДатаФильтр
			|	И ЗП.Дата <= &ДатаФильтрКонец";
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрСумма Тогда
		УсловияГде = УсловияГде
			+ "
			|	И ЗП.СуммаДокумента = &СуммаФильтр";
	КонецЕсли;

	Если Фильтры.ИспользоватьФильтрПроведен Тогда
		УсловияГде = УсловияГде
			+ "
			|	И ЗП.Проведен = &ПроведенФильтр";
	КонецЕсли;

	ЗапросБД.Текст =
	"ВЫБРАТЬ
	|	ЗП.Ссылка КАК Ссылка,
	|	ЗП.Номер КАК Номер,
	|	ЗП.Дата КАК Дата,
	|	ЗП.ДатаОплаты КАК ДатаОплаты,
	|	ЗП.ДатаПоступления КАК ДатаПоступления,
	|	ПРЕДСТАВЛЕНИЕ(ЗП.Контрагент) КАК Контрагент,
	|	ПРЕДСТАВЛЕНИЕ(ЗП.Организация) КАК Организация,
	|	ПРЕДСТАВЛЕНИЕ(ЗП.Склад) КАК Склад,
	|	ПРЕДСТАВЛЕНИЕ(ЗП.Ответственный) КАК Ответственный,
	|	ЗП.СуммаДокумента КАК СуммаДокумента,
	|	ЗП.Проведен КАК Проведен,
	|	ЗП.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗП
	|ГДЕ
	|	1=1"
	+ УсловияГде
	+ "
	|УПОРЯДОЧИТЬ ПО
	|	ЗП.Дата УБЫВ, ЗП.Номер УБЫВ";

	ЗапросБД.УстановитьПараметр("ДатаНачала", Фильтры.ДатаНачала);
	ЗапросБД.УстановитьПараметр("ДатаОкончания", Фильтры.ДатаОкончания);
	ЗапросБД.УстановитьПараметр("НомерШаблон", Фильтры.НомерШаблон);
	ЗапросБД.УстановитьПараметр("ДатаФильтр", Фильтры.ДатаФильтр);
	ЗапросБД.УстановитьПараметр("ДатаФильтрКонец", Фильтры.ДатаФильтрКонец);
	ЗапросБД.УстановитьПараметр("СуммаФильтр", Фильтры.СуммаФильтр);
	ЗапросБД.УстановитьПараметр("ПроведенФильтр", Фильтры.ПроведенФильтр);

	Результат = ЗапросБД.Выполнить();
	Возврат Результат.Выбрать();
КонецФункции

Функция ПолучитьМассивЗаказов(Выборка, Фильтры, МассивОшибок, КлючЕсть, КлючКоличество, ТекстНеУказано)
	МассивЗаказов = Новый Массив;

	Пока Выборка.Следующий() Цикл
		Если ПроходитПостФильтры(Выборка, Фильтры) Тогда
			ЗаказПоставщику = СформироватьЗаказИзВыборки(
				Выборка,
				Фильтры,
				МассивОшибок,
				КлючЕсть,
				КлючКоличество,
				ТекстНеУказано);

			МассивЗаказов.Добавить(ЗаказПоставщику);
		КонецЕсли;
	КонецЦикла;

	Возврат МассивЗаказов;
КонецФункции

Функция GetSOrders_Impl(Запрос)
	МассивЗаказов = Новый Массив;
	МассивОшибок = Новый Массив;

	HTTPСтатусУспеха = 200;
	HTTPСтатусОшибки = 500;

	КлючЕсть = "Есть";
	КлючКоличество = "Количество";
	КлючData = "data";
	КлючErrors = "errors";
	КлючError = "error";

	ТекстНеУказано = "Не указано";

	КолЧастейДаты = СтрДлина("000");
	ДлинаГода = СтрДлина("0000");
	ДлинаМесяца = СтрДлина("00");
	ДлинаДня = СтрДлина("00");

	Попытка
		Фильтры = СобратьФильтры(Запрос, КолЧастейДаты, ДлинаГода, ДлинаМесяца, ДлинаДня, МассивОшибок);
		Выборка = ПолучитьВыборкуЗаказов(Фильтры);
		МассивЗаказов = ПолучитьМассивЗаказов(Выборка, Фильтры, МассивОшибок, КлючЕсть, КлючКоличество, ТекстНеУказано);

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить(КлючData, МассивЗаказов);
		ИтоговыйРезультат.Вставить(КлючErrors, МассивОшибок);

		JSON = Новый ЗаписьJSON;
		JSON.УстановитьСтроку();
		ЗаписатьJSON(JSON, ИтоговыйРезультат);
		JSONСтрока = JSON.Закрыть();

		Ответ = Новый HTTPСервисОтвет(HTTPСтатусУспеха);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура(КлючError, ТекстОшибки);

		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		JSONОшибкиСтрока = JSONОшибки.Закрыть();

		Ответ = Новый HTTPСервисОтвет(HTTPСтатусОшибки);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(JSONОшибкиСтрока);

		Возврат Ответ;
	КонецПопытки;
КонецФункции
