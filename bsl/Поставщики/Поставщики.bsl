// Модуль HTTP-сервиса. Имя функции должно совпадать с именем шаблона URL в конфигураторе.
// Поставщики — контрагенты с признаком Поставщик (Справочник.Контрагенты).
// Параметры: name (в query слэш: _slash_), inn, full. По умолчанию — базовый набор полей; при full=true — массив действующих договоров.

Функция GetSuppliers(Запрос) Экспорт
	МассивПоставщиков = Новый Массив;
	МассивОшибок = Новый Массив;

	Попытка
		ИспользоватьФильтрНаименование = Ложь;
		ШаблонНаименование = "";
		ЗначName = "";
		Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("name"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначName) Тогда Попытка ЗначName = СокрЛП(Строка(Запрос.ПараметрыURL["name"])); Исключение КонецПопытки; КонецЕсли;
		ЗначName = СтрЗаменить(ЗначName, "_slash_", "/");
		Если ЗначениеЗаполнено(ЗначName) Тогда ИспользоватьФильтрНаименование = Истина; ШаблонНаименование = "%" + ЗначName + "%"; Иначе ШаблонНаименование = "%"; КонецЕсли;

		ИспользоватьФильтрИНН = Ложь;
		ШаблонИНН = "";
		ЗначInn = "";
		Попытка ЗначInn = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("inn"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначInn) Тогда Попытка ЗначInn = СокрЛП(Строка(Запрос.ПараметрыURL["inn"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначInn) Тогда ИспользоватьФильтрИНН = Истина; ШаблонИНН = "%" + ЗначInn + "%"; Иначе ШаблонИНН = "%"; КонецЕсли;

		ПолныйОтвет = Ложь;
		ЗначFull = "";
		Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыЗапроса.Получить("full"))); Исключение КонецПопытки;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["Full"])); Исключение КонецПопытки; КонецЕсли;
		Если Не ЗначениеЗаполнено(ЗначFull) Тогда Попытка ЗначFull = СокрЛП(Строка(Запрос.ПараметрыURL["FULL"])); Исключение КонецПопытки; КонецЕсли;
		Если ЗначениеЗаполнено(ЗначFull) Тогда ПолныйОтвет = (ВРег(ЗначFull) = "1" Или ВРег(ЗначFull) = "TRUE" Или ВРег(ЗначFull) = "YES" Или ВРег(ЗначFull) = "ДА"); КонецЕсли;

		ЗапросБД = Новый Запрос;
		ЗапросБД.Текст =
		"ВЫБРАТЬ
		|	К.Ссылка КАК Ссылка,
		|	К.Наименование КАК Наименование,
		|	К.НаименованиеПолное КАК НаименованиеПолное,
		|	К.ИНН КАК ИНН,
		|	К.КПП КАК КПП,
		|	К.КодПоОКПО КАК КодПоОКПО,
		|	К.ОГРН КАК ОГРН,
		|	ПРЕДСТАВЛЕНИЕ(К.ЮрФизЛицо) КАК ЮрФизЛицо,
		|	К.СрокВыполненияЗаказаПоставщиком КАК СрокВыполненияЗаказа,
		|	К.Покупатель КАК ТакжеПокупатель,
		|	К.НеЯвляетсяРезидентом КАК НеРезидент,
		|	К.Комментарий КАК Комментарий
		|ИЗ
		|	Справочник.Контрагенты КАК К
		|ГДЕ
		|	К.Поставщик = ИСТИНА
		|	И К.ПометкаУдаления = ЛОЖЬ
		|	И (НЕ &ИспользоватьФильтрНаименование ИЛИ К.Наименование ПОДОБНО &ШаблонНаименование)
		|	И (НЕ &ИспользоватьФильтрИНН ИЛИ К.ИНН ПОДОБНО &ШаблонИНН)
		|УПОРЯДОЧИТЬ ПО
		|	К.Наименование";
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрНаименование", ИспользоватьФильтрНаименование);
		ЗапросБД.УстановитьПараметр("ШаблонНаименование", ШаблонНаименование);
		ЗапросБД.УстановитьПараметр("ИспользоватьФильтрИНН", ИспользоватьФильтрИНН);
		ЗапросБД.УстановитьПараметр("ШаблонИНН", ШаблонИНН);

		Результат = ЗапросБД.Выполнить();
		Выборка = Результат.Выбрать();

		Пока Выборка.Следующий() Цикл
			Поставщик = Новый Структура;
			Поставщик.Вставить("Наименование", ?(ЗначениеЗаполнено(Выборка.Наименование), СокрЛП(Строка(Выборка.Наименование)), ""));
			Поставщик.Вставить("НаименованиеПолное", ?(ЗначениеЗаполнено(Выборка.НаименованиеПолное), СокрЛП(Строка(Выборка.НаименованиеПолное)), ""));
			Поставщик.Вставить("ИНН", ?(ЗначениеЗаполнено(Выборка.ИНН), СокрЛП(Строка(Выборка.ИНН)), ""));
			Поставщик.Вставить("КПП", ?(ЗначениеЗаполнено(Выборка.КПП), СокрЛП(Строка(Выборка.КПП)), ""));
			Поставщик.Вставить("ОГРН", ?(ЗначениеЗаполнено(Выборка.ОГРН), СокрЛП(Строка(Выборка.ОГРН)), ""));
			Поставщик.Вставить("КодПоОКПО", ?(ЗначениеЗаполнено(Выборка.КодПоОКПО), СокрЛП(Строка(Выборка.КодПоОКПО)), ""));
			Поставщик.Вставить("ЮрФизЛицо", ?(ЗначениеЗаполнено(Выборка.ЮрФизЛицо), СокрЛП(Строка(Выборка.ЮрФизЛицо)), ""));
			Поставщик.Вставить("СрокВыполненияЗаказа", Выборка.СрокВыполненияЗаказа);
			Поставщик.Вставить("ТакжеПокупатель", Выборка.ТакжеПокупатель);
			Поставщик.Вставить("НеРезидент", Выборка.НеРезидент);
			Поставщик.Вставить("Комментарий", ?(ЗначениеЗаполнено(Выборка.Комментарий), Выборка.Комментарий, ""));

			Если ПолныйОтвет Тогда
				МассивДоговоров = Новый Массив;
				ЗапросДоговоров = Новый Запрос;
				ЗапросДоговоров.Текст =
				"ВЫБРАТЬ
				|	Д.Наименование КАК Наименование,
				|	Д.Номер КАК Номер,
				|	Д.Дата КАК Дата,
				|	Д.СрокДействия КАК СрокДействия,
				|	ПРЕДСТАВЛЕНИЕ(Д.Организация) КАК Организация,
				|	ПРЕДСТАВЛЕНИЕ(Д.ВидДоговора) КАК ВидДоговора,
				|	ПРЕДСТАВЛЕНИЕ(Д.ВалютаВзаиморасчетов) КАК Валюта
				|ИЗ
				|	Справочник.ДоговорыКонтрагентов КАК Д
				|ГДЕ
				|	Д.Владелец = &Контрагент
				|	И Д.ПометкаУдаления = ЛОЖЬ
				|УПОРЯДОЧИТЬ ПО
				|	Д.Дата УБЫВ";
				ЗапросДоговоров.УстановитьПараметр("Контрагент", Выборка.Ссылка);
				РезДоговоров = ЗапросДоговоров.Выполнить();
				ВыборкаД = РезДоговоров.Выбрать();
				Пока ВыборкаД.Следующий() Цикл
					Договор = Новый Структура;
					Договор.Вставить("Наименование", ?(ЗначениеЗаполнено(ВыборкаД.Наименование), СокрЛП(Строка(ВыборкаД.Наименование)), ""));
					Договор.Вставить("Номер", ?(ЗначениеЗаполнено(ВыборкаД.Номер), СокрЛП(Строка(ВыборкаД.Номер)), ""));
					Если ЗначениеЗаполнено(ВыборкаД.Дата) Тогда Договор.Вставить("Дата", Формат(ВыборкаД.Дата, "ДФ=dd.MM.yyyy")); Иначе Договор.Вставить("Дата", ""); КонецЕсли;
					Если ЗначениеЗаполнено(ВыборкаД.СрокДействия) Тогда Договор.Вставить("СрокДействия", Формат(ВыборкаД.СрокДействия, "ДФ=dd.MM.yyyy")); Иначе Договор.Вставить("СрокДействия", ""); КонецЕсли;
					Договор.Вставить("Организация", ?(ЗначениеЗаполнено(ВыборкаД.Организация), СокрЛП(Строка(ВыборкаД.Организация)), ""));
					Договор.Вставить("ВидДоговора", ?(ЗначениеЗаполнено(ВыборкаД.ВидДоговора), СокрЛП(Строка(ВыборкаД.ВидДоговора)), ""));
					Договор.Вставить("Валюта", ?(ЗначениеЗаполнено(ВыборкаД.Валюта), СокрЛП(Строка(ВыборкаД.Валюта)), ""));
					МассивДоговоров.Добавить(Договор);
				КонецЦикла;
				Поставщик.Вставить("Договоры", МассивДоговоров);
			Иначе
				// Сводка по договорам: количество
				ЗапросКолДоговоров = Новый Запрос;
				ЗапросКолДоговоров.Текст =
				"ВЫБРАТЬ
				|	КОЛИЧЕСТВО(Д.Ссылка) КАК Кол
				|ИЗ
				|	Справочник.ДоговорыКонтрагентов КАК Д
				|ГДЕ
				|	Д.Владелец = &Контрагент
				|	И Д.ПометкаУдаления = ЛОЖЬ";
				ЗапросКолДоговоров.УстановитьПараметр("Контрагент", Выборка.Ссылка);
				РезКол = ЗапросКолДоговоров.Выполнить();
				ВыбКол = РезКол.Выбрать();
				КолДог = 0;
				Если ВыбКол.Следующий() Тогда КолДог = ВыбКол.Кол; КонецЕсли;
				ДогСводка = Новый Структура;
				ДогСводка.Вставить("Есть", КолДог > 0);
				ДогСводка.Вставить("Количество", КолДог);
				Поставщик.Вставить("Договоры", ДогСводка);
			КонецЕсли;

			МассивПоставщиков.Добавить(Поставщик);
		КонецЦикла;

		ИтоговыйРезультат = Новый Структура;
		ИтоговыйРезультат.Вставить("data", МассивПоставщиков);
		ИтоговыйРезультат.Вставить("errors", МассивОшибок);
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, ИтоговыйРезультат);
		JSONСтрока = ЗаписьJSON.Закрыть();
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONСтрока);
		Возврат Ответ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ДанныеОшибки = Новый Структура("error", ТекстОшибки);
		JSONОшибки = Новый ЗаписьJSON;
		JSONОшибки.УстановитьСтроку();
		ЗаписатьJSON(JSONОшибки, ДанныеОшибки);
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
		Ответ.УстановитьТелоИзСтроки(JSONОшибки.Закрыть());
		Возврат Ответ;
	КонецПопытки;
КонецФункции
